{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Aspire AppHost",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"ClubBaist.AppHost/ClubBaist.AppHost.csproj"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run RoundScoreDerivationServiceTests",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"--project",
				"ClubBaist.Domain2.Tests/ClubBaist.Domain2.Tests.csproj",
				"--filter",
				"FullyQualifiedName~RoundScoreDerivationServiceTests"
			],
			"isBackground": false
		},
		{
			"label": "Re-run RoundScoreDerivationServiceTests",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"--project",
				"ClubBaist.Domain2.Tests/ClubBaist.Domain2.Tests.csproj",
				"--filter",
				"FullyQualifiedName~RoundScoreDerivationServiceTests"
			],
			"isBackground": false
		}
	]
}