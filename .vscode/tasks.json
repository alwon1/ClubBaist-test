			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"cd /Users/allyn/Repos/ClubBaist-test && echo '---status---' && git status -sb && echo '---remote---' && git remote -v && echo '---branch---' && git branch -vv && echo '---pull.rebase---' && git config --get pull.rebase || true && echo '---pull.ff---' && git config --get pull.ff || true && echo '---fetch---' && git fetch --all --prune && echo '---pull---' && git pull"
			],
			"isBackground": false
		},
