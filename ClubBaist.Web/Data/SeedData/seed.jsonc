{
  /*
   * ClubBaist Seed Data
   * ═══════════════════════════════════════════════════════════════════════
   *
   * INSERTION ORDER  (database FK constraint dependencies)
   * ───────────────────────────────────────────────────────────────────────
   *  1. roles             — no dependencies
   *  2. membershipLevels  — no dependencies
   *  3. users             — depends on: roles  (AspNetUserRoles FK)
   *  4. members           — depends on: users  (MemberShipInfo.UserId FK)
   *                                     levels (MemberShipInfo.MembershipLevelId FK)
   *  5. applications      — depends on: levels  (MembershipApplication.RequestedMembershipLevelId FK)
   *                                     members (MembershipApplication.Sponsor1MemberId /
   *                                              MembershipApplication.Sponsor2MemberId FKs)
   *
   * NOTE: Sponsor FKs are plain int columns with no navigation property — they
   * cannot use $ref and are filled in by the seeder after members are saved
   * (see AppDbContextSeed.SeedApplicationsAsync).
   *
   * ── HOW CROSS-OBJECT REFERENCES WORK ───────────────────────────────────
   * Objects use $id / $ref (System.Text.Json ReferenceHandler.Preserve).
   *   • $id  — must be the FIRST property of the object being labelled.
   *   • $ref — the ONLY property on the referencing object: { "$ref": "some-id" }
   *   • References may only point to $id values that appear EARLIER in the document;
   *     forward references are not supported.
   *
   * ── ADDING A NEW TABLE TO SEEDING ──────────────────────────────────────
   *  1. Add a top-level array here named after the entity (camelCase plural).
   *  2. Add a corresponding List<YourEntity> property to the SeedData record
   *     in AppDbContextSeed.cs.
   *  3. Add a seeding step in SeedAsync() at the correct position in the
   *     insertion order above.
   *       • Set any scalar FK properties from nav property IDs after the
   *         dependency is saved (e.g. member.UserId = member.User.Id).
   *       • Call db.YourDbSet.AddRange(seed.YourEntities) then SaveChangesAsync().
   *  4. If YourEntity has a nav property back to a parent, use a $ref in JSON
   *     (the parent $id must appear before the child in this document).
   */

  // ── 1. Roles ─────────────────────────────────────────────────────────────
  // IdentityRole<Guid>: inserted directly via db.Roles — no RoleManager needed.
  // Id, NormalizedName, and ConcurrencyStamp must be supplied explicitly.
  "roles": [
    {
      "$id": "role-Admin",
      "id": "00000000-0000-0000-0000-000000000001",
      "name": "Admin",
      "normalizedName": "ADMIN",
      "concurrencyStamp": "00000000-0000-0001-0000-000000000001"
    },
    {
      "$id": "role-MembershipCommittee",
      "id": "00000000-0000-0000-0000-000000000002",
      "name": "MembershipCommittee",
      "normalizedName": "MEMBERSHIPCOMMITTEE",
      "concurrencyStamp": "00000000-0000-0001-0000-000000000002"
    },
    {
      "$id": "role-Member",
      "id": "00000000-0000-0000-0000-000000000003",
      "name": "Member",
      "normalizedName": "MEMBER",
      "concurrencyStamp": "00000000-0000-0001-0000-000000000003"
    }
  ],

  // ── 2. Membership Levels ─────────────────────────────────────────────────
  // Each level's availabilities reference their parent level via $ref.
  // DayOfWeek string values: Sunday, Monday, Tuesday, Wednesday, Thursday, Friday, Saturday
  "membershipLevels": [
    {
      "$id": "level-SH",
      "shortCode": "SH",
      "name": "Shareholder",
      // Full access: 7 AM – 7 PM every day of the week
      "availabilities": [
        { "membershipLevel": { "$ref": "level-SH" }, "dayOfWeek": "Sunday",    "startTime": "07:00:00", "endTime": "19:00:00" },
        { "membershipLevel": { "$ref": "level-SH" }, "dayOfWeek": "Monday",    "startTime": "07:00:00", "endTime": "19:00:00" },
