  // ── 4. Members (MemberShipInfo) ──────────────────────────────────────────
  // Only users with a membership level get a MemberShipInfo record.
  // UserId and MembershipLevelId (scalar FKs) are set by the seeder in code after
  // users and levels are saved — their $ref-linked objects already carry the DB IDs.
  // MemberShipInfo.Id is DB-assigned (identity column); the seeder reads it back
  // from these objects after SaveChangesAsync to populate application sponsor FKs.
  "members": [
    {
      "$id": "member-sh1",
      "user": { "$ref": "user-sh1" },
      "membershipLevel": { "$ref": "level-SH" }
    },
    {
      "$id": "member-sh2",
      "user": { "$ref": "user-sh2" },
      "membershipLevel": { "$ref": "level-SH" }
