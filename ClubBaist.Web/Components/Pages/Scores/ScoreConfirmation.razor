@page "/scores/confirmation"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = AppRoles.AdminOrMember)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Domain2.Entities
@using ClubBaist.Domain2.Entities.Scoring
@using ClubBaist.Services2.Scoring

@inject IAppDbContext2 DbContext
@inject RoundScoreDerivationService RoundScoreDerivationService
@inject HandicapCalculationService HandicapCalculationService
@inject CourseHoleReferenceService CourseHoleReferenceService
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<ScoreConfirmation> Logger

<PageTitle>Score Submitted - Club Baist</PageTitle>

<h3 class="mb-4">Score Submitted</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (round is not null)
{
    <div class="card mb-4" style="max-width: 480px;">
        <div class="card-header bg-success text-white">
            <strong>Round Confirmed</strong>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-5">Date</dt>
                <dd class="col-sm-7">@round.TeeTimeBooking.TeeTimeSlotStart.ToString("dddd, MMMM d, yyyy")</dd>

                <dt class="col-sm-5">Time</dt>
                <dd class="col-sm-7">@round.TeeTimeBooking.TeeTimeSlotStart.ToString("h:mm tt")</dd>

                <dt class="col-sm-5">Tee Colour</dt>
                <dd class="col-sm-7">@round.SelectedTeeColor</dd>

                <dt class="col-sm-5">Raw Total Score</dt>
                <dd class="col-sm-7">@scoreView.RawTotal</dd>

                <dt class="col-sm-5">Calculated Adjusted Score</dt>
                <dd class="col-sm-7">@scoreView.AdjustedTotal</dd>

                <dt class="col-sm-5">Current Handicap Index</dt>
                <dd class="col-sm-7">
                    @if (handicapResult?.IsAvailable == true && handicapResult.CurrentHandicap.HasValue)
                    {
                        <span>@handicapResult.CurrentHandicap.Value.ToString("0.0")</span>
                        @if (handicapResult.IsProvisional)
                        {
                            <span class="badge bg-warning text-dark ms-1">Provisional</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">Not available</span>
                    }
                </dd>

                <dt class="col-sm-5">Rounds Used</dt>
                <dd class="col-sm-7">@(handicapResult?.RoundCount ?? 0)</dd>

                <dt class="col-sm-5">Calculation Basis</dt>
                <dd class="col-sm-7 small text-muted">@scoreView.Basis</dd>

                @if (isAdmin)
                {
                    <dt class="col-sm-5">Member</dt>
                    <dd class="col-sm-7">@($"{round.Member.User.FirstName} {round.Member.User.LastName}".Trim())</dd>
                }

                <dt class="col-sm-5">Submitted On</dt>
                <dd class="col-sm-7">@round.SubmittedAt.ToString("MMM d, yyyy h:mm tt")</dd>
            </dl>
        </div>
    </div>

    <div class="d-flex gap-2">
        @if (isAdmin)
        {
            <a href="/scores/staff" class="btn btn-primary">Return to Score Console</a>
        }
        else
        {
            <a href="/scores/my" class="btn btn-primary">Return to My Score Submissions</a>
        }
    </div>
}
else
{
    <div class="alert alert-warning">No submitted round found for this booking.</div>
    <a href="/scores/my" class="btn btn-outline-secondary">Return to My Score Submissions</a>
}

@code {
    [SupplyParameterFromQuery]
    public int BookingId { get; set; }

    [SupplyParameterFromQuery]
    public int MemberId { get; set; }

    private bool isLoading = true;
    private string? errorMessage;

    private GolfRound? round;
    private bool isAdmin;
    private HandicapResult? handicapResult;
    private RoundScoreView scoreView = new(0, 0, false, "No scores loaded");

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            isAdmin = user.IsInRole(AppRoles.Admin);

            if (!isAdmin)
            {
                var userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);
                var currentMember = await DbContext.MemberShips.FirstOrDefaultAsync(m => m.UserId == userId);
                if (currentMember is null || currentMember.Id != MemberId)
                {
                    errorMessage = "Not authorized to view this submission.";
                    isLoading = false;
                    return;
                }
            }

            round = await DbContext.GolfRounds
                .Include(r => r.TeeTimeBooking)
                .Include(r => r.Member).ThenInclude(m => m.User)
                .Where(r => r.TeeTimeBookingId == BookingId && r.MembershipId == MemberId)
                .OrderByDescending(r => r.SubmittedAt)
                .FirstOrDefaultAsync();

            if (round is not null)
            {
                handicapResult = await HandicapCalculationService.GetCurrentHandicapAsync(round.MembershipId, CancellationToken.None);
                scoreView = await DeriveScoreViewAsync(round, handicapResult);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load confirmation for booking {BookingId}, member {MemberId}", BookingId, MemberId);
            errorMessage = "An unexpected error occurred while loading the confirmation. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<RoundScoreView> DeriveScoreViewAsync(GolfRound golfRound, HandicapResult handicap)
    {
        var fallback = RoundScoreDerivationService.Compute(golfRound.Scores);
        if (golfRound.Member.User.Gender is null)
        {
            return fallback with { Basis = "Derived from raw totals (member gender missing for WHS rules)" };
        }

        var gender = golfRound.Member.User.Gender.Value;
        var rating = await DbContext.CourseRatings
            .FirstOrDefaultAsync(r => r.TeeColor == golfRound.SelectedTeeColor && r.Gender == gender);

        if (rating is null)
        {
            return fallback with { Basis = "Derived from raw totals (missing tee/gender course rating for WHS rules)" };
        }

        var hasEstablishedHandicap = handicap.IsAvailable && handicap.RoundCount >= 3;
        var holeRefs = await CourseHoleReferenceService.GetHoleReferencesAsync(golfRound.SelectedTeeColor);
        if (holeRefs.Count != 18)
        {
            return fallback with { Basis = "Derived from raw totals (missing complete hole reference data for WHS rules)" };
        }

        var courseHandicap = CalculateCourseHandicap(handicap.CurrentHandicap, rating.Rating, rating.SlopeRating, holeRefs.Sum(h => h.Par));

        return RoundScoreDerivationService.ComputeWithWhsHoleAdjustments(
            BuildHoleInputs(golfRound.Scores, holeRefs),
            courseHandicap,
            hasEstablishedHandicap && handicap.CurrentHandicap.HasValue);
    }

    private static List<HoleScoreInput> BuildHoleInputs(
        IReadOnlyList<uint?> scores,
        IReadOnlyList<CourseHoleReference> holeRefs)
    {
        var holeInputs = new List<HoleScoreInput>(18);

        for (var i = 0; i < 18; i++)
        {
            var state = scores.Count > i && scores[i].HasValue
                ? HolePlayState.Completed
                : HolePlayState.NotPlayed;

            holeInputs.Add(new HoleScoreInput(
                HoleNumber: i + 1,
                Par: holeRefs[i].Par,
                StrokeIndex: holeRefs[i].StrokeIndex,
                RawScore: scores.Count > i && scores[i].HasValue ? Convert.ToInt32(scores[i]!.Value) : null,
                State: state));
        }

        return holeInputs;
    }

    private static int CalculateCourseHandicap(decimal? handicapIndex, decimal courseRating, int slopeRating, int parTotal)
    {
        if (!handicapIndex.HasValue)
        {
            return 0;
        }

        var rawCourseHandicap = handicapIndex.Value * (slopeRating / 113m) + (courseRating - parTotal);
        return Convert.ToInt32(decimal.Round(rawCourseHandicap, 0, MidpointRounding.AwayFromZero));
    }
}
