@page "/scores/record"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = AppRoles.AdminOrMember)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain
@using ClubBaist.Domain.Entities.Scoring
@using ClubBaist.Services.Scoring

@inject AppDbContext DbContext
@inject ScoreService ScoreService
@inject RoundScoreDerivationService RoundScoreDerivationService
@inject HandicapCalculationService HandicapCalculationService
@inject CourseHoleReferenceService CourseHoleReferenceService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ILogger<RecordScore> Logger

<PageTitle>Record Score - Club Baist</PageTitle>

<h3 class="mb-4">Record Score</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (booking is not null)
{
    <div class="card mb-4">
        <div class="card-header">
            <strong>Round Details</strong>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Date &amp; Time</dt>
                <dd class="col-sm-9">@booking.TeeTimeSlotStart.ToString("dddd, MMMM d, yyyy h:mm tt")</dd>

                <dt class="col-sm-3">Players</dt>
                <dd class="col-sm-9">@booking.ParticipantCount</dd>

                @if (isAdmin && memberName is not null)
                {
                    <dt class="col-sm-3">Member</dt>
                    <dd class="col-sm-9">@memberName</dd>
                }

                <dt class="col-sm-3">Tee Colour</dt>
                <dd class="col-sm-9">
                    <div class="d-flex gap-3">
                        @foreach (var tee in Enum.GetValues<GolfRound.TeeColor>())
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="radio"
                                       name="teeColor"
                                       id="tee-@tee"
                                       value="@tee"
                                       checked="@(selectedTeeColor == tee)"
                                       @onchange="async () => await OnTeeColorChangedAsync(tee)" />
                                <label class="form-check-label" for="tee-@tee">@tee</label>
                            </div>
                        }
                    </div>
                </dd>
            </dl>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <strong>Scorecard</strong>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-sm mb-0 text-center">
                    <thead class="table-light">
                        <tr>
                            <th style="min-width:70px">Hole</th>
                            @for (int i = 0; i < 9; i++)
                            {
                                <th style="min-width:50px">@(i + 1)</th>
                            }
                            <th class="table-secondary" style="min-width:60px">Out</th>
                            @for (int i = 9; i < 18; i++)
                            {
                                <th style="min-width:50px">@(i + 1)</th>
                            }
                            <th class="table-secondary" style="min-width:60px">In</th>
                            <th class="table-dark" style="min-width:60px">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <th class="table-light">Par</th>
                            @for (int i = 0; i < 9; i++)
                            {
                                <td>@holeReferences[i].Par</td>
                            }
                            <td class="table-secondary fw-semibold">@holeReferences.Take(9).Sum(h => h.Par)</td>
                            @for (int i = 9; i < 18; i++)
                            {
                                <td>@holeReferences[i].Par</td>
                            }
                            <td class="table-secondary fw-semibold">@holeReferences.Skip(9).Sum(h => h.Par)</td>
                            <td class="table-dark text-white fw-bold">@holeReferences.Sum(h => h.Par)</td>
                        </tr>
                        <tr>
                            <th class="table-light">Score</th>
                            @for (int i = 0; i < 9; i++)
                            {
                                var holeIndex = i;
                                <td>
                                    <input type="number"
                                           class="form-control form-control-sm p-1 text-center"
                                           style="min-width:48px"
                                           min="1" max="20"
                                           value="@scores[holeIndex]"
                                           @onchange="e => OnScoreChanged(holeIndex, e)" />
                                </td>
                            }
                            <td class="table-secondary fw-semibold">
                                @if (scores.Take(9).All(s => s.HasValue))
                                {
                                    @scores.Take(9).Sum(s => (long?)s)
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            @for (int i = 9; i < 18; i++)
                            {
                                var holeIndex = i;
                                <td>
                                    <input type="number"
                                           class="form-control form-control-sm p-1 text-center"
                                           style="min-width:48px"
                                           min="1" max="20"
                                           value="@scores[holeIndex]"
                                           @onchange="e => OnScoreChanged(holeIndex, e)" />
                                </td>
                            }
                            <td class="table-secondary fw-semibold">
                                @if (scores.Skip(9).All(s => s.HasValue))
                                {
                                    @scores.Skip(9).Sum(s => (long?)s)
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="table-dark text-white fw-bold">
                                @if (scores.All(s => s.HasValue))
                                {
                                    @scores.Sum(s => (long?)s)
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-success"
                disabled="@(!AllScoresEntered)"
                @onclick="HandleSubmit">
            Submit Round
        </button>
        @if (!AllScoresEntered)
        {
            <span class="text-muted small">All 18 hole scores are required before submitting.</span>
        }
    </div>

    <div class="mt-3 small text-muted">
        <div>Raw Total: @DerivedScore.RawTotal</div>
        <div>Calculated Adjusted: @DerivedScore.AdjustedTotal</div>
        <div>@DerivedScore.Basis</div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public int BookingId { get; set; }

    [SupplyParameterFromQuery]
    public int MemberId { get; set; }

    private bool isLoading = true;
    private string? errorMessage;

    private TeeTimeBooking? booking;
    private bool isAdmin;
    private string? memberName;

    private uint?[] scores = new uint?[18];
    private GolfRound.TeeColor selectedTeeColor = GolfRound.TeeColor.White;
    private IReadOnlyList<CourseHoleReference> holeReferences = DefaultHoleReferences;

    private static readonly IReadOnlyList<CourseHoleReference> DefaultHoleReferences =
    [
        new(1, 4, 1), new(2, 5, 2), new(3, 3, 3), new(4, 4, 4), new(5, 4, 5), new(6, 4, 6),
        new(7, 4, 7), new(8, 5, 8), new(9, 4, 9), new(10, 4, 10), new(11, 4, 11), new(12, 3, 12),
        new(13, 5, 13), new(14, 4, 14), new(15, 4, 15), new(16, 3, 16), new(17, 5, 17), new(18, 4, 18)
    ];

    private bool AllScoresEntered => scores.All(s => s.HasValue);
    private RoundScoreView DerivedScore => DeriveScorePreview();

    private Dictionary<GolfRound.TeeColor, CourseRating> ratingsByTeeColor = [];
    private decimal? currentHandicapIndex;
    private bool hasEstablishedHandicap;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            isAdmin = user.IsInRole(AppRoles.Admin);

            booking = await DbContext.TeeTimeBookings
                .Include(b => b.BookingMember).ThenInclude(m => m.User)
                .Include(b => b.AdditionalParticipants)
                .FirstOrDefaultAsync(b => b.Id == BookingId);

            if (booking is null)
            {
                errorMessage = "Booking not found.";
                isLoading = false;
                return;
            }

            if (isAdmin)
            {
                memberName = $"{booking.BookingMember.User.FirstName} {booking.BookingMember.User.LastName}".Trim();
                MemberId = booking.BookingMemberId;
            }
            else
            {
                var userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);
                var member = await DbContext.MemberShips
                    .FirstOrDefaultAsync(m => m.UserId == userId);

                if (member is null || member.Id != booking.BookingMemberId)
                {
                    errorMessage = "Not authorized to record a score for this booking.";
                    isLoading = false;
                    return;
                }

                MemberId = member.Id;
            }

            await LoadDerivationInputsAsync();
            await LoadHoleReferencesAsync(selectedTeeColor);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load booking {BookingId} for score entry", BookingId);
            errorMessage = "An unexpected error occurred while loading the booking. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDerivationInputsAsync()
    {
        var member = await DbContext.MemberShips
            .Include(m => m.User)
            .FirstOrDefaultAsync(m => m.Id == MemberId);

        if (member?.User.Gender is null)
        {
            ratingsByTeeColor = [];
            currentHandicapIndex = null;
            hasEstablishedHandicap = false;
            return;
        }

        ratingsByTeeColor = await DbContext.CourseRatings
            .Where(r => r.Gender == member.User.Gender.Value)
            .ToDictionaryAsync(r => r.TeeColor);

        var handicapResult = await HandicapCalculationService.GetCurrentHandicapAsync(MemberId, CancellationToken.None);
        currentHandicapIndex = handicapResult.CurrentHandicap;
        hasEstablishedHandicap = handicapResult.IsAvailable && handicapResult.RoundCount >= 3;
    }

    private RoundScoreView DeriveScorePreview()
    {
        var fallback = RoundScoreDerivationService.Compute(scores);
        if (holeReferences.Count != 18)
        {
            return fallback;
        }

        if (!ratingsByTeeColor.TryGetValue(selectedTeeColor, out var rating))
        {
            return fallback;
        }

        var courseHandicap = CalculateCourseHandicap(currentHandicapIndex, rating.Rating, rating.SlopeRating, holeReferences.Sum(h => h.Par));
        return RoundScoreDerivationService.ComputeWithWhsHoleAdjustments(
            BuildHoleInputs(scores, holeReferences),
            courseHandicap,
            hasEstablishedHandicap && currentHandicapIndex.HasValue);
    }

    private static List<HoleScoreInput> BuildHoleInputs(
        IReadOnlyList<uint?> scoreValues,
        IReadOnlyList<CourseHoleReference> references)
    {
        var holeInputs = new List<HoleScoreInput>(18);

        for (var i = 0; i < 18; i++)
        {
            var state = scoreValues.Count > i && scoreValues[i].HasValue
                ? HolePlayState.Completed
                : HolePlayState.NotPlayed;

            holeInputs.Add(new HoleScoreInput(
                HoleNumber: i + 1,
                Par: references[i].Par,
                StrokeIndex: references[i].StrokeIndex,
                RawScore: scoreValues.Count > i && scoreValues[i].HasValue ? Convert.ToInt32(scoreValues[i]!.Value) : null,
                State: state));
        }

        return holeInputs;
    }

    private static int CalculateCourseHandicap(decimal? handicapIndex, decimal courseRating, int slopeRating, int parTotal)
    {
        if (!handicapIndex.HasValue)
        {
            return 0;
        }

        var rawCourseHandicap = handicapIndex.Value * (slopeRating / 113m) + (courseRating - parTotal);
        return Convert.ToInt32(decimal.Round(rawCourseHandicap, 0, MidpointRounding.AwayFromZero));
    }

    private async Task OnTeeColorChangedAsync(GolfRound.TeeColor tee)
    {
        selectedTeeColor = tee;
        await LoadHoleReferencesAsync(tee);
    }

    private async Task LoadHoleReferencesAsync(GolfRound.TeeColor teeColor)
    {
        holeReferences = await CourseHoleReferenceService.GetHoleReferencesAsync(teeColor);
    }

    private void OnScoreChanged(int holeIndex, ChangeEventArgs e)
    {
        if (uint.TryParse(e.Value?.ToString(), out var value) && value >= 1 && value <= 20)
        {
            scores[holeIndex] = value;
        }
        else
        {
            scores[holeIndex] = null;
        }
    }

    private async Task HandleSubmit()
    {
        if (!AllScoresEntered)
            return;

        errorMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var actingUserId = user.FindFirstValue(ClaimTypes.NameIdentifier)!;

            var result = await ScoreService.SubmitRoundAsync(
                BookingId, MemberId, selectedTeeColor, scores.ToList(), actingUserId);

            if (result.Success)
            {
                NavigationManager.NavigateTo($"/scores/confirmation?bookingId={BookingId}&memberId={MemberId}");
            }
            else
            {
                errorMessage = result.Error ?? "Score submission failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to submit round for booking {BookingId}", BookingId);
            errorMessage = "An unexpected error occurred while submitting the score. Please try again later.";
        }
    }
}
