@page "/scores/my"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.Member)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Domain2.Entities
@using ClubBaist.Domain2.Entities.Scoring
@using ClubBaist.Services2.Scoring

@inject IAppDbContext2 DbContext
@inject ScoreService ScoreService
@inject RoundScoreDerivationService RoundScoreDerivationService
@inject HandicapCalculationService HandicapCalculationService
@inject CourseHoleReferenceService CourseHoleReferenceService
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<MyScoreSubmissions> Logger

<PageTitle>My Score Submissions - Club Baist</PageTitle>

<h3 class="mb-4">My Score Submissions</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <h5 class="mt-3 mb-2">Eligible rounds available to score</h5>

    @if (eligibleBookings is { Count: > 0 })
    {
        <QuickGrid Items="@eligibleBookings.AsQueryable()" Class="table table-striped">
            <TemplateColumn Title="Date" SortBy="@(GridSort<TeeTimeBooking>.ByDescending(b => b.TeeTimeSlotStart))">
                @context.TeeTimeSlotStart.ToString("MMM d, yyyy")
            </TemplateColumn>
            <TemplateColumn Title="Time" SortBy="@(GridSort<TeeTimeBooking>.ByDescending(b => b.TeeTimeSlotStart))">
                @context.TeeTimeSlotStart.ToString("h:mm tt")
            </TemplateColumn>
            <TemplateColumn Title="Players">
                @context.ParticipantCount
            </TemplateColumn>
            <TemplateColumn Title="Action">
                <a href="@($"/scores/record?bookingId={context.Id}&memberId={currentMemberId}")"
                   class="btn btn-sm btn-primary">
                    Record Score
                </a>
            </TemplateColumn>
        </QuickGrid>
    }
    else
    {
        <div class="alert alert-info">No eligible rounds available to score at this time.</div>
    }

    <h5 class="mt-4 mb-2">Past Submitted Rounds</h5>

    @if (pastRounds is { Count: > 0 })
    {
        <QuickGrid Items="@pastRounds.AsQueryable()" Class="table table-striped">
            <TemplateColumn Title="Date" SortBy="@(GridSort<GolfRound>.ByDescending(r => r.TeeTimeBooking.TeeTimeSlotStart))">
                @context.TeeTimeBooking.TeeTimeSlotStart.ToString("MMM d, yyyy")
            </TemplateColumn>
            <TemplateColumn Title="Tee" SortBy="@(GridSort<GolfRound>.ByAscending(r => r.SelectedTeeColor))">
                @context.SelectedTeeColor
            </TemplateColumn>
            <TemplateColumn Title="Raw Total Score">
                @GetDerivedScore(context).RawTotal
            </TemplateColumn>
            <TemplateColumn Title="Calculated Adjusted Score">
                @GetDerivedScore(context).AdjustedTotal
            </TemplateColumn>
            <TemplateColumn Title="Submitted On" SortBy="@(GridSort<GolfRound>.ByDescending(r => r.SubmittedAt))">
                @context.SubmittedAt.ToString("MMM d, yyyy h:mm tt")
            </TemplateColumn>
        </QuickGrid>
    }
    else
    {
        <div class="alert alert-info">No submitted rounds on record.</div>
    }
}

@code {
    private bool isLoading = true;
    private string? errorMessage;

    private int currentMemberId;
    private IReadOnlyList<TeeTimeBooking> eligibleBookings = [];
    private IReadOnlyList<GolfRound> pastRounds = [];
    private Dictionary<int, RoundScoreView> derivedRoundScores = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);

            var member = await DbContext.MemberShips
                .Include(m => m.User)
                .FirstOrDefaultAsync(m => m.UserId == userId);

            if (member is null)
            {
                errorMessage = "Member account not found.";
                isLoading = false;
                return;
            }

            currentMemberId = member.Id;

            eligibleBookings = await ScoreService.GetEligibleBookingsAsync(currentMemberId);
            pastRounds = await ScoreService.GetRoundsByMemberAsync(currentMemberId);

            await PopulateDerivedRoundScoresAsync(member, pastRounds);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load score submissions");
            errorMessage = "An unexpected error occurred while loading your score submissions. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PopulateDerivedRoundScoresAsync(MemberShipInfo member, IReadOnlyList<GolfRound> rounds)
    {
        derivedRoundScores = [];

        var fallback = rounds.ToDictionary(
            round => round.Id,
            round => RoundScoreDerivationService.Compute(round.Scores));

        if (rounds.Count == 0)
        {
            derivedRoundScores = fallback;
            return;
        }

        if (member.User.Gender is null)
        {
            derivedRoundScores = fallback;
            return;
        }

        var gender = member.User.Gender.Value;
        var handicapResult = await HandicapCalculationService.GetCurrentHandicapAsync(member.Id, CancellationToken.None);
        var hasEstablishedHandicap = handicapResult.IsAvailable && handicapResult.RoundCount >= 3;

        var ratingsByTee = await DbContext.CourseRatings
            .Where(r => r.Gender == gender)
            .ToDictionaryAsync(r => r.TeeColor);

        var holeRefsByTee = new Dictionary<GolfRound.TeeColor, IReadOnlyList<CourseHoleReference>>();
        foreach (var teeColor in rounds.Select(r => r.SelectedTeeColor).Distinct())
        {
            holeRefsByTee[teeColor] = await CourseHoleReferenceService.GetHoleReferencesAsync(teeColor);
        }

        foreach (var round in rounds)
        {
            if (!ratingsByTee.TryGetValue(round.SelectedTeeColor, out var rating))
            {
                derivedRoundScores[round.Id] = fallback[round.Id];
                continue;
            }

            if (!holeRefsByTee.TryGetValue(round.SelectedTeeColor, out var holeRefs) || holeRefs.Count != 18)
            {
                derivedRoundScores[round.Id] = fallback[round.Id];
                continue;
            }

            var courseHandicap = CalculateCourseHandicap(
                handicapResult.CurrentHandicap,
                rating.Rating,
                rating.SlopeRating,
                holeRefs.Sum(h => h.Par));

            var holeInputs = BuildHoleInputs(round.Scores, holeRefs);
            derivedRoundScores[round.Id] = RoundScoreDerivationService.ComputeWithWhsHoleAdjustments(
                holeInputs,
                courseHandicap,
                hasEstablishedHandicap && handicapResult.CurrentHandicap.HasValue);
        }
    }

    private static List<HoleScoreInput> BuildHoleInputs(
        IReadOnlyList<uint?> scores,
        IReadOnlyList<CourseHoleReference> holeRefs)
    {
        var holeInputs = new List<HoleScoreInput>(18);

        for (var i = 0; i < 18; i++)
        {
            var state = scores.Count > i && scores[i].HasValue
                ? HolePlayState.Completed
                : HolePlayState.NotPlayed;

            holeInputs.Add(new HoleScoreInput(
                HoleNumber: i + 1,
                Par: holeRefs[i].Par,
                StrokeIndex: holeRefs[i].StrokeIndex,
                RawScore: scores.Count > i && scores[i].HasValue ? Convert.ToInt32(scores[i]!.Value) : null,
                State: state));
        }

        return holeInputs;
    }

    private static int CalculateCourseHandicap(decimal? handicapIndex, decimal courseRating, int slopeRating, int parTotal)
    {
        if (!handicapIndex.HasValue)
        {
            return 0;
        }

        var rawCourseHandicap = handicapIndex.Value * (slopeRating / 113m) + (courseRating - parTotal);
        return Convert.ToInt32(decimal.Round(rawCourseHandicap, 0, MidpointRounding.AwayFromZero));
    }

    private RoundScoreView GetDerivedScore(GolfRound round)
    {
        if (derivedRoundScores.TryGetValue(round.Id, out var derived))
        {
            return derived;
        }

        return RoundScoreDerivationService.Compute(round.Scores);
    }
}
