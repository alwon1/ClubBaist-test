@page "/membership/apply"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain
@using ClubBaist.Domain.Entities.Membership
@using ClubBaist.Services
@using ClubBaist.Services.Membership.Applications

@inject MembershipApplicationService ApplicationService
@inject AppDbContext DbContext
@inject ILogger<Apply> Logger
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Apply for Membership</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">Apply for Membership</h2>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success" role="alert">
            @_successMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @_errorMessage
        </div>
    }

    @if (!_submitted)
    {
        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="applyForm">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" />

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="email" class="form-control" @bind-Value="_model.Email" placeholder="Email" autocomplete="username" />
                                <label for="email">Email Address</label>
                                <ValidationMessage For="() => _model.Email" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="firstName" class="form-control" @bind-Value="_model.FirstName" placeholder="First Name" />
                                <label for="firstName">First Name</label>
                                <ValidationMessage For="() => _model.FirstName" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="lastName" class="form-control" @bind-Value="_model.LastName" placeholder="Last Name" />
                                <label for="lastName">Last Name</label>
                                <ValidationMessage For="() => _model.LastName" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputDate id="dateOfBirth" class="form-control" @bind-Value="_model.DateOfBirth" placeholder="Date of Birth" />
                                <label for="dateOfBirth">Date of Birth</label>
                                <ValidationMessage For="() => _model.DateOfBirth" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="phone" class="form-control" @bind-Value="_model.Phone" placeholder="Phone" />
                                <label for="phone">Phone (e.g. (403) 555-1234)</label>
                                <ValidationMessage For="() => _model.Phone" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="alternatePhone" class="form-control" @bind-Value="_model.AlternatePhone" placeholder="Alternate Phone" />
                                <label for="alternatePhone">Alternate Phone (Optional)</label>
                                <ValidationMessage For="() => _model.AlternatePhone" />
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <InputText id="address" class="form-control" @bind-Value="_model.Address" placeholder="Address" />
                        <label for="address">Address</label>
                        <ValidationMessage For="() => _model.Address" />
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-floating mb-3">
                                <InputText id="postalCode" class="form-control" @bind-Value="_model.PostalCode" placeholder="Postal Code" />
                                <label for="postalCode">Postal Code (e.g. T2A 4K3)</label>
                                <ValidationMessage For="() => _model.PostalCode" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Employment Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="occupation" class="form-control" @bind-Value="_model.Occupation" placeholder="Occupation" />
                                <label for="occupation">Occupation</label>
                                <ValidationMessage For="() => _model.Occupation" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="companyName" class="form-control" @bind-Value="_model.CompanyName" placeholder="Company Name" />
                                <label for="companyName">Company Name</label>
                                <ValidationMessage For="() => _model.CompanyName" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Membership Details</h5>
                </div>
                <div class="card-body">
                    <div class="form-floating mb-3">
                        <InputSelect id="membershipLevel" class="form-select" @bind-Value="_model.RequestedMembershipLevelId">
                            <option value="">-- Select Level --</option>
                            @foreach (var level in _levels)
                            {
                                <option value="@level.Id">@level.Name (@level.MemberType) — @level.AnnualFee.ToString("C0")/yr</option>
                            }
                        </InputSelect>
                        <label for="membershipLevel">Membership Level</label>
                        <ValidationMessage For="() => _model.RequestedMembershipLevelId" />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                @if (_isStaffOrAdmin)
                                {
                                    <label class="form-label fw-semibold">Sponsor 1</label>
                                    <div class="input-group mb-1">
                                        <input type="text" class="form-control" id="sponsor1Search"
                                               placeholder="Search by name..."
                                               value="@_sponsor1SearchTerm"
                                               @oninput="e => OnSponsorSearchInput(1, e.Value?.ToString() ?? string.Empty)" />
                                        @if (_sponsor1LookupName is not null)
                                        {
                                            <button type="button" class="btn btn-outline-secondary" @onclick="() => ClearSponsor(1)">✕</button>
                                        }
                                    </div>
                                    @if (_sponsor1SearchResults.Count > 0 && _model.Sponsor1MemberId is null)
                                    {
                                        <div class="list-group mb-1">
                                            @foreach (var m in _sponsor1SearchResults)
                                            {
                                                var displayName1 = $"{m.User.FirstName} {m.User.LastName} (#{m.MembershipNumber})";
                                                <button type="button" class="list-group-item list-group-item-action py-1"
                                                        @onclick="() => SelectSponsor(1, m.Id, displayName1)">
                                                    @m.User.FirstName @m.User.LastName — Member #@m.MembershipNumber
                                                </button>
                                            }
                                        </div>
                                    }
                                    @if (_sponsor1LookupName is not null)
                                    {
                                        <div class="text-success small mb-1"><span class="bi bi-check-circle-fill me-1"></span>@_sponsor1LookupName</div>
                                    }
                                }
                                else
                                {
                                    <div class="form-floating mb-1">
                                        <InputNumber id="sponsor1" class="form-control" @bind-Value="_model.Sponsor1MemberId"
                                                     placeholder="Sponsor 1 Member ID"
                                                     @oninput="e => OnSponsorIdInput(1, e.Value?.ToString() ?? string.Empty)" />
                                        <label for="sponsor1">Sponsor 1 Member ID</label>
                                    </div>
                                    @if (_sponsor1LookupName is not null)
                                    {
                                        <div class="text-success small"><span class="bi bi-check-circle-fill me-1"></span>@_sponsor1LookupName</div>
                                    }
                                    else if (_sponsor1LookupError is not null)
                                    {
                                        <div class="text-danger small">@_sponsor1LookupError</div>
                                    }
                                    else if (_sponsor1Loading)
                                    {
                                        <div class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span>Looking up member...</div>
                                    }
                                }
                                <ValidationMessage For="() => _model.Sponsor1MemberId" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                @if (_isStaffOrAdmin)
                                {
                                    <label class="form-label fw-semibold">Sponsor 2</label>
                                    <div class="input-group mb-1">
                                        <input type="text" class="form-control" id="sponsor2Search"
                                               placeholder="Search by name..."
                                               value="@_sponsor2SearchTerm"
                                               @oninput="e => OnSponsorSearchInput(2, e.Value?.ToString() ?? string.Empty)" />
                                        @if (_sponsor2LookupName is not null)
                                        {
                                            <button type="button" class="btn btn-outline-secondary" @onclick="() => ClearSponsor(2)">✕</button>
                                        }
                                    </div>
                                    @if (_sponsor2SearchResults.Count > 0 && _model.Sponsor2MemberId is null)
                                    {
                                        <div class="list-group mb-1">
                                            @foreach (var m in _sponsor2SearchResults)
                                            {
                                                var displayName2 = $"{m.User.FirstName} {m.User.LastName} (#{m.MembershipNumber})";
                                                <button type="button" class="list-group-item list-group-item-action py-1"
                                                        @onclick="() => SelectSponsor(2, m.Id, displayName2)">
                                                    @m.User.FirstName @m.User.LastName — Member #@m.MembershipNumber
                                                </button>
                                            }
                                        </div>
                                    }
                                    @if (_sponsor2LookupName is not null)
                                    {
                                        <div class="text-success small mb-1"><span class="bi bi-check-circle-fill me-1"></span>@_sponsor2LookupName</div>
                                    }
                                }
                                else
                                {
                                    <div class="form-floating mb-1">
                                        <InputNumber id="sponsor2" class="form-control" @bind-Value="_model.Sponsor2MemberId"
                                                     placeholder="Sponsor 2 Member ID"
                                                     @oninput="e => OnSponsorIdInput(2, e.Value?.ToString() ?? string.Empty)" />
                                        <label for="sponsor2">Sponsor 2 Member ID</label>
                                    </div>
                                    @if (_sponsor2LookupName is not null)
                                    {
                                        <div class="text-success small"><span class="bi bi-check-circle-fill me-1"></span>@_sponsor2LookupName</div>
                                    }
                                    else if (_sponsor2LookupError is not null)
                                    {
                                        <div class="text-danger small">@_sponsor2LookupError</div>
                                    }
                                    else if (_sponsor2Loading)
                                    {
                                        <div class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span>Looking up member...</div>
                                    }
                                }
                                <ValidationMessage For="() => _model.Sponsor2MemberId" />
                            </div>
                        </div>
                    </div>

                    @if (_isStaffOrAdmin)
                    {
                        <div class="mb-3">
                            <div class="form-check">
                                <InputCheckbox id="endorsementConfirm" class="form-check-input" @bind-Value="_model.SponsorEndorsementConfirmed" />
                                <label class="form-check-label" for="endorsementConfirm">
                                    I confirm that both sponsors have reviewed and endorsed this application in person.
                                </label>
                            </div>
                            <ValidationMessage For="() => _model.SponsorEndorsementConfirmed" />
                        </div>
                    }
                </div>
            </div>

            <div class="mb-4">
                <button type="submit" class="btn btn-primary" disabled="@_submitting">
                    @if (_submitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Submit Application
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    private ApplicationFormModel _model = new();
    private List<MembershipLevel> _levels = [];
    private bool _submitting;
    private bool _submitted;
    private string? _successMessage;
    private string? _errorMessage;
    private bool _isStaffOrAdmin;

    // Sponsor 1 state
    private string _sponsor1SearchTerm = string.Empty;
    private List<MemberShipInfo> _sponsor1SearchResults = [];
    private string? _sponsor1LookupName;
    private string? _sponsor1LookupError;
    private bool _sponsor1Loading;
    private CancellationTokenSource? _sponsor1Debounce;

    // Sponsor 2 state
    private string _sponsor2SearchTerm = string.Empty;
    private List<MemberShipInfo> _sponsor2SearchResults = [];
    private string? _sponsor2LookupName;
    private string? _sponsor2LookupError;
    private bool _sponsor2Loading;
    private CancellationTokenSource? _sponsor2Debounce;

    protected override async Task OnInitializedAsync()
    {
        _levels = await DbContext.MembershipLevels.ToListAsync();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isStaffOrAdmin = user.IsInRole(AppRoles.Admin)
                       || user.IsInRole(AppRoles.MembershipCommittee);
    }

    private async Task OnSponsorIdInput(int sponsorNumber, string rawValue)
    {
        if (!int.TryParse(rawValue, out var memberId) || memberId <= 0)
        {
            SetSponsorLookup(sponsorNumber, null, null, false);
            return;
        }

        SetSponsorLookup(sponsorNumber, null, null, true);
        StateHasChanged();

        var cts = new CancellationTokenSource();
        if (sponsorNumber == 1)
        {
            var old1 = _sponsor1Debounce;
            _sponsor1Debounce = cts;
            old1?.Cancel();
            old1?.Dispose();
        }
        else
        {
            var old2 = _sponsor2Debounce;
            _sponsor2Debounce = cts;
            old2?.Cancel();
            old2?.Dispose();
        }

        try
        {
            await Task.Delay(400, cts.Token);
            var member = await DbContext.MemberShips
                .Include(m => m.User)
                .FirstOrDefaultAsync(m => m.Id == memberId, cts.Token);

            if (member is not null)
                SetSponsorLookup(sponsorNumber, $"{member.User.FirstName} {member.User.LastName} (#{member.MembershipNumber})", null, false);
            else
                SetSponsorLookup(sponsorNumber, null, "Member ID not found.", false);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error looking up sponsor member ID");
            SetSponsorLookup(sponsorNumber, null, "Error looking up member.", false);
        }
        finally
        {
            cts.Dispose();
        }

        StateHasChanged();
    }

    private async Task OnSponsorSearchInput(int sponsorNumber, string term)
    {
        if (sponsorNumber == 1) _sponsor1SearchTerm = term;
        else _sponsor2SearchTerm = term;

        if (string.IsNullOrWhiteSpace(term))
        {
            if (sponsorNumber == 1) _sponsor1SearchResults = [];
            else _sponsor2SearchResults = [];
            StateHasChanged();
            return;
        }

        var cts = new CancellationTokenSource();
        if (sponsorNumber == 1)
        {
            var old1 = _sponsor1Debounce;
            _sponsor1Debounce = cts;
            old1?.Cancel();
            old1?.Dispose();
        }
        else
        {
            var old2 = _sponsor2Debounce;
            _sponsor2Debounce = cts;
            old2?.Cancel();
            old2?.Dispose();
        }

        try
        {
            await Task.Delay(300, cts.Token);
            var pattern = $"%{term.Trim()}%";
            var results = await DbContext.MemberShips
                .Include(m => m.User)
                .Where(m => EF.Functions.Like(m.User.FirstName, pattern)
                         || EF.Functions.Like(m.User.LastName, pattern))
                .OrderBy(m => m.User.LastName)
                .ThenBy(m => m.User.FirstName)
                .Take(10)
                .ToListAsync(cts.Token);

            if (sponsorNumber == 1) _sponsor1SearchResults = results;
            else _sponsor2SearchResults = results;
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching sponsors");
        }
        finally
        {
            cts.Dispose();
        }

        StateHasChanged();
    }

    private void SelectSponsor(int sponsorNumber, int memberId, string displayName)
    {
        if (sponsorNumber == 1)
        {
            _model.Sponsor1MemberId = memberId;
            _sponsor1LookupName = displayName;
            _sponsor1SearchResults = [];
            _sponsor1SearchTerm = displayName;
        }
        else
        {
            _model.Sponsor2MemberId = memberId;
            _sponsor2LookupName = displayName;
            _sponsor2SearchResults = [];
            _sponsor2SearchTerm = displayName;
        }
    }

    private void ClearSponsor(int sponsorNumber)
    {
        if (sponsorNumber == 1)
        {
            _model.Sponsor1MemberId = null;
            _sponsor1LookupName = null;
            _sponsor1SearchTerm = string.Empty;
            _sponsor1SearchResults = [];
        }
        else
        {
            _model.Sponsor2MemberId = null;
            _sponsor2LookupName = null;
            _sponsor2SearchTerm = string.Empty;
            _sponsor2SearchResults = [];
        }
    }

    private void SetSponsorLookup(int sponsorNumber, string? name, string? error, bool loading)
    {
        if (sponsorNumber == 1)
        {
            _sponsor1LookupName = name;
            _sponsor1LookupError = error;
            _sponsor1Loading = loading;
        }
        else
        {
            _sponsor2LookupName = name;
            _sponsor2LookupError = error;
            _sponsor2Loading = loading;
        }
    }

    private async Task HandleSubmitAsync()
    {
        _submitting = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            if (_isStaffOrAdmin && !_model.SponsorEndorsementConfirmed)
            {
                _errorMessage = "You must confirm that both sponsors have endorsed this application.";
                _submitting = false;
                return;
            }

            if (_model.Sponsor1MemberId == _model.Sponsor2MemberId)
            {
                _errorMessage = "Sponsor 1 and Sponsor 2 must be different members.";
                _submitting = false;
                return;
            }

            var sponsor1Exists = await DbContext.MemberShips
                .AnyAsync(m => m.Id == _model.Sponsor1MemberId!.Value);

            if (!sponsor1Exists)
            {
                _errorMessage = "Sponsor 1 member ID was not found.";
                _submitting = false;
                return;
            }

            var sponsor2Exists = await DbContext.MemberShips
                .AnyAsync(m => m.Id == _model.Sponsor2MemberId!.Value);

            if (!sponsor2Exists)
            {
                _errorMessage = "Sponsor 2 member ID was not found.";
                _submitting = false;
                return;
            }

            var normalizedPostalCode = NormalizePostalCode(_model.PostalCode!);

            var application = new MembershipApplication
            {
                FirstName = _model.FirstName!,
                LastName = _model.LastName!,
                Email = _model.Email!,
                DateOfBirth = _model.DateOfBirth,
                Phone = _model.Phone!,
                AlternatePhone = _model.AlternatePhone,
                Address = _model.Address!,
                PostalCode = normalizedPostalCode,
                Occupation = _model.Occupation!,
                CompanyName = _model.CompanyName!,
                RequestedMembershipLevelId = _model.RequestedMembershipLevelId!.Value,
                RequestedMembershipLevel = (await DbContext.MembershipLevels.FindAsync(_model.RequestedMembershipLevelId!.Value))!,
                Sponsor1MemberId = _model.Sponsor1MemberId!.Value,
                Sponsor2MemberId = _model.Sponsor2MemberId!.Value
            };

            await ApplicationService.SubmitMembershipApplicationAsync(application);

            _successMessage = "Your membership application has been submitted successfully. You will be notified once your application has been reviewed.";
            _submitted = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to submit membership application");
            _errorMessage = "An unexpected error occurred while submitting your application. Please try again later.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string NormalizePostalCode(string postalCode)
    {
        var cleaned = postalCode.ToUpperInvariant().Replace(" ", "");
        return cleaned.Length == 6 ? $"{cleaned[..3]} {cleaned[3..]}" : postalCode.ToUpperInvariant();
    }

    private sealed class ApplicationFormModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string? Email { get; set; }

        [Required(ErrorMessage = "First name is required.")]
        public string? FirstName { get; set; }

        [Required(ErrorMessage = "Last name is required.")]
        public string? LastName { get; set; }

        [Required(ErrorMessage = "Occupation is required.")]
        public string? Occupation { get; set; }

        [Required(ErrorMessage = "Company name is required.")]
        public string? CompanyName { get; set; }

        [Required(ErrorMessage = "Address is required.")]
        public string? Address { get; set; }

        [Required(ErrorMessage = "Postal code is required.")]
        [RegularExpression(@"^[A-Za-z]\d[A-Za-z]\s?\d[A-Za-z]\d$", ErrorMessage = "Enter a valid Canadian postal code (e.g. T2A 4K3).")]
        public string? PostalCode { get; set; }

        [Required(ErrorMessage = "Phone number is required.")]
        [RegularExpression(@"^\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$", ErrorMessage = "Enter a valid 10-digit Canadian phone number (e.g. (403) 555-1234).")]
        public string? Phone { get; set; }

        [Required(ErrorMessage = "Date of birth is required.")]
        public DateTime DateOfBirth { get; set; } = DateTime.Today.AddYears(-30);

        [RegularExpression(@"^\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$", ErrorMessage = "Enter a valid 10-digit Canadian phone number (e.g. (403) 555-1234).")]
        public string? AlternatePhone { get; set; }

        [Required(ErrorMessage = "Membership level is required.")]
        public int? RequestedMembershipLevelId { get; set; }

        [Required(ErrorMessage = "Sponsor 1 member ID is required.")]
        public int? Sponsor1MemberId { get; set; }

        [Required(ErrorMessage = "Sponsor 2 member ID is required.")]
        public int? Sponsor2MemberId { get; set; }

        // Only used and validated when submitted by staff/admin/committee
        public bool SponsorEndorsementConfirmed { get; set; }
    }
}
