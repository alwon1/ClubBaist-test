@page "/membership/apply"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Domain2.Entities.Membership
@using ClubBaist.Services2
@using ClubBaist.Services2.Membership.Applications

@inject MembershipApplicationService ApplicationService
@inject IAppDbContext2 DbContext
@inject ILogger<Apply> Logger

<PageTitle>Apply for Membership</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">Apply for Membership</h2>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success" role="alert">
            @_successMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @_errorMessage
        </div>
    }

    @if (!_submitted)
    {
        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="applyForm">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" />

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="email" class="form-control" @bind-Value="_model.Email" placeholder="Email" autocomplete="username" />
                                <label for="email">Email Address</label>
                                <ValidationMessage For="() => _model.Email" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="firstName" class="form-control" @bind-Value="_model.FirstName" placeholder="First Name" />
                                <label for="firstName">First Name</label>
                                <ValidationMessage For="() => _model.FirstName" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="lastName" class="form-control" @bind-Value="_model.LastName" placeholder="Last Name" />
                                <label for="lastName">Last Name</label>
                                <ValidationMessage For="() => _model.LastName" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputDate id="dateOfBirth" class="form-control" @bind-Value="_model.DateOfBirth" placeholder="Date of Birth" />
                                <label for="dateOfBirth">Date of Birth</label>
                                <ValidationMessage For="() => _model.DateOfBirth" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="phone" class="form-control" @bind-Value="_model.Phone" placeholder="Phone" />
                                <label for="phone">Phone (e.g. (403) 555-1234)</label>
                                <ValidationMessage For="() => _model.Phone" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="alternatePhone" class="form-control" @bind-Value="_model.AlternatePhone" placeholder="Alternate Phone" />
                                <label for="alternatePhone">Alternate Phone (Optional)</label>
                                <ValidationMessage For="() => _model.AlternatePhone" />
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <InputText id="address" class="form-control" @bind-Value="_model.Address" placeholder="Address" />
                        <label for="address">Address</label>
                        <ValidationMessage For="() => _model.Address" />
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-floating mb-3">
                                <InputText id="postalCode" class="form-control" @bind-Value="_model.PostalCode" placeholder="Postal Code" />
                                <label for="postalCode">Postal Code (e.g. T2A 4K3)</label>
                                <ValidationMessage For="() => _model.PostalCode" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Employment Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="occupation" class="form-control" @bind-Value="_model.Occupation" placeholder="Occupation" />
                                <label for="occupation">Occupation</label>
                                <ValidationMessage For="() => _model.Occupation" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="companyName" class="form-control" @bind-Value="_model.CompanyName" placeholder="Company Name" />
                                <label for="companyName">Company Name</label>
                                <ValidationMessage For="() => _model.CompanyName" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Membership Details</h5>
                </div>
                <div class="card-body">
                    <div class="form-floating mb-3">
                        <InputSelect id="membershipLevel" class="form-select" @bind-Value="_model.RequestedMembershipLevelId">
                            <option value="">-- Select Level --</option>
                            @foreach (var level in _levels)
                            {
                                <option value="@level.Id">@level.Name</option>
                            }
                        </InputSelect>
                        <label for="membershipLevel">Membership Level</label>
                        <ValidationMessage For="() => _model.RequestedMembershipLevelId" />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputNumber id="sponsor1" class="form-control" @bind-Value="_model.Sponsor1MemberId" placeholder="Sponsor 1 Member ID" />
                                <label for="sponsor1">Sponsor 1 Member ID</label>
                                <ValidationMessage For="() => _model.Sponsor1MemberId" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputNumber id="sponsor2" class="form-control" @bind-Value="_model.Sponsor2MemberId" placeholder="Sponsor 2 Member ID" />
                                <label for="sponsor2">Sponsor 2 Member ID</label>
                                <ValidationMessage For="() => _model.Sponsor2MemberId" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <button type="submit" class="btn btn-primary" disabled="@_submitting">
                    @if (_submitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Submit Application
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    private ApplicationFormModel _model = new();
    private List<MembershipLevel> _levels = [];
    private bool _submitting;
    private bool _submitted;
    private string? _successMessage;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        _levels = await DbContext.MembershipLevels.ToListAsync();
    }

    private async Task HandleSubmitAsync()
    {
        _submitting = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            if (_model.Sponsor1MemberId == _model.Sponsor2MemberId)
            {
                _errorMessage = "Sponsor 1 and Sponsor 2 must be different members.";
                _submitting = false;
                return;
            }

            var sponsor1Exists = await DbContext.MemberShips
                .AnyAsync(m => m.Id == _model.Sponsor1MemberId!.Value);

            if (!sponsor1Exists)
            {
                _errorMessage = "Sponsor 1 member ID was not found.";
                _submitting = false;
                return;
            }

            var sponsor2Exists = await DbContext.MemberShips
                .AnyAsync(m => m.Id == _model.Sponsor2MemberId!.Value);

            if (!sponsor2Exists)
            {
                _errorMessage = "Sponsor 2 member ID was not found.";
                _submitting = false;
                return;
            }

            var normalizedPostalCode = NormalizePostalCode(_model.PostalCode!);

            var application = new MembershipApplication
            {
                FirstName = _model.FirstName!,
                LastName = _model.LastName!,
                Email = _model.Email!,
                DateOfBirth = _model.DateOfBirth,
                Phone = _model.Phone!,
                AlternatePhone = _model.AlternatePhone,
                Address = _model.Address!,
                PostalCode = normalizedPostalCode,
                Occupation = _model.Occupation!,
                CompanyName = _model.CompanyName!,
                RequestedMembershipLevelId = _model.RequestedMembershipLevelId!.Value,
                RequestedMembershipLevel = (await DbContext.MembershipLevels.FindAsync(_model.RequestedMembershipLevelId!.Value))!,
                Sponsor1MemberId = _model.Sponsor1MemberId!.Value,
                Sponsor2MemberId = _model.Sponsor2MemberId!.Value
            };

            await ApplicationService.SubmitMembershipApplicationAsync(application);

            _successMessage = "Your membership application has been submitted successfully. You will be notified once your application has been reviewed.";
            _submitted = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to submit membership application");
            _errorMessage = "An unexpected error occurred while submitting your application. Please try again later.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string NormalizePostalCode(string postalCode)
    {
        var cleaned = postalCode.ToUpperInvariant().Replace(" ", "");
        return cleaned.Length == 6 ? $"{cleaned[..3]} {cleaned[3..]}" : postalCode.ToUpperInvariant();
    }

    private sealed class ApplicationFormModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string? Email { get; set; }

        [Required(ErrorMessage = "First name is required.")]
        public string? FirstName { get; set; }

        [Required(ErrorMessage = "Last name is required.")]
        public string? LastName { get; set; }

        [Required(ErrorMessage = "Occupation is required.")]
        public string? Occupation { get; set; }

        [Required(ErrorMessage = "Company name is required.")]
        public string? CompanyName { get; set; }

        [Required(ErrorMessage = "Address is required.")]
        public string? Address { get; set; }

        [Required(ErrorMessage = "Postal code is required.")]
        [RegularExpression(@"^[A-Za-z]\d[A-Za-z]\s?\d[A-Za-z]\d$", ErrorMessage = "Enter a valid Canadian postal code (e.g. T2A 4K3).")]
        public string? PostalCode { get; set; }

        [Required(ErrorMessage = "Phone number is required.")]
        [RegularExpression(@"^\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$", ErrorMessage = "Enter a valid 10-digit Canadian phone number (e.g. (403) 555-1234).")]
        public string? Phone { get; set; }

        [Required(ErrorMessage = "Date of birth is required.")]
        public DateTime DateOfBirth { get; set; } = DateTime.Today.AddYears(-30);

        [RegularExpression(@"^\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$", ErrorMessage = "Enter a valid 10-digit Canadian phone number (e.g. (403) 555-1234).")]
        public string? AlternatePhone { get; set; }

        [Required(ErrorMessage = "Membership level is required.")]
        public int? RequestedMembershipLevelId { get; set; }

        [Required(ErrorMessage = "Sponsor 1 member ID is required.")]
        public int? Sponsor1MemberId { get; set; }

        [Required(ErrorMessage = "Sponsor 2 member ID is required.")]
        public int? Sponsor2MemberId { get; set; }
    }
}
