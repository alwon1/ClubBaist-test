@page "/membership/applications/{ApplicationId:int}"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.AdminOrCommittee)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Domain2.Entities.Membership
@using ClubBaist.Services2
@using ClubBaist.Services2.Membership.Applications

@inject IAppDbContext2 DbContext
@inject MembershipApplicationService ApplicationService
@inject ILogger<ReviewApplication> Logger

<PageTitle>Review Application</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Review Application</h2>
        <a href="/membership/applications" class="btn btn-outline-secondary">Back to Inbox</a>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (_application is null)
    {
        <div class="alert alert-warning" role="alert">
            Application not found.
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_resultMessage))
        {
            <div class="alert @(_isError ? "alert-danger" : "alert-success")" role="alert">
                @_resultMessage
            </div>
        }

        <div class="row">
            <div class="col-lg-8">
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Applicant Details</h5>
                        <span class="badge @GetStatusBadgeClass(_application.Status) fs-6">
                            @_application.Status
                        </span>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>First Name:</strong>
                                <p>@_application.FirstName</p>
                            </div>
                            <div class="col-md-6">
                                <strong>Last Name:</strong>
                                <p>@_application.LastName</p>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Date of Birth:</strong>
                                <p>@_application.DateOfBirth.ToString("yyyy-MM-dd")</p>
                            </div>
                            <div class="col-md-6">
                                <strong>Email:</strong>
                                <p>@_application.Email</p>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Phone:</strong>
                                <p>@_application.Phone</p>
                            </div>
                            <div class="col-md-6">
                                <strong>Alternate Phone:</strong>
                                <p>@(_application.AlternatePhone ?? "N/A")</p>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Address:</strong>
                                <p>@_application.Address</p>
                            </div>
                            <div class="col-md-6">
                                <strong>Postal Code:</strong>
                                <p>@_application.PostalCode</p>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Occupation:</strong>
                                <p>@_application.Occupation</p>
                            </div>
                            <div class="col-md-6">
                                <strong>Company:</strong>
                                <p>@_application.CompanyName</p>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Requested Level:</strong>
                                <p>@_application.RequestedMembershipLevel?.Name</p>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Sponsor 1:</strong>
                                <p>@GetSponsorName(_application.Sponsor1MemberId)</p>
                            </div>
                            <div class="col-md-6">
                                <strong>Sponsor 2:</strong>
                                <p>@GetSponsorName(_application.Sponsor2MemberId)</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                @if (_validTransitions.Count > 0)
                {
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Make Decision</h5>
                        </div>
                        <div class="card-body">
                            <div class="form-floating mb-3">
                                <select id="newStatus" class="form-select" @bind="_selectedStatus">
                                    <option value="">-- Select Status --</option>
                                    @foreach (var status in _validTransitions)
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </select>
                                <label for="newStatus">New Status</label>
                            </div>
                            @if (_selectedStatus == ApplicationStatus.Accepted)
                            {
                                <div class="form-floating mb-3">
                                    <select id="membershipLevel" class="form-select" @bind="_selectedLevelId">
                                        <option value="">-- Select Level --</option>
                                        @foreach (var level in _levels)
                                        {
                                            <option value="@level.Id">@level.Name</option>
                                        }
                                    </select>
                                    <label for="membershipLevel">Membership Level</label>
                                </div>
                            }
                            <button class="btn btn-primary w-100" @onclick="HandleDecisionAsync"
                                    disabled="@(_processing || _selectedStatus is null)">
                                @if (_processing)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                }
                                Submit Decision
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-body text-center text-muted">
                            <p class="mb-0">No further status transitions are available for this application.</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int ApplicationId { get; set; }

    private MembershipApplication? _application;
    private Dictionary<int, string> _sponsorNames = new();
    private List<ApplicationStatus> _validTransitions = [];
    private ApplicationStatus? _selectedStatus;
    private List<MembershipLevel> _levels = [];
    private int? _selectedLevelId;
    private bool _loading = true;
    private bool _processing;
    private string? _resultMessage;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadApplicationAsync();
    }

    private async Task LoadApplicationAsync()
    {
        _loading = true;

        try
        {
            _application = await DbContext.MembershipApplications
                .Include(a => a.RequestedMembershipLevel)
                .FirstOrDefaultAsync(a => a.Id == ApplicationId);

            if (_application is not null)
            {
                _validTransitions = _application.Status switch
                {
                    ApplicationStatus.Submitted => [ApplicationStatus.OnHold, ApplicationStatus.Waitlisted, ApplicationStatus.Accepted, ApplicationStatus.Denied],
                    ApplicationStatus.OnHold => [ApplicationStatus.Submitted, ApplicationStatus.Waitlisted, ApplicationStatus.Accepted, ApplicationStatus.Denied],
                    ApplicationStatus.Waitlisted => [ApplicationStatus.OnHold, ApplicationStatus.Accepted, ApplicationStatus.Denied],
                    _ => [] // Accepted and Denied are terminal states
                };

                var sponsorIds = new[] { _application.Sponsor1MemberId, _application.Sponsor2MemberId };
                _sponsorNames = (await DbContext.MemberShips
                        .Include(m => m.User)
                        .Include(m => m.MembershipLevel)
                        .Where(m => sponsorIds.Contains(m.Id))
                        .ToListAsync())
                    .ToDictionary(m => m.Id, m => $"{m.User.FirstName} {m.User.LastName} ({m.MembershipNumber})");

                _levels = await DbContext.MembershipLevels.ToListAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load application {ApplicationId}", ApplicationId);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleDecisionAsync()
    {
        if (_selectedStatus is null || _application is null)
            return;

        _processing = true;
        _resultMessage = null;
        _isError = false;

        try
        {
            bool result;
            if (_selectedStatus == ApplicationStatus.Accepted)
            {
                if (_selectedLevelId is null)
                {
                    _resultMessage = "Please select a membership level before approving.";
                    _isError = true;
                    return;
                }
                result = await ApplicationService.ApproveMembershipApplicationAsync(ApplicationId, _selectedLevelId.Value);
                if (result) _resultMessage = "Application approved. Member account created successfully.";
            }
            else if (_selectedStatus == ApplicationStatus.Denied)
            {
                result = await ApplicationService.DenyApplicationAsync(ApplicationId);
                if (result) _resultMessage = "Application denied.";
            }
            else
            {
                result = await ApplicationService.SetApplicationStatusAsync(ApplicationId, _selectedStatus.Value);
                if (result) _resultMessage = $"Application status changed to {_selectedStatus.Value}.";
            }

            if (!result)
            {
                _isError = true;
                _resultMessage = "Failed to update application status. Please try again.";
            }
            else
            {
                _selectedStatus = null;
                _selectedLevelId = null;
                await LoadApplicationAsync();
            }
        }
        catch (Exception ex)
        {
            _isError = true;
            Logger.LogError(ex, "Error updating application {ApplicationId} status", ApplicationId);
            _resultMessage = "An unexpected error occurred while updating the application status. Please try again later.";
        }
        finally
        {
            _processing = false;
        }
    }

    private string GetSponsorName(int sponsorId) =>
        _sponsorNames.TryGetValue(sponsorId, out var name) ? name : $"Member #{sponsorId}";

    private static string GetStatusBadgeClass(ApplicationStatus status) =>
        UiHelpers.GetStatusBadgeClass(status);
}
