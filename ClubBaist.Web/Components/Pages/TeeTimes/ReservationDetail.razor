@page "/teetimes/reservation/{BookingId:int}"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.AdminOrMember)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Domain2.Entities
@using ClubBaist.Services2

@inject BookingService BookingService
@inject IAppDbContext2 DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<ReservationDetail> Logger

<PageTitle>Reservation Details - Club Baist</PageTitle>

<h3 class="mb-4">Reservation Details</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (booking is null)
{
    <div class="alert alert-warning">Reservation not found.</div>
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Reservation Information</strong>
            @if (booking.TeeTimeSlotStart >= DateTime.Now)
            {
                <span class="badge bg-success">Upcoming</span>
            }
            else
            {
                <span class="badge bg-secondary">Past</span>
            }
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Date:</strong> @booking.TeeTimeSlotStart.ToString("dddd, MMMM d, yyyy")</p>
                    <p><strong>Time:</strong> @booking.TeeTimeSlotStart.ToString("h:mm tt")</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Booking Member:</strong> @MemberName(booking.BookingMember)</p>
                    <p><strong>Total Players:</strong> @(booking.AdditionalParticipants.Count + 1)</p>
                </div>
            </div>
        </div>
    </div>

    @if (booking.TeeTimeSlotStart >= DateTime.Now && isEditMode)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Edit Players</strong>
                @if (editPlayerIds.Count < 3)
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="AddEditPlayerSlot">
                        + Add Player
                    </button>
                }
            </div>
            <div class="card-body">
                @if (editPlayerIds.Count == 0)
                {
                    <p class="text-muted">No additional players.</p>
                }
                else
                {
                    @for (var i = 0; i < editPlayerIds.Count; i++)
                    {
                        var index = i;
                        <div class="row mb-3 align-items-center">
                            <div class="col">
                                <div class="form-floating">
                                    <select class="form-select" id="@($"edit-player-{index}")"
                                            value="@editPlayerIds[index]"
                                            @onchange="(e) => OnEditPlayerChanged(index, e)">
                                        <option value="0">-- Select Player --</option>
                                        @foreach (var member in allMembers.Where(m => m.Id != booking.BookingMemberId))
                                        {
                                            <option value="@member.Id">
                                                @member.MembershipNumber - @member.User.FirstName @member.User.LastName
                                            </option>
                                        }
                                    </select>
                                    <label for="@($"edit-player-{index}")">Player @(index + 2)</label>
                                </div>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveEditPlayerSlot(index)">
                                    Remove
                                </button>
                            </div>
                        </div>
                    }
                }

                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="SaveChanges" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Save Changes
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel Edit</button>
                </div>
            </div>
        </div>
    }
    else if (booking.TeeTimeSlotStart >= DateTime.Now)
    {
        <div class="card mb-4">
            <div class="card-header">
                <strong>Players</strong>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <strong>1.</strong> @MemberName(booking.BookingMember)
                        <span class="badge bg-primary ms-2">Booking Member</span>
                    </li>
                    @for (var i = 0; i < booking.AdditionalParticipants.Count; i++)
                    {
                        <li class="list-group-item">
                            <strong>@(i + 2).</strong> @MemberName(booking.AdditionalParticipants[i])
                        </li>
                    }
                </ul>
            </div>
        </div>
    }

    @if (booking.TeeTimeSlotStart >= DateTime.Now)
    {
        <div class="d-flex gap-2">
            @if (!isEditMode)
            {
                <button class="btn btn-outline-primary" @onclick="EnterEditMode">Edit Players</button>
            }

            @if (showCancelConfirm)
            {
                <button class="btn btn-danger" @onclick="ConfirmCancel">Confirm Cancellation</button>
                <button class="btn btn-outline-secondary" @onclick="() => showCancelConfirm = false">Keep Reservation</button>
            }
            else
            {
                <button class="btn btn-outline-danger" @onclick="() => showCancelConfirm = true">Cancel Reservation</button>
            }
        </div>
    }

    <div class="mt-3">
        <a href="/teetimes/my" class="btn btn-outline-secondary">Back to My Reservations</a>
    </div>
}

@code {
    [Parameter]
    public int BookingId { get; set; }

    private bool isLoading = true;
    private bool isEditMode;
    private bool isSaving;
    private bool showCancelConfirm;
    private string? errorMessage;
    private string? successMessage;

    private TeeTimeBooking? booking;
    private List<MemberShipInfo> allMembers = [];
    private List<int> editPlayerIds = [];
    private int currentMemberId;
    private bool isAdmin;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);
            isAdmin = user.IsInRole(AppRoles.Admin);

            if (!isAdmin)
            {
                var currentMember = await DbContext.MemberShips
                    .FirstOrDefaultAsync(m => m.User.Id == userId);
                currentMemberId = currentMember?.Id ?? 0;
            }

            booking = await DbContext.TeeTimeBookings
                .Include(b => b.BookingMember).ThenInclude(m => m.User)
                .Include(b => b.BookingMember).ThenInclude(m => m.MembershipLevel)
                .Include(b => b.AdditionalParticipants).ThenInclude(m => m.User)
                .Include(b => b.AdditionalParticipants).ThenInclude(m => m.MembershipLevel)
                .FirstOrDefaultAsync(b => b.Id == BookingId);

            if (booking is null) { isLoading = false; return; }

            if (!isAdmin && booking.BookingMemberId != currentMemberId)
            {
                booking = null;
                isLoading = false;
                return;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load booking {BookingId}", BookingId);
            errorMessage = "An unexpected error occurred while loading the reservation. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string MemberName(MemberShipInfo m) =>
        $"{m.User.FirstName} {m.User.LastName} ({m.MembershipNumber})";

    private async Task EnterEditMode()
    {
        if (allMembers.Count == 0)
        {
            allMembers = await DbContext.MemberShips
                .Include(m => m.User)
                .Include(m => m.MembershipLevel)
                .OrderBy(m => m.User.LastName)
                .ThenBy(m => m.User.FirstName)
                .ToListAsync();
        }

        editPlayerIds = booking!.AdditionalParticipants.Select(p => p.Id).ToList();
        isEditMode = true;
        successMessage = null;
    }

    private void CancelEdit()
    {
        isEditMode = false;
        editPlayerIds.Clear();
    }

    private void OnEditPlayerChanged(int index, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
            editPlayerIds[index] = id;
    }

    private void AddEditPlayerSlot()
    {
        if (editPlayerIds.Count < 3)
            editPlayerIds.Add(0);
    }

    private void RemoveEditPlayerSlot(int index)
    {
        editPlayerIds.RemoveAt(index);
    }

    private async Task SaveChanges()
    {
        errorMessage = null;
        successMessage = null;
        isSaving = true;

        try
        {
            var playerIds = editPlayerIds.Where(id => id != 0).Distinct().ToList();
            var participants = await DbContext.MemberShips
                .Where(m => playerIds.Contains(m.Id))
                .ToListAsync();

            var result = await BookingService.UpdateBookingAsync(BookingId, participants);

            if (!result)
            {
                errorMessage = "Unable to update reservation. The slot may be full or booking rules prevent this change.";
            }
            else
            {
                successMessage = "Reservation updated successfully.";
                isEditMode = false;
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update booking {BookingId}", BookingId);
            errorMessage = "An unexpected error occurred while updating the reservation. Please try again later.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ConfirmCancel()
    {
        errorMessage = null;
        successMessage = null;
        showCancelConfirm = false;

        try
        {
            var result = await BookingService.CancelBookingAsync(BookingId);

            if (result)
            {
                successMessage = "Reservation cancelled successfully.";
                await LoadData();
            }
            else
            {
                errorMessage = "Unable to cancel reservation.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to cancel booking {BookingId}", BookingId);
            errorMessage = "An unexpected error occurred while cancelling the reservation. Please try again later.";
        }
    }
}
