@page "/teetimes/staff"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.AdminOrProShopStaff)]
@implements IDisposable

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain
@using ClubBaist.Domain.Entities
@using ClubBaist.Services

@inject BookingService BookingService
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<StaffConsole> Logger

<PageTitle>Staff Console - Club Baist</PageTitle>

<h3 class="mb-4">Staff Console</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(activeView == ConsoleView.Members ? "active" : "")"
                @onclick='() => SetView(ConsoleView.Members)'>
            Members
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(activeView == ConsoleView.Reservations ? "active" : "")"
                @onclick='() => SetView(ConsoleView.Reservations)'>
            Reservations
        </button>
    </li>
</ul>

@if (activeView == ConsoleView.Members)
{
    <div class="card mb-4">
        <div class="card-header d-flex align-items-center gap-2">
            <strong>Members</strong>
            @if (isMemberSearching)
            {
                <span class="spinner-border spinner-border-sm" role="status">
                    <span class="visually-hidden">Loading...</span>
                </span>
            }
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="memberSearchInput"
                               value="@memberSearchTerm"
                               @oninput="OnMemberSearchInput"
                               placeholder=" " />
                        <label for="memberSearchInput">Filter by name or member number</label>
                    </div>
                </div>
            </div>

            @if (memberSearchResults is { Count: > 0 })
            {
                <QuickGrid Items="@memberSearchResults.AsQueryable()" Class="table table-striped table-hover"
                           RowClass="@(m => selectedMember?.Id == m.Id ? "table-active" : "")">
                    <TemplateColumn Title="Member #" SortBy="@(GridSort<MemberShipInfo>.ByAscending(m => m.MembershipNumber))">
                        @context.MembershipNumber
                    </TemplateColumn>
                    <TemplateColumn Title="Name" SortBy="@(GridSort<MemberShipInfo>.ByAscending(m => m.User.LastName).ThenAscending(m => m.User.FirstName))">
                        @context.User.FirstName @context.User.LastName
                    </TemplateColumn>
                    <TemplateColumn Title="Email">
                        @context.User.Email
                    </TemplateColumn>
                    <TemplateColumn Title="Level">
                        @context.MembershipLevel.Name
                    </TemplateColumn>
                    <TemplateColumn Title="Action">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => SelectMember(context)">
                            Select
                        </button>
                    </TemplateColumn>
                </QuickGrid>
            }
            else if (!isMemberSearching)
            {
                <p class="text-muted">No members found.</p>
            }
        </div>
    </div>

    @if (selectedMember is not null)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Reservations for @selectedMember.User.FirstName @selectedMember.User.LastName (@selectedMember.MembershipNumber)</strong>
                @if (true)
                {
                    <button class="btn btn-sm @(showBookingPanel ? "btn-secondary" : "btn-primary")"
                            @onclick="ToggleBookingPanel">
                        @(showBookingPanel ? "Hide Availability" : "Book on Behalf")
                    </button>
                }
                @* Active check removed: all members in Domain are managed by membership level *@
            </div>
            <div class="card-body">
                @if (isLoadingReservations)
                {
                    <div class="text-center my-3">
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (memberReservations is { Count: > 0 })
                {
                    <QuickGrid Items="@memberReservations.AsQueryable()" Class="table table-striped">
                        <TemplateColumn Title="Date" SortBy="@(GridSort<TeeTimeBooking>.ByAscending(b => b.TeeTimeSlotStart))">
                            @context.TeeTimeSlotStart.ToString("MMM d, yyyy")
                        </TemplateColumn>
                        <TemplateColumn Title="Time">
                            @context.TeeTimeSlotStart.ToString("h:mm tt")
                        </TemplateColumn>
                        <TemplateColumn Title="Players">
                            @(context.AdditionalParticipants.Count + 1)
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            @if (context.TeeTimeSlotStart >= DateTime.Now)
                            {
                                <span class="badge bg-success">Upcoming</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Past</span>
                            }
                        </TemplateColumn>
                        <TemplateColumn Title="Actions">
                            <a href="@($"/teetimes/reservation/{context.Id}")"
                               class="btn btn-sm btn-outline-primary me-1">
                                View/Edit
                            </a>
                            @if (context.TeeTimeSlotStart >= DateTime.Now)
                            {
                                @if (cancelConfirmId == context.Id)
                                {
                                    <button class="btn btn-sm btn-danger me-1"
                                            @onclick="() => ConfirmCancel(context.Id)">
                                        Confirm
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary"
                                            @onclick="() => cancelConfirmId = null">
                                        No
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => cancelConfirmId = context.Id">
                                        Cancel
                                    </button>
                                }
                            }
                        </TemplateColumn>
                    </QuickGrid>
                }
                else
                {
                    <p class="text-muted">No reservations found for this member.</p>
                }
            </div>
        </div>

        @if (showBookingPanel)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <strong>Availability — booking for @selectedMember.User.FirstName @selectedMember.User.LastName (@selectedMember.MembershipLevel.Name)</strong>
                </div>
                <div class="card-body">
                    <TeeTimeAvailabilityPanel @key="selectedMember.Id"
                        IsAdmin="true"
                        CurrentMemberId="0"
                        BookForMemberId="selectedMember.Id" />
                </div>
            </div>
        }
    }
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex align-items-center gap-2">
            <strong>Reservations</strong>
            @if (isReservationSearching)
            {
                <span class="spinner-border spinner-border-sm" role="status">
                    <span class="visually-hidden">Loading...</span>
                </span>
            }
        </div>
        <div class="card-body">
            <div class="row align-items-end g-3 mb-3">
                <div class="col-md-4">
                    <div class="form-floating">
                        <input type="text" class="form-control" id="reservationSearchInput"
                               value="@reservationSearchTerm"
                               @oninput="OnReservationSearchInput"
                               placeholder=" " />
                        <label for="reservationSearchInput">Filter by member name or number</label>
                    </div>
                </div>
                <div class="col-auto d-flex align-items-center">
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="dateRangeToggle"
                               @bind="dateRangeEnabled" @bind:after="OnDateRangeToggled" />
                        <label class="form-check-label" for="dateRangeToggle">Custom date range</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="input-group">
                        <span class="input-group-text">From</span>
                        <input type="date" class="form-control" style="min-width:150px"
                               disabled="@(!dateRangeEnabled)"
                               value="@dateFrom.ToString("yyyy-MM-dd")"
                               @onchange="OnDateFromChanged" />
                    </div>
                </div>
                <div class="col-auto">
                    <div class="input-group">
                        <span class="input-group-text">To</span>
                        <input type="date" class="form-control" style="min-width:150px"
                               disabled="@(!dateRangeEnabled)"
                               value="@(dateTo?.ToString("yyyy-MM-dd") ?? "")"
                               @onchange="OnDateToChanged" />
                    </div>
                </div>
            </div>

            @if (reservationRows is { Count: > 0 })
            {
                <QuickGrid Items="@reservationRows.AsQueryable()" Class="table table-striped table-hover">
                    <TemplateColumn Title="Date" SortBy="@(GridSort<BookingRow>.ByAscending(r => r.SlotStart))">
                        @context.SlotStart.ToString("MMM d, yyyy")
                    </TemplateColumn>
                    <TemplateColumn Title="Time" SortBy="@(GridSort<BookingRow>.ByAscending(r => r.SlotStart))">
                        @context.SlotStart.ToString("h:mm tt")
                    </TemplateColumn>
                    <TemplateColumn Title="Booked By" SortBy="@(GridSort<BookingRow>.ByAscending(r => r.BookingMemberName))">
                        @context.BookingMemberName
                    </TemplateColumn>
                    <TemplateColumn Title="Member #">
                        @context.MemberNumber
                    </TemplateColumn>
                    <TemplateColumn Title="Players">
                        @context.PlayerCount
                    </TemplateColumn>
                    <TemplateColumn Title="Status">
                        @if (context.SlotStart >= DateTime.Now)
                        {
                            <span class="badge bg-success">Upcoming</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Past</span>
                        }
                    </TemplateColumn>
                    <TemplateColumn Title="Actions">
                        <a href="@($"/teetimes/reservation/{context.BookingId}")"
                           class="btn btn-sm btn-outline-primary me-1">
                            View/Edit
                        </a>
                        @if (context.SlotStart >= DateTime.Now)
                        {
                            @if (cancelConfirmId == context.BookingId)
                            {
                                <button class="btn btn-sm btn-danger me-1"
                                        @onclick="() => ConfirmCancel(context.BookingId)">
                                    Confirm
                                </button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => cancelConfirmId = null">
                                    No
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => cancelConfirmId = context.BookingId">
                                    Cancel
                                </button>
                            }
                        }
                    </TemplateColumn>
                </QuickGrid>
            }
            else if (!isReservationSearching)
            {
                <p class="text-muted">No reservations found.</p>
            }
        </div>
    </div>
}

@code {
    private enum ConsoleView { Members, Reservations }

    private record BookingRow(
        int BookingId,
        DateTime SlotStart,
        string BookingMemberName,
        string MemberNumber,
        int PlayerCount);

    // Shared state
    private ConsoleView activeView = ConsoleView.Members;
    private string? errorMessage;
    private string? successMessage;
    private int? cancelConfirmId;

    // Members view state
    private string memberSearchTerm = string.Empty;
    private bool isMemberSearching;
    private List<MemberShipInfo>? memberSearchResults;
    private MemberShipInfo? selectedMember;
    private List<TeeTimeBooking>? memberReservations;
    private bool isLoadingReservations;
    private bool showBookingPanel;

    // Reservations view state
    private string reservationSearchTerm = string.Empty;
    private bool isReservationSearching;
    private List<BookingRow>? reservationRows;
    // dateFrom defaults to today; always applied as a floor.
    // When dateRangeEnabled is false the date inputs are disabled but the
    // today-or-later default is still enforced.  Enabling the toggle lets
    // staff choose a custom window.
    private bool dateRangeEnabled;
    private DateOnly dateFrom = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? dateTo;

    // Debounce tokens
    private CancellationTokenSource? _memberDebounce;
    private CancellationTokenSource? _reservationDebounce;

    protected override async Task OnInitializedAsync()
    {
        await SearchMembers();
    }

    private async Task SetView(ConsoleView view)
    {
        activeView = view;
        errorMessage = null;
        successMessage = null;
        cancelConfirmId = null;

        if (view == ConsoleView.Reservations && reservationRows is null)
        {
            await LoadReservations();
        }
    }

    // --- Members View ---

    private async Task OnMemberSearchInput(ChangeEventArgs e)
    {
        memberSearchTerm = e.Value?.ToString() ?? string.Empty;

        var old = _memberDebounce;
        old?.Cancel();
        _memberDebounce = new CancellationTokenSource();
        var token = _memberDebounce.Token;
        old?.Dispose();

        try
        {
            await Task.Delay(300, token);
            await SearchMembers(token);
        }
        catch (OperationCanceledException) { }
    }

    private async Task SearchMembers(CancellationToken cancellationToken = default)
    {
        isMemberSearching = true;
        StateHasChanged();

        try
        {
            if (string.IsNullOrWhiteSpace(memberSearchTerm))
            {
                memberSearchResults = await DbContext.MemberShips
                    .Include(m => m.User)
                    .Include(m => m.MembershipLevel)
                    .OrderBy(m => m.User.LastName)
                    .ThenBy(m => m.User.FirstName)
                    .ToListAsync(cancellationToken);
            }
            else
            {
                var pattern = $"%{memberSearchTerm.Trim()}%";
                memberSearchResults = await DbContext.MemberShips
                    .Include(m => m.User)
                    .Include(m => m.MembershipLevel)
                    .Where(m => EF.Functions.Like(m.User.FirstName, pattern)
                             || EF.Functions.Like(m.User.LastName, pattern))
                    .OrderBy(m => m.User.LastName)
                    .ThenBy(m => m.User.FirstName)
                    .Take(50)
                    .ToListAsync(cancellationToken);
            }
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Member search failed for term '{SearchTerm}'", memberSearchTerm);
            errorMessage = "Search failed. Please try again.";
        }
        finally
        {
            isMemberSearching = false;
            StateHasChanged();
        }
    }

    private void ToggleBookingPanel()
    {
        showBookingPanel = !showBookingPanel;
    }

    private async Task SelectMember(MemberShipInfo member)
    {
        selectedMember = member;
        showBookingPanel = false;
        cancelConfirmId = null;
        isLoadingReservations = true;
        errorMessage = null;

        try
        {
            memberReservations = await DbContext.TeeTimeBookings
                .Include(b => b.AdditionalParticipants)
                .Where(b => b.BookingMemberId == member.Id
                         || b.AdditionalParticipants.Any(p => p.Id == member.Id))
                .OrderBy(b => b.TeeTimeSlotStart)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load bookings for member {MemberId}", member.Id);
            errorMessage = "Failed to load reservations. Please try again.";
        }
        finally
        {
            isLoadingReservations = false;
        }
    }

    // --- Reservations View ---

    private async Task OnReservationSearchInput(ChangeEventArgs e)
    {
        reservationSearchTerm = e.Value?.ToString() ?? string.Empty;

        var old = _reservationDebounce;
        old?.Cancel();
        _reservationDebounce = new CancellationTokenSource();
        var token = _reservationDebounce.Token;
        old?.Dispose();

        try
        {
            await Task.Delay(300, token);
            await LoadReservations(token);
        }
        catch (OperationCanceledException) { }
    }

    private async Task OnDateRangeToggled()
    {
        if (!dateRangeEnabled)
        {
            dateFrom = DateOnly.FromDateTime(DateTime.Today);
            dateTo = null;
        }
        await LoadReservations();
    }

    private async Task OnDateFromChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
        {
            dateFrom = date;
            await LoadReservations();
        }
    }

    private async Task OnDateToChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        dateTo = string.IsNullOrEmpty(val) ? null
            : DateOnly.TryParse(val, out var date) ? date
            : dateTo;
        await LoadReservations();
    }

    private async Task LoadReservations(CancellationToken cancellationToken = default)
    {
        isReservationSearching = true;
        StateHasChanged();

        try
        {
            // Date range filter: dateFrom is always applied (defaults to today when the
            // custom-range toggle is off), so the view never shows past reservations by default.
            var fromDateTime = dateFrom.ToDateTime(TimeOnly.MinValue);
            var bookingQuery = DbContext.TeeTimeBookings
                .Include(b => b.BookingMember).ThenInclude(m => m.User)
                .Include(b => b.BookingMember).ThenInclude(m => m.MembershipLevel)
                .Include(b => b.AdditionalParticipants)
                .Where(b => b.TeeTimeSlotStart >= fromDateTime);

            if (dateTo.HasValue)
            {
                var toDateTime = dateTo.Value.ToDateTime(TimeOnly.MaxValue);
                bookingQuery = bookingQuery.Where(b => b.TeeTimeSlotStart <= toDateTime);
            }

            if (!string.IsNullOrWhiteSpace(reservationSearchTerm))
            {
                var pattern = $"%{reservationSearchTerm.Trim()}%";
                var matchingMemberIds = DbContext.MemberShips
                    .Where(m => EF.Functions.Like(m.User.FirstName, pattern)
                             || EF.Functions.Like(m.User.LastName, pattern))
                    .Select(m => m.Id);
                bookingQuery = bookingQuery.Where(b => matchingMemberIds.Contains(b.BookingMemberId));
            }

            var bookings = await bookingQuery
                .OrderBy(b => b.TeeTimeSlotStart)
                .ToListAsync(cancellationToken);

            reservationRows = bookings.Select(b => new BookingRow(
                b.Id,
                b.TeeTimeSlotStart,
                $"{b.BookingMember.User.FirstName} {b.BookingMember.User.LastName}",
                b.BookingMember.MembershipNumber,
                b.AdditionalParticipants.Count + 1)).ToList();
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load reservations");
            errorMessage = "Failed to load reservations. Please try again.";
        }
        finally
        {
            isReservationSearching = false;
            StateHasChanged();
        }
    }

    // --- Shared Cancel ---

    private async Task ConfirmCancel(int bookingId)
    {
        errorMessage = null;
        successMessage = null;
        cancelConfirmId = null;

        try
        {
            var result = await BookingService.CancelBookingAsync(bookingId);

            if (result)
            {
                successMessage = "Reservation cancelled successfully.";
                if (activeView == ConsoleView.Members && selectedMember is not null)
                    await SelectMember(selectedMember);
                else if (activeView == ConsoleView.Reservations)
                    await LoadReservations();
            }
            else
            {
                errorMessage = "Unable to cancel booking.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to cancel booking {BookingId}", bookingId);
            errorMessage = "Failed to cancel booking. Please try again.";
        }
    }

    public void Dispose()
    {
        _memberDebounce?.Cancel();
        _memberDebounce?.Dispose();
        _reservationDebounce?.Cancel();
        _reservationDebounce?.Dispose();
    }
}
