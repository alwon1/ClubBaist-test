@page "/teetimes/book"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = AppRoles.AdminOrMember)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Domain2.Entities
@using ClubBaist.Services2

@inject BookingService BookingService
@inject IAppDbContext2 DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ILogger<CreateReservation> Logger

<PageTitle>Book Tee Time - Club Baist</PageTitle>

<h3 class="mb-4">Book a Tee Time</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (successMessage is not null)
{
    <div class="alert alert-success">
        <p>@successMessage</p>
        <a href="@(isAdmin ? "/teetimes/staff" : "/teetimes/my")" class="btn btn-outline-success mt-2">
            @(isAdmin ? "Back to Staff Console" : "View Reservations")
        </a>
    </div>
}
else if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-header">
            <strong>Selected Slot</strong>
        </div>
        <div class="card-body">
            <p><strong>Date:</strong> @slotDate.ToString("dddd, MMMM d, yyyy")</p>
            <p><strong>Time:</strong> @slotTime.ToString("h:mm tt")</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <strong>Booking Member</strong>
        </div>
        <div class="card-body">
            @if (isAdmin)
            {
                <div class="form-floating mb-3">
                    <select class="form-select" id="bookingMember" @bind="BookingMemberId">
                        <option value="">-- Select Member --</option>
                        @foreach (var member in allMembers)
                        {
                            <option value="@member.Id">
                                @member.MembershipNumber - @member.User.FirstName @member.User.LastName
                            </option>
                        }
                    </select>
                    <label for="bookingMember">Booking Member (Admin Override)</label>
                </div>
            }
            else if (currentMember is not null)
            {
                <p>@currentMember.MembershipNumber - @currentMember.User.FirstName @currentMember.User.LastName</p>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Additional Players</strong>
            @if (additionalPlayerIds.Count < 3)
            {
                <button class="btn btn-sm btn-outline-primary" @onclick="AddPlayerSlot">
                    + Add Player
                </button>
            }
        </div>
        <div class="card-body">
            @if (additionalPlayerIds.Count == 0)
            {
                <p class="text-muted">No additional players added.</p>
            }
            else
            {
                @for (var i = 0; i < additionalPlayerIds.Count; i++)
                {
                    var index = i;
                    <div class="row mb-3 align-items-center">
                        <div class="col">
                            <div class="form-floating">
                                <select class="form-select" id="@($"player-{index}")"
                                        value="@additionalPlayerIds[index]"
                                        @onchange="(e) => OnPlayerChanged(index, e)">
                                    <option value="0">-- Select Player --</option>
                                    @foreach (var member in allMembers.Where(m => m.Id != _bookingMemberId))
                                    {
                                        <option value="@member.Id">
                                            @member.MembershipNumber - @member.User.FirstName @member.User.LastName
                                        </option>
                                    }
                                </select>
                                <label for="@($"player-{index}")">Player @(index + 2)</label>
                            </div>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemovePlayerSlot(index)">
                                Remove
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <button class="btn btn-primary" @onclick="SubmitReservation" disabled="@isSubmitting">
        @if (isSubmitting)
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
        }
        Book Tee Time
    </button>
    <a href="@(isAdmin ? "/teetimes/staff" : "/teetimes")"
       class="btn btn-outline-secondary ms-2">Cancel</a>
}

@code {
    [SupplyParameterFromQuery]
    public string? Date { get; set; }

    [SupplyParameterFromQuery]
    public string? Time { get; set; }

    [SupplyParameterFromQuery]
    public int? BookFor { get; set; }

    private DateOnly slotDate;
    private TimeOnly slotTime;
    private bool isLoading = true;
    private bool isSubmitting;
    private bool isAdmin;
    private string? errorMessage;
    private string? successMessage;

    private MemberShipInfo? currentMember;
    private int _bookingMemberId;
    private string BookingMemberId
    {
        get => _bookingMemberId == 0 ? "" : _bookingMemberId.ToString();
        set
        {
            _bookingMemberId = int.TryParse(value, out var id) ? id : 0;
            additionalPlayerIds.RemoveAll(p => p == _bookingMemberId);
        }
    }
    private List<MemberShipInfo> allMembers = [];
    private List<int> additionalPlayerIds = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!DateOnly.TryParse(Date, out slotDate) || !TimeOnly.TryParse(Time, out slotTime))
            {
                errorMessage = "Invalid date or time parameters.";
                isLoading = false;
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);
            isAdmin = user.IsInRole(AppRoles.Admin);

            currentMember = await DbContext.MemberShips
                .Include(m => m.User)
                .Include(m => m.MembershipLevel)
                .FirstOrDefaultAsync(m => m.UserId == userId);

            if (currentMember is null && !isAdmin)
            {
                errorMessage = "Member account not found. Please contact an administrator.";
                isLoading = false;
                return;
            }

            _bookingMemberId = currentMember?.Id ?? 0;

            allMembers = await DbContext.MemberShips
                .Include(m => m.User)
                .Include(m => m.MembershipLevel)
                .OrderBy(m => m.User.LastName)
                .ThenBy(m => m.User.FirstName)
                .ToListAsync();

            if (isAdmin && BookFor.HasValue && allMembers.Any(m => m.Id == BookFor.Value))
                _bookingMemberId = BookFor.Value;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize booking page");
            errorMessage = "An unexpected error occurred. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnPlayerChanged(int index, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
            additionalPlayerIds[index] = id;
    }

    private void AddPlayerSlot()
    {
        if (additionalPlayerIds.Count < 3)
            additionalPlayerIds.Add(0);
    }

    private void RemovePlayerSlot(int index)
    {
        additionalPlayerIds.RemoveAt(index);
    }

    private async Task SubmitReservation()
    {
        errorMessage = null;

        if (_bookingMemberId == 0)
        {
            errorMessage = "Please select a booking member.";
            return;
        }

        var playerIds = additionalPlayerIds.Where(id => id != 0).Distinct().ToList();

        if (playerIds.Contains(_bookingMemberId))
        {
            errorMessage = "The booking member cannot also be listed as an additional player.";
            return;
        }

        isSubmitting = true;

        try
        {
            var slotStart = slotDate.ToDateTime(slotTime);
            var slot = await DbContext.TeeTimeSlots.FirstOrDefaultAsync(s => s.Start == slotStart);
            if (slot is null)
            {
                errorMessage = "The selected time slot does not exist.";
                return;
            }

            var bookingMember = await DbContext.MemberShips
                .Include(m => m.MembershipLevel)
                .FirstOrDefaultAsync(m => m.Id == _bookingMemberId);
            if (bookingMember is null)
            {
                errorMessage = "Booking member not found.";
                return;
            }

            var additionalParticipants = await DbContext.MemberShips
                .Where(m => playerIds.Contains(m.Id))
                .ToListAsync();

            var booking = new TeeTimeBooking
            {
                TeeTimeSlotStart = slotStart,
                TeeTimeSlot = slot,
                BookingMemberId = bookingMember.Id,
                BookingMember = bookingMember,
                AdditionalParticipants = additionalParticipants
            };

            var result = await BookingService.CreateBookingAsync(booking);

            if (!result)
            {
                errorMessage = "Unable to create reservation. The slot may be full or booking rules prevent this reservation.";
            }
            else
            {
                successMessage = $"Tee time booked successfully for {slotDate:dddd, MMMM d, yyyy} at {slotTime:h:mm tt}.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create reservation");
            errorMessage = "An unexpected error occurred while creating the reservation. Please try again later.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
