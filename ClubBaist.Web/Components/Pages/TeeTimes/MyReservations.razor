@page "/teetimes/my"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.Member)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain
@using ClubBaist.Domain.Entities
@using ClubBaist.Services

@inject AppDbContext DbContext
@inject BookingService BookingService
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<MyReservations> Logger

<PageTitle>My Reservations - Club Baist</PageTitle>

<h3 class="mb-4">My Reservations</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="mb-3">
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="showPast" checked="@showPast" @onchange="OnTogglePast" />
        <label class="form-check-label" for="showPast">Show past reservations</label>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (filteredBookings is not null && filteredBookings.Count > 0)
{
    <QuickGrid Items="@filteredBookings.AsQueryable()" Class="table table-striped">
        <TemplateColumn Title="Date" SortBy="@(GridSort<TeeTimeBooking>.ByAscending(b => b.TeeTimeSlotStart))">
            @context.TeeTimeSlotStart.ToString("MMM d, yyyy")
        </TemplateColumn>
        <TemplateColumn Title="Time" SortBy="@(GridSort<TeeTimeBooking>.ByAscending(b => b.TeeTimeSlotStart))">
            @context.TeeTimeSlotStart.ToString("h:mm tt")
        </TemplateColumn>
        <TemplateColumn Title="Players">
            @(context.AdditionalParticipants.Count + 1)
        </TemplateColumn>
        <TemplateColumn Title="Status">
            @if (context.TeeTimeSlotStart >= DateTime.Now)
            {
                <span class="badge bg-success">Upcoming</span>
            }
            else
            {
                <span class="badge bg-secondary">Past</span>
            }
        </TemplateColumn>
        <TemplateColumn Title="Actions">
            <a href="@($"/teetimes/reservation/{context.Id}")" class="btn btn-sm btn-outline-primary me-1">
                View/Edit
            </a>
            @if (context.TeeTimeSlotStart >= DateTime.Now)
            {
                @if (cancelConfirmId == context.Id)
                {
                    <button class="btn btn-sm btn-danger me-1" @onclick="() => ConfirmCancel(context.Id)">
                        Confirm
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => cancelConfirmId = null">
                        No
                    </button>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => cancelConfirmId = context.Id">
                        Cancel
                    </button>
                }
            }
        </TemplateColumn>
    </QuickGrid>
}
else
{
    <div class="alert alert-info">No reservations found.</div>
}

@code {
    private bool isLoading = true;
    private bool showPast;
    private string? errorMessage;
    private string? successMessage;
    private int? cancelConfirmId;

    private int currentMemberId;
    private List<TeeTimeBooking> allBookings = [];
    private List<TeeTimeBooking>? filteredBookings;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);

            var member = await DbContext.MemberShips
                .FirstOrDefaultAsync(m => m.UserId == userId);

            if (member is null)
            {
                errorMessage = "Member account not found.";
                isLoading = false;
                return;
            }

            currentMemberId = member.Id;

            allBookings = await DbContext.TeeTimeBookings
                .Include(b => b.AdditionalParticipants)
                .Where(b => b.BookingMemberId == currentMemberId)
                .ToListAsync();

            ApplyFilter();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load reservations");
            errorMessage = "An unexpected error occurred while loading reservations. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilter()
    {
        filteredBookings = (showPast
            ? allBookings
            : allBookings.Where(b => b.TeeTimeSlotStart >= DateTime.Now))
            .OrderBy(b => b.TeeTimeSlotStart)
            .ToList();
    }

    private void OnTogglePast(ChangeEventArgs e)
    {
        showPast = (bool)(e.Value ?? false);
        ApplyFilter();
    }

    private async Task ConfirmCancel(int bookingId)
    {
        errorMessage = null;
        successMessage = null;
        cancelConfirmId = null;

        try
        {
            var result = await BookingService.CancelBookingAsync(bookingId);

            if (result)
            {
                successMessage = "Booking cancelled successfully.";
                await LoadData();
            }
            else
            {
                errorMessage = "Unable to cancel booking.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to cancel booking {BookingId}", bookingId);
            errorMessage = "An unexpected error occurred while cancelling the booking. Please try again later.";
        }
    }
}
