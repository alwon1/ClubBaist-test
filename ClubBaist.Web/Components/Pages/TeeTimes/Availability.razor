@page "/teetimes"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = AppRoles.AdminOrMember)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain
@using ClubBaist.Services

@inject IApplicationDbContext<Guid> DbContext
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Tee Time Availability - Club Baist</PageTitle>

<h3 class="mb-4">Tee Time Availability</h3>

@if (!isLoading)
{
    <TeeTimeAvailabilityPanel
        MemberCategory="currentMemberCategory"
        IsAdmin="isAdmin"
        CurrentMemberAccountId="currentMemberAccountId"
        BookForMemberId="null" />
}
else
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isAdmin;
    private int currentMemberAccountId;
    private MembershipCategory? currentMemberCategory;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);
        isAdmin = user.IsInRole(AppRoles.Admin);

        if (!isAdmin)
        {
            var member = await DbContext.MemberAccounts
                .FirstOrDefaultAsync(m => m.ApplicationUserId == userId);
            currentMemberAccountId = member?.MemberAccountId ?? 0;
            currentMemberCategory = member?.MembershipCategory;
        }

        isLoading = false;
    }
}
