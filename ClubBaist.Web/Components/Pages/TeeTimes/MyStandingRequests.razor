@page "/teetimes/standing/my"
@rendermode InteractiveServer
@attribute [Authorize(Policy = AppRoles.Permissions.BookStandingTeeTime)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Services2

@inject IAppDbContext2 DbContext
@inject StandingTeeTimeService StandingTeeTimeService
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<MyStandingRequests> Logger

<PageTitle>My Standing Tee Times - Club Baist</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>My Standing Tee Time Requests</h3>
    <a href="/teetimes/standing/request" class="btn btn-primary">New Request</a>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (requests is null || requests.Count == 0)
{
    <div class="alert alert-info">
        You have no standing tee time requests.
        <a href="/teetimes/standing/request" class="alert-link ms-1">Submit a new request.</a>
    </div>
}
else
{
    <QuickGrid Items="@requests.AsQueryable()" Class="table table-striped table-hover">
        <TemplateColumn Title="Day / Time" SortBy="@(GridSort<StandingTeeTime>.ByAscending(r => r.RequestedDayOfWeek).ThenAscending(r => r.RequestedTime))">
            <strong>@context.RequestedDayOfWeek</strong>
            <span class="ms-1">@context.RequestedTime.ToString("h:mm tt")</span>
            <small class="text-muted ms-1">(±@context.ToleranceMinutes min)</small>
        </TemplateColumn>
        <TemplateColumn Title="Season">
            @context.StartDate.ToString("MMM d, yyyy") – @context.EndDate.ToString("MMM d, yyyy")
        </TemplateColumn>
        <TemplateColumn Title="Players">
            <span>@context.BookingMember.User.FirstName @context.BookingMember.User.LastName</span>
            @foreach (var p in context.AdditionalParticipants)
            {
                <text>, @p.User.FirstName @p.User.LastName</text>
            }
        </TemplateColumn>
        <TemplateColumn Title="Status" SortBy="@(GridSort<StandingTeeTime>.ByAscending(r => r.Status))">
            <span class="badge @GetStatusBadgeClass(context.Status)">@context.Status</span>
        </TemplateColumn>
        <TemplateColumn Title="Approved Time / Priority">
            @if (context.ApprovedTime.HasValue)
            {
                <span>@context.ApprovedTime.Value.ToString("h:mm tt")</span>
            }
            @if (context.PriorityNumber.HasValue)
            {
                <span class="badge bg-info ms-1">#@context.PriorityNumber</span>
            }
            @if (!context.ApprovedTime.HasValue && !context.PriorityNumber.HasValue)
            {
                <span class="text-muted">—</span>
            }
        </TemplateColumn>
        <TemplateColumn Title="Actions">
            @if (context.Status is not (StandingTeeTimeStatus.Cancelled or StandingTeeTimeStatus.Denied))
            {
                @if (cancelConfirmId == context.Id)
                {
                    <span class="me-2 small">Are you sure?</span>
                    <button class="btn btn-sm btn-danger me-1" @onclick="() => ConfirmCancelAsync(context.Id)">Yes</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => cancelConfirmId = null">No</button>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => cancelConfirmId = context.Id">Cancel Request</button>
                }
            }
        </TemplateColumn>
    </QuickGrid>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private string? successMessage;
    private int? cancelConfirmId;

    private int currentMemberId;
    private IReadOnlyList<StandingTeeTime>? requests;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);

            var member = await DbContext.MemberShips.FirstOrDefaultAsync(m => m.UserId == userId);
            if (member is null)
            {
                errorMessage = "Member account not found.";
                return;
            }

            currentMemberId = member.Id;
            requests = await StandingTeeTimeService.GetForMemberAsync(currentMemberId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load standing tee time requests");
            errorMessage = "An unexpected error occurred while loading your requests. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ConfirmCancelAsync(int id)
    {
        cancelConfirmId = null;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await StandingTeeTimeService.CancelAsync(id, currentMemberId);
            if (result)
            {
                successMessage = "Standing tee time request cancelled.";
                await LoadDataAsync();
            }
            else
            {
                errorMessage = "Unable to cancel the request. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to cancel standing tee time request {Id}", id);
            errorMessage = "An unexpected error occurred. Please try again later.";
        }
    }

    private static string GetStatusBadgeClass(StandingTeeTimeStatus status) => status switch
    {
        StandingTeeTimeStatus.Draft => "bg-secondary",
        StandingTeeTimeStatus.Approved => "bg-success",
        StandingTeeTimeStatus.Allocated => "bg-primary",
        StandingTeeTimeStatus.Unallocated => "bg-warning text-dark",
        StandingTeeTimeStatus.Cancelled => "bg-danger",
        StandingTeeTimeStatus.Denied => "bg-danger",
        _ => "bg-secondary"
    };
}
