@page "/admin/users/create"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.Admin)]

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Domain2.Entities.Membership
@using ClubBaist.Services2

@inject UserManager<ClubBaistUser> UserManager
@inject IAppDbContext2 DbContext
@inject NavigationManager NavigationManager
@inject ILogger<CreateUser> Logger

<PageTitle>Create User - Club Baist</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Create User</h3>
    <a href="/admin/users" class="btn btn-outline-secondary">Back to Users</a>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

<EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="createUserForm">
    <DataAnnotationsValidator />

    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Account Details</h5></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <InputText id="email" class="form-control" @bind-Value="_model.Email" placeholder="email@example.com" />
                        <label for="email">Email Address</label>
                        <ValidationMessage For="() => _model.Email" />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <InputText id="password" type="password" class="form-control" @bind-Value="_model.Password" placeholder="Password" />
                        <label for="password">Password</label>
                        <ValidationMessage For="() => _model.Password" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="_model.ConfirmPassword" placeholder="Confirm Password" />
                        <label for="confirmPassword">Confirm Password</label>
                        <ValidationMessage For="() => _model.ConfirmPassword" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Roles</h5></div>
        <div class="card-body">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="roleAdmin"
                       @bind="_model.IsAdmin" />
                <label class="form-check-label" for="roleAdmin">
                    <span class="badge @UiHelpers.GetRoleBadgeClass(AppRoles.Admin) me-1">Admin</span>
                    Full system access
                </label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="roleCommittee"
                       @bind="_model.IsMembershipCommittee" />
                <label class="form-check-label" for="roleCommittee">
                    <span class="badge @UiHelpers.GetRoleBadgeClass(AppRoles.MembershipCommittee) me-1">MembershipCommittee</span>
                    Can review membership applications
                </label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="roleMember"
                       @bind="_model.IsMember" />
                <label class="form-check-label" for="roleMember">
                    <span class="badge @UiHelpers.GetRoleBadgeClass(AppRoles.Member) me-1">Member</span>
                    Club member with tee time access — fill in member profile below
                </label>
            </div>
        </div>
    </div>

    @if (_model.IsMember)
    {
        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0">Member Profile</h5></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputText id="firstName" class="form-control" @bind-Value="_model.FirstName" placeholder="First Name" />
                            <label for="firstName">First Name</label>
                            <ValidationMessage For="() => _model.FirstName" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputText id="lastName" class="form-control" @bind-Value="_model.LastName" placeholder="Last Name" />
                            <label for="lastName">Last Name</label>
                            <ValidationMessage For="() => _model.LastName" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputDate id="dateOfBirth" class="form-control" @bind-Value="_model.DateOfBirth" />
                            <label for="dateOfBirth">Date of Birth</label>
                            <ValidationMessage For="() => _model.DateOfBirth" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputSelect id="membershipLevel" class="form-select" @bind-Value="_model.MembershipLevelId">
                                <option value="">-- Select Level --</option>
                                @foreach (var level in _levels)
                                {
                                    <option value="@level.Id">@level.Name</option>
                                }
                            </InputSelect>
                            <label for="membershipLevel">Membership Level</label>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputText id="phone" class="form-control" @bind-Value="_model.Phone" placeholder="Phone" />
                            <label for="phone">Phone (e.g. (403) 555-1234)</label>
                            <ValidationMessage For="() => _model.Phone" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputText id="alternatePhone" class="form-control" @bind-Value="_model.AlternatePhone" placeholder="Alternate Phone (optional)" />
                            <label for="alternatePhone">Alternate Phone (optional)</label>
                            <ValidationMessage For="() => _model.AlternatePhone" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-8">
                        <div class="form-floating mb-3">
                            <InputText id="address" class="form-control" @bind-Value="_model.Address" placeholder="Address" />
                            <label for="address">Address</label>
                            <ValidationMessage For="() => _model.Address" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating mb-3">
                            <InputText id="postalCode" class="form-control" @bind-Value="_model.PostalCode" placeholder="Postal Code" />
                            <label for="postalCode">Postal Code (e.g. T2A 4K3)</label>
                            <ValidationMessage For="() => _model.PostalCode" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary" disabled="@_submitting">
        @if (_submitting)
        {
            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
        }
        Create User
    </button>
</EditForm>

@code {
    private sealed class CreateUserModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;

        public bool IsAdmin { get; set; }
        public bool IsMembershipCommittee { get; set; }
        public bool IsMember { get; set; }

        // Member profile fields — required only when IsMember is true (validated manually)
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public DateTime DateOfBirth { get; set; } = DateTime.Today.AddYears(-30);

        [RegularExpression(@"^\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$", ErrorMessage = "Enter a valid 10-digit Canadian phone number (e.g. (403) 555-1234).")]
        public string? Phone { get; set; }

        [RegularExpression(@"^\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$", ErrorMessage = "Enter a valid 10-digit Canadian phone number (e.g. (403) 555-1234).")]
        public string? AlternatePhone { get; set; }

        public string? Address { get; set; }

        [RegularExpression(@"^[A-Za-z]\d[A-Za-z]\s?\d[A-Za-z]\d$", ErrorMessage = "Enter a valid Canadian postal code (e.g. T2A 4K3).")]
        public string? PostalCode { get; set; }

        public int? MembershipLevelId { get; set; }
    }

    private readonly CreateUserModel _model = new();
    private List<MembershipLevel> _levels = [];
    private bool _submitting;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        _levels = await DbContext.MembershipLevels.ToListAsync();
    }

    private async Task HandleSubmitAsync()
    {
        _errorMessage = null;

        // Manual validation for member profile fields
        if (_model.IsMember)
        {
            if (string.IsNullOrWhiteSpace(_model.FirstName) ||
                string.IsNullOrWhiteSpace(_model.LastName) ||
                string.IsNullOrWhiteSpace(_model.Phone) ||
                string.IsNullOrWhiteSpace(_model.Address) ||
                string.IsNullOrWhiteSpace(_model.PostalCode) ||
                _model.MembershipLevelId is null)
            {
                _errorMessage = "All member profile fields are required when assigning the Member role.";
                return;
            }
        }

        _submitting = true;
        try
        {
            var normalizedPhone = _model.IsMember && _model.Phone is not null ? NormalizePhone(_model.Phone) : null;
            var normalizedAltPhone = _model.IsMember && _model.AlternatePhone is not null ? NormalizePhone(_model.AlternatePhone) : null;
            var normalizedPostalCode = _model.IsMember && _model.PostalCode is not null ? NormalizePostalCode(_model.PostalCode) : null;

            var user = new ClubBaistUser
            {
                UserName = _model.Email,
                Email = _model.Email,
                EmailConfirmed = true,
                FirstName = _model.IsMember ? (_model.FirstName ?? string.Empty) : string.Empty,
                LastName = _model.IsMember ? (_model.LastName ?? string.Empty) : string.Empty,
                PhoneNumber = _model.IsMember ? (normalizedPhone ?? string.Empty) : string.Empty,
                DateOfBirth = _model.IsMember ? _model.DateOfBirth : default,
                AddressLine1 = _model.IsMember ? (_model.Address ?? string.Empty) : string.Empty,
                PostalCode = _model.IsMember ? (normalizedPostalCode ?? string.Empty) : string.Empty,
                AlternatePhoneNumber = _model.IsMember ? normalizedAltPhone : null
            };

            var createResult = await UserManager.CreateAsync(user, _model.Password);
            if (!createResult.Succeeded)
            {
                _errorMessage = string.Join(" ", createResult.Errors.Select(e => e.Description));
                return;
            }

            // Assign non-member roles, validating each result
            var nonMemberRoles = new List<string>();
            if (_model.IsAdmin) nonMemberRoles.Add(AppRoles.Admin);
            if (_model.IsMembershipCommittee) nonMemberRoles.Add(AppRoles.MembershipCommittee);

            foreach (var role in nonMemberRoles)
            {
                var roleResult = await UserManager.AddToRoleAsync(user, role);
                if (!roleResult.Succeeded)
                {
                    Logger.LogError("Failed to assign role '{Role}' to '{Email}': {Errors}", role, user.Email,
                        string.Join(", ", roleResult.Errors.Select(e => $"{e.Code}: {e.Description}")));
                    await UserManager.DeleteAsync(user);
                    _errorMessage = $"Failed to assign role '{role}': {string.Join(" ", roleResult.Errors.Select(e => e.Description))}";
                    return;
                }
            }

            // Member role + membership record are saved atomically in a single transaction
            if (_model.IsMember)
            {
                await using var transaction = await DbContext.BeginTransactionAsync(System.Data.IsolationLevel.ReadCommitted);
                try
                {
                    var memberRoleResult = await UserManager.AddToRoleAsync(user, AppRoles.Member);
                    if (!memberRoleResult.Succeeded)
                    {
                        Logger.LogError("Failed to assign Member role to '{Email}': {Errors}", user.Email,
                            string.Join(", ", memberRoleResult.Errors.Select(e => $"{e.Code}: {e.Description}")));
                        await transaction.RollbackAsync();
                        await UserManager.DeleteAsync(user);
                        _errorMessage = $"Failed to assign Member role: {string.Join(" ", memberRoleResult.Errors.Select(e => e.Description))}";
                        return;
                    }

                    var level = _levels.First(l => l.Id == _model.MembershipLevelId!.Value);
                    DbContext.MemberShips.Add(new MemberShipInfo { User = user, MembershipLevel = level });
                    await DbContext.SaveChangesAsync();
                    await transaction.CommitAsync();
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Failed to create membership record for '{Email}'; rolling back", user.Email);
                    await transaction.RollbackAsync();
                    await UserManager.DeleteAsync(user);
                    _errorMessage = "Failed to save membership record. Please try again.";
                    return;
                }
            }

            NavigationManager.NavigateTo($"/admin/users/{user.Id}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create user");
            _errorMessage = "An unexpected error occurred while creating the user. Please try again.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string NormalizePostalCode(string postalCode)
    {
        var cleaned = postalCode.ToUpperInvariant().Replace(" ", "");
        return cleaned.Length == 6 ? $"{cleaned[..3]} {cleaned[3..]}" : postalCode.ToUpperInvariant();
    }

    private static string NormalizePhone(string phone)
    {
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        return digits.Length == 10
            ? $"({digits[..3]}) {digits[3..6]}-{digits[6..]}"
            : phone;
    }
}
