@page "/admin/standing-teetimes"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.Admin)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Services2

@inject IAppDbContext2 DbContext
@inject StandingTeeTimeService StandingTeeTimeService
@inject ILogger<StandingTeeTimes> Logger

<PageTitle>Standing Tee Times - Club Baist</PageTitle>

<h3 class="mb-4">Standing Tee Time Requests</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (allRequests is null || allRequests.Count == 0)
{
    <div class="alert alert-info">No standing tee time requests found.</div>
}
else
{
    <div class="mb-3">
        <div class="d-flex gap-2 flex-wrap">
            @foreach (var status in new[] { (StandingTeeTimeStatus?)null, StandingTeeTimeStatus.Draft, StandingTeeTimeStatus.Approved, StandingTeeTimeStatus.Allocated, StandingTeeTimeStatus.Unallocated, StandingTeeTimeStatus.Denied, StandingTeeTimeStatus.Cancelled })
            {
                <button class="btn btn-sm @(statusFilter == status ? "btn-primary" : "btn-outline-secondary")"
                        @onclick="() => SetFilter(status)">
                    @(status.HasValue ? status.Value.ToString() : "All") @if (!status.HasValue)
                    {
                        <span class="badge bg-secondary ms-1">@allRequests.Count</span>
                    }
                    else
                    {
                        var count = allRequests.Count(r => r.Status == status.Value);
                        if (count > 0) { <span class="badge bg-secondary ms-1">@count</span> }
                    }
                </button>
            }
        </div>
    </div>

    @if (FilteredRequests.Count == 0)
    {
        <div class="alert alert-info">No requests match the current filter.</div>
    }
    else
    {
        <QuickGrid Items="@FilteredRequests.AsQueryable()" Class="table table-striped table-hover">
            <TemplateColumn Title="Member" SortBy="@(GridSort<StandingTeeTime>.ByAscending(r => r.BookingMember.User.LastName).ThenAscending(r => r.BookingMember.User.FirstName))">
                <strong>@context.BookingMember.User.FirstName @context.BookingMember.User.LastName</strong>
                <small class="text-muted ms-1">(#@context.BookingMember.MembershipNumber)</small>
            </TemplateColumn>
            <TemplateColumn Title="Day / Time" SortBy="@(GridSort<StandingTeeTime>.ByAscending(r => r.RequestedDayOfWeek).ThenAscending(r => r.RequestedTime))">
                @context.RequestedDayOfWeek, @context.RequestedTime.ToString("h:mm tt")
                <small class="text-muted ms-1">(±@context.ToleranceMinutes min)</small>
            </TemplateColumn>
            <TemplateColumn Title="Season">
                @context.StartDate.ToString("MMM d") – @context.EndDate.ToString("MMM d, yyyy")
            </TemplateColumn>
            <TemplateColumn Title="Players">
                <span>@context.BookingMember.User.FirstName @context.BookingMember.User.LastName</span>
                @foreach (var p in context.AdditionalParticipants)
                {
                    <text>, @p.User.FirstName @p.User.LastName</text>
                }
            </TemplateColumn>
            <TemplateColumn Title="Status" SortBy="@(GridSort<StandingTeeTime>.ByAscending(r => r.Status))">
                <span class="badge @GetStatusBadgeClass(context.Status)">@context.Status</span>
            </TemplateColumn>
            <TemplateColumn Title="Approved Time / Priority">
                @if (context.ApprovedTime.HasValue)
                {
                    <span>@context.ApprovedTime.Value.ToString("h:mm tt")</span>
                }
                @if (context.PriorityNumber.HasValue)
                {
                    <span class="badge bg-info ms-1">#@context.PriorityNumber</span>
                }
                @if (!context.ApprovedTime.HasValue && !context.PriorityNumber.HasValue)
                {
                    <span class="text-muted">—</span>
                }
            </TemplateColumn>
            <TemplateColumn Title="Actions">
                @if (context.Status == StandingTeeTimeStatus.Draft)
                {
                    @if (approvePanel == context.Id)
                    {
                        <div class="p-2 border rounded bg-light">
                            <div class="mb-2">
                                <label class="form-label small mb-1" for="@($"approvedTime-{context.Id}")">Approved Time <span class="text-danger">*</span></label>
                                <input id="@($"approvedTime-{context.Id}")" type="time" class="form-control form-control-sm"
                                       value="@approvedTimeStr"
                                       @onchange="OnApprovedTimeChanged" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label small mb-1" for="@($"priority-{context.Id}")">Priority Number</label>
                                <input id="@($"priority-{context.Id}")" type="number" class="form-control form-control-sm" min="1"
                                       @bind="approvedPriority" placeholder="Optional" />
                            </div>
                            <button class="btn btn-sm btn-success me-1" @onclick="() => ApproveAsync(context.Id)"
                                    disabled="@isProcessing">
                                @if (isProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                Confirm
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => approvePanel = null"
                                    disabled="@isProcessing">
                                Cancel
                            </button>
                        </div>
                    }
                    else if (denyConfirmId == context.Id)
                    {
                        <span class="me-2 small">Deny this request?</span>
                        <button class="btn btn-sm btn-danger me-1" @onclick="() => DenyAsync(context.Id)"
                                disabled="@isProcessing">
                            @if (isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            Yes
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => denyConfirmId = null">No</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-success me-2" @onclick="() => OpenApprovePanel(context.Id)">
                            Approve
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => denyConfirmId = context.Id">
                            Deny
                        </button>
                    }
                }
            </TemplateColumn>
        </QuickGrid>
    }
}

@code {
    private bool isLoading = true;
    private bool isProcessing;
    private string? errorMessage;
    private string? successMessage;
    private StandingTeeTimeStatus? statusFilter;

    private IReadOnlyList<StandingTeeTime>? allRequests;

    private IReadOnlyList<StandingTeeTime> FilteredRequests =>
        allRequests is null ? [] :
        statusFilter is null ? allRequests :
        allRequests.Where(r => r.Status == statusFilter.Value).ToList();

    private int? approvePanel;
    private string approvedTimeStr = "08:00";
    private int? approvedPriority;

    private int? denyConfirmId;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            allRequests = await StandingTeeTimeService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load standing tee time requests");
            errorMessage = "An unexpected error occurred while loading requests. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetFilter(StandingTeeTimeStatus? status)
    {
        statusFilter = status;
    }

    private void OpenApprovePanel(int id)
    {
        approvePanel = id;
        approvedTimeStr = "08:00";
        approvedPriority = null;
        denyConfirmId = null;
    }

    private void OnApprovedTimeChanged(ChangeEventArgs e) =>
        approvedTimeStr = e.Value?.ToString() ?? "08:00";

    private async Task ApproveAsync(int id)
    {
        if (!TimeOnly.TryParse(approvedTimeStr, out var approvedTime))
        {
            errorMessage = "Please enter a valid approved time.";
            return;
        }

        isProcessing = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await StandingTeeTimeService.ApproveAsync(id, approvedTime, approvedPriority);
            if (result)
            {
                successMessage = $"Request #{id} approved with time {approvedTime:h:mm tt}.";
                approvePanel = null;
                await LoadDataAsync();
            }
            else
            {
                errorMessage = "Unable to approve the request. It may have already been processed.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to approve standing tee time request {Id}", id);
            errorMessage = "An unexpected error occurred. Please try again later.";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task DenyAsync(int id)
    {
        isProcessing = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await StandingTeeTimeService.DenyAsync(id);
            if (result)
            {
                successMessage = $"Request #{id} denied.";
                denyConfirmId = null;
                await LoadDataAsync();
            }
            else
            {
                errorMessage = "Unable to deny the request. It may have already been processed.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to deny standing tee time request {Id}", id);
            errorMessage = "An unexpected error occurred. Please try again later.";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private static string GetStatusBadgeClass(StandingTeeTimeStatus status) => status switch
    {
        StandingTeeTimeStatus.Draft => "bg-secondary",
        StandingTeeTimeStatus.Approved => "bg-success",
        StandingTeeTimeStatus.Allocated => "bg-primary",
        StandingTeeTimeStatus.Unallocated => "bg-warning text-dark",
        StandingTeeTimeStatus.Cancelled => "bg-danger",
        StandingTeeTimeStatus.Denied => "bg-danger",
        _ => "bg-secondary"
    };
}
