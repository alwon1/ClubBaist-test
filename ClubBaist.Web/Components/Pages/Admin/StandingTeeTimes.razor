@page "/admin/standing-teetimes"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.Admin)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Services2

@inject IAppDbContext2 DbContext
@inject StandingTeeTimeService StandingTeeTimeService
@inject ILogger<StandingTeeTimes> Logger

<PageTitle>Standing Tee Times - Club Baist</PageTitle>

<h3 class="mb-4">Standing Tee Time Requests</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

@if (!isLoading)
{
    <div class="card mb-4">
        <div class="card-header">
            <strong>Create Standing Tee Time Request (Admin)</strong>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="bookingMember">Booking Shareholder</label>
                    <select id="bookingMember" class="form-select" value="@selectedBookingMemberId" @onchange="OnBookingMemberChanged">
                        <option value="0">-- Select Shareholder --</option>
                        @foreach (var member in shareholderMembers)
                        {
                            <option value="@member.Id">@member.MembershipNumber - @member.User.FirstName @member.User.LastName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="requestedDay">Day</label>
                    <select id="requestedDay" class="form-select" @bind="createRequestedDayOfWeek">
                        @foreach (var day in Enum.GetValues<DayOfWeek>())
                        {
                            <option value="@day">@day</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="requestedTime">Time</label>
                    <input id="requestedTime" type="time" class="form-control" value="@createRequestedTimeStr" @onchange="OnCreateTimeChanged" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="tolerance">Tolerance</label>
                    <select id="tolerance" class="form-select" @bind="createToleranceMinutes">
                        <option value="0">0 min</option>
                        <option value="15">±15 min</option>
                        <option value="30">±30 min</option>
                        <option value="60">±60 min</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="priority">Priority</label>
                    <input id="priority" type="number" class="form-control" min="1" @bind="createPriority" placeholder="Optional" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="startDate">Start Date</label>
                    <input id="startDate" type="date" class="form-control" value="@createStartDateStr" @onchange="OnCreateStartDateChanged" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="endDate">End Date</label>
                    <input id="endDate" type="date" class="form-control" value="@createEndDateStr" @onchange="OnCreateEndDateChanged" />
                </div>
                @for (var i = 0; i < 3; i++)
                {
                    var idx = i;
                    <div class="col-md-2">
                        <label class="form-label" for="@($"player-{idx}")">Player @(idx + 2)</label>
                        <select id="@($"player-{idx}")" class="form-select" value="@createAdditionalPlayerIds[idx]" @onchange="(e) => OnCreatePlayerChanged(idx, e)">
                            <option value="0">-- Select --</option>
                            @foreach (var member in allMembers.Where(m => m.Id != selectedBookingMemberId))
                            {
                                <option value="@member.Id">@member.MembershipNumber - @member.User.FirstName @member.User.LastName</option>
                            }
                        </select>
                    </div>
                }
                <div class="col-md-3 align-self-end">
                    <button class="btn btn-primary" @onclick="CreateStandingRequestAsync" disabled="@isCreatingRequest">
                        @if (isCreatingRequest)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Create Request
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (allRequests is null || allRequests.Count == 0)
{
    <div class="alert alert-info">No standing tee time requests found.</div>
}
else
{
    <div class="mb-3">
        <div class="d-flex gap-2 flex-wrap">
            @foreach (var status in new[] { (StandingTeeTimeStatus?)null, StandingTeeTimeStatus.Draft, StandingTeeTimeStatus.Approved, StandingTeeTimeStatus.Allocated, StandingTeeTimeStatus.Unallocated, StandingTeeTimeStatus.Denied, StandingTeeTimeStatus.Cancelled })
            {
                <button class="btn btn-sm @(statusFilter == status ? "btn-primary" : "btn-outline-secondary")"
                        @onclick="() => SetFilter(status)">
                    @(status.HasValue ? status.Value.ToString() : "All") @if (!status.HasValue)
                    {
                        <span class="badge bg-secondary ms-1">@allRequests.Count</span>
                    }
                    else
                    {
                        var count = allRequests.Count(r => r.Status == status.Value);
                        if (count > 0) { <span class="badge bg-secondary ms-1">@count</span> }
                    }
                </button>
            }
        </div>
    </div>

    @if (FilteredRequests.Count == 0)
    {
        <div class="alert alert-info">No requests match the current filter.</div>
    }
    else
    {
        <QuickGrid Items="@FilteredRequests.AsQueryable()" Class="table table-striped table-hover">
            <TemplateColumn Title="Member" SortBy="@(GridSort<StandingTeeTime>.ByAscending(r => r.BookingMember.User.LastName).ThenAscending(r => r.BookingMember.User.FirstName))">
                <strong>@context.BookingMember.User.FirstName @context.BookingMember.User.LastName</strong>
                <small class="text-muted ms-1">(#@context.BookingMember.MembershipNumber)</small>
            </TemplateColumn>
            <TemplateColumn Title="Day / Time" SortBy="@(GridSort<StandingTeeTime>.ByAscending(r => r.RequestedDayOfWeek).ThenAscending(r => r.RequestedTime))">
                @context.RequestedDayOfWeek, @context.RequestedTime.ToString("h:mm tt")
                <small class="text-muted ms-1">(±@context.ToleranceMinutes min)</small>
            </TemplateColumn>
            <TemplateColumn Title="Season">
                @context.StartDate.ToString("MMM d") – @context.EndDate.ToString("MMM d, yyyy")
            </TemplateColumn>
            <TemplateColumn Title="Players">
                <span>@context.BookingMember.User.FirstName @context.BookingMember.User.LastName</span>
                @foreach (var p in context.AdditionalParticipants)
                {
                    <text>, @p.User.FirstName @p.User.LastName</text>
                }
            </TemplateColumn>
            <TemplateColumn Title="Status" SortBy="@(GridSort<StandingTeeTime>.ByAscending(r => r.Status))">
                <span class="badge @UiHelpers.GetStandingTeeTimeStatusBadgeClass(context.Status)">@context.Status</span>
            </TemplateColumn>
            <TemplateColumn Title="Approved Time / Priority">
                @if (context.ApprovedTime.HasValue)
                {
                    <span>@context.ApprovedTime.Value.ToString("h:mm tt")</span>
                }
                @if (context.PriorityNumber.HasValue)
                {
                    <span class="badge bg-info ms-1">#@context.PriorityNumber</span>
                }
                @if (!context.ApprovedTime.HasValue && !context.PriorityNumber.HasValue)
                {
                    <span class="text-muted">—</span>
                }
            </TemplateColumn>
            <TemplateColumn Title="Actions">
                @if (context.Status == StandingTeeTimeStatus.Draft)
                {
                    @if (approvePanel == context.Id)
                    {
                        <div class="p-2 border rounded bg-light">
                            <div class="mb-2">
                                <label class="form-label small mb-1" for="@($"approvedTime-{context.Id}")">Approved Time <span class="text-danger">*</span></label>
                                <input id="@($"approvedTime-{context.Id}")" type="time" class="form-control form-control-sm"
                                       value="@approvedTimeStr"
                                       @onchange="OnApprovedTimeChanged" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label small mb-1" for="@($"priority-{context.Id}")">Priority Number</label>
                                <input id="@($"priority-{context.Id}")" type="number" class="form-control form-control-sm" min="1"
                                       @bind="approvedPriority" placeholder="Optional" />
                            </div>
                            <button class="btn btn-sm btn-success me-1" @onclick="() => ApproveAsync(context.Id)"
                                    disabled="@isProcessing">
                                @if (isProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                Confirm
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => approvePanel = null"
                                    disabled="@isProcessing">
                                Cancel
                            </button>
                        </div>
                    }
                    else if (denyConfirmId == context.Id)
                    {
                        <span class="me-2 small">Deny this request?</span>
                        <button class="btn btn-sm btn-danger me-1" @onclick="() => DenyAsync(context.Id)"
                                disabled="@isProcessing">
                            @if (isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            Yes
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => denyConfirmId = null">No</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-success me-2" @onclick="() => OpenApprovePanel(context.Id)">
                            Approve
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => denyConfirmId = context.Id">
                            Deny
                        </button>
                    }
                }
            </TemplateColumn>
        </QuickGrid>
    }
}

@code {
    private bool isLoading = true;
    private bool isProcessing;
    private string? errorMessage;
    private string? successMessage;
    private StandingTeeTimeStatus? statusFilter;

    private IReadOnlyList<StandingTeeTime>? allRequests;
    private List<MemberShipInfo> allMembers = [];
    private List<MemberShipInfo> shareholderMembers = [];

    private int selectedBookingMemberId;
    private DayOfWeek createRequestedDayOfWeek = DayOfWeek.Saturday;
    private string createRequestedTimeStr = "08:00";
    private int createToleranceMinutes = 30;
    private int? createPriority;
    private string createStartDateStr = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
    private string createEndDateStr = DateOnly.FromDateTime(DateTime.Today.AddMonths(6)).ToString("yyyy-MM-dd");
    private List<int> createAdditionalPlayerIds = [0, 0, 0];
    private bool isCreatingRequest;

    private IReadOnlyList<StandingTeeTime> FilteredRequests =>
        allRequests is null ? [] :
        statusFilter is null ? allRequests :
        allRequests.Where(r => r.Status == statusFilter.Value).ToList();

    private int? approvePanel;
    private string approvedTimeStr = "08:00";
    private int? approvedPriority;

    private int? denyConfirmId;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            allRequests = await StandingTeeTimeService.GetAllAsync();
            allMembers = await DbContext.MemberShips
                .AsNoTracking()
                .OrderBy(m => m.User.LastName)
                .ThenBy(m => m.User.FirstName)
                .ToListAsync();

            shareholderMembers = allMembers
                .Where(m => string.Equals(m.MembershipLevel.ShortCode, "SH", StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load standing tee time requests");
            errorMessage = "An unexpected error occurred while loading requests. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetFilter(StandingTeeTimeStatus? status)
    {
        statusFilter = status;
    }

    private void OpenApprovePanel(int id)
    {
        approvePanel = id;
        approvedTimeStr = "08:00";
        approvedPriority = null;
        denyConfirmId = null;
    }

    private void OnApprovedTimeChanged(ChangeEventArgs e) =>
        approvedTimeStr = e.Value?.ToString() ?? "08:00";

    private void OnBookingMemberChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var memberId))
        {
            selectedBookingMemberId = memberId;
        }
    }

    private void OnCreateTimeChanged(ChangeEventArgs e) =>
        createRequestedTimeStr = e.Value?.ToString() ?? "08:00";

    private void OnCreateStartDateChanged(ChangeEventArgs e) =>
        createStartDateStr = e.Value?.ToString() ?? string.Empty;

    private void OnCreateEndDateChanged(ChangeEventArgs e) =>
        createEndDateStr = e.Value?.ToString() ?? string.Empty;

    private void OnCreatePlayerChanged(int index, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var memberId))
        {
            createAdditionalPlayerIds[index] = memberId;
        }
    }

    private async Task CreateStandingRequestAsync()
    {
        errorMessage = null;
        successMessage = null;

        if (selectedBookingMemberId <= 0)
        {
            errorMessage = "Please select a booking shareholder member.";
            return;
        }

        var bookingMember = shareholderMembers.FirstOrDefault(m => m.Id == selectedBookingMemberId);
        if (bookingMember is null)
        {
            errorMessage = "Selected booking member is invalid. Only shareholders may be selected.";
            return;
        }

        if (!TimeOnly.TryParse(createRequestedTimeStr, out var requestedTime))
        {
            errorMessage = "Please enter a valid requested time.";
            return;
        }

        if (!DateOnly.TryParse(createStartDateStr, out var startDate) || !DateOnly.TryParse(createEndDateStr, out var endDate))
        {
            errorMessage = "Please enter valid start and end dates.";
            return;
        }

        var playerIds = createAdditionalPlayerIds.Where(id => id > 0).Distinct().ToList();
        if (playerIds.Count != 3)
        {
            errorMessage = "Please select exactly 3 unique additional players.";
            return;
        }

        if (playerIds.Contains(selectedBookingMemberId))
        {
            errorMessage = "Booking member cannot also be selected as an additional player.";
            return;
        }

        var players = allMembers.Where(m => playerIds.Contains(m.Id)).ToList();
        if (players.Count != 3)
        {
            errorMessage = "One or more selected players are invalid.";
            return;
        }

        isCreatingRequest = true;
        try
        {
            var request = new StandingTeeTime
            {
                BookingMemberId = bookingMember.Id,
                BookingMember = bookingMember,
                RequestedDayOfWeek = createRequestedDayOfWeek,
                RequestedTime = requestedTime,
                ToleranceMinutes = createToleranceMinutes,
                StartDate = startDate,
                EndDate = endDate,
                PriorityNumber = createPriority,
                AdditionalParticipants = players
            };

            var (success, error) = await StandingTeeTimeService.SubmitRequestAsync(request);
            if (!success)
            {
                errorMessage = error ?? "Unable to create standing tee time request.";
                return;
            }

            successMessage = "Standing tee time request created.";
            createAdditionalPlayerIds = [0, 0, 0];
            createPriority = null;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create standing tee time request from admin page");
            errorMessage = "An unexpected error occurred while creating the request.";
        }
        finally
        {
            isCreatingRequest = false;
        }
    }

    private async Task ApproveAsync(int id)
    {
        if (!TimeOnly.TryParse(approvedTimeStr, out var approvedTime))
        {
            errorMessage = "Please enter a valid approved time.";
            return;
        }

        if (approvedPriority.HasValue && approvedPriority.Value < 1)
        {
            errorMessage = "Priority number must be 1 or greater.";
            return;
        }

        isProcessing = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await StandingTeeTimeService.ApproveAsync(id, approvedTime, approvedPriority);
            if (result)
            {
                successMessage = $"Request #{id} approved with time {approvedTime:h:mm tt}.";
                approvePanel = null;
                await LoadDataAsync();
            }
            else
            {
                errorMessage = "Unable to approve the request. It may have already been processed.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to approve standing tee time request {Id}", id);
            errorMessage = "An unexpected error occurred. Please try again later.";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task DenyAsync(int id)
    {
        isProcessing = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await StandingTeeTimeService.DenyAsync(id);
            if (result)
            {
                successMessage = $"Request #{id} denied.";
                denyConfirmId = null;
                await LoadDataAsync();
            }
            else
            {
                errorMessage = "Unable to deny the request. It may have already been processed.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to deny standing tee time request {Id}", id);
            errorMessage = "An unexpected error occurred. Please try again later.";
        }
        finally
        {
            isProcessing = false;
        }
    }

}
