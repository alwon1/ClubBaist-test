@page "/admin/members/{MemberId:int}"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.Admin)]

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain2
@using ClubBaist.Domain2.Entities.Membership
@using ClubBaist.Services2
@using ClubBaist.Services2.Membership

@inject IAppDbContext2 DbContext
@inject IMemberClaimSynchroniser ClaimSynchroniser
@inject ILogger<EditMember> Logger

<PageTitle>Edit Member - Club Baist</PageTitle>

@if (_loading)
{
    <div class="d-flex justify-content-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_member is null)
{
    <div class="alert alert-warning">Member not found.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3>
                Edit Member
                <span class="badge bg-secondary ms-2">@_member.MembershipNumber</span>
            </h3>
        </div>
        <a href="@($"/admin/users/{_member.User.Id}")" class="btn btn-outline-secondary">Back to User</a>
    </div>

    @if (!string.IsNullOrEmpty(_resultMessage))
    {
        <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible fade show">
            @_resultMessage
            <button type="button" class="btn-close" @onclick="() => _resultMessage = null"></button>
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="editMemberForm">
        <DataAnnotationsValidator />

        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0">Personal Information</h5></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputText id="firstName" class="form-control" @bind-Value="_model.FirstName" placeholder="First Name" />
                            <label for="firstName">First Name</label>
                            <ValidationMessage For="() => _model.FirstName" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputText id="lastName" class="form-control" @bind-Value="_model.LastName" placeholder="Last Name" />
                            <label for="lastName">Last Name</label>
                            <ValidationMessage For="() => _model.LastName" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputDate id="dateOfBirth" class="form-control" @bind-Value="_model.DateOfBirth" />
                            <label for="dateOfBirth">Date of Birth</label>
                            <ValidationMessage For="() => _model.DateOfBirth" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputText id="phone" class="form-control" @bind-Value="_model.Phone" placeholder="Phone" />
                            <label for="phone">Phone (e.g. (403) 555-1234)</label>
                            <ValidationMessage For="() => _model.Phone" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputText id="alternatePhone" class="form-control" @bind-Value="_model.AlternatePhone" placeholder="Alternate Phone (optional)" />
                            <label for="alternatePhone">Alternate Phone (optional)</label>
                            <ValidationMessage For="() => _model.AlternatePhone" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-8">
                        <div class="form-floating mb-3">
                            <InputText id="address" class="form-control" @bind-Value="_model.Address" placeholder="Address" />
                            <label for="address">Address</label>
                            <ValidationMessage For="() => _model.Address" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating mb-3">
                            <InputText id="postalCode" class="form-control" @bind-Value="_model.PostalCode" placeholder="Postal Code" />
                            <label for="postalCode">Postal Code (e.g. T2A 4K3)</label>
                            <ValidationMessage For="() => _model.PostalCode" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0">Membership</h5></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <InputSelect id="membershipLevel" class="form-select" @bind-Value="_model.MembershipLevelId">
                                @foreach (var level in _levels)
                                {
                                    <option value="@level.Id">@level.Name</option>
                                }
                            </InputSelect>
                            <label for="membershipLevel">Membership Level</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary" disabled="@_submitting">
            @if (_submitting)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            Save Changes
        </button>
    </EditForm>
}

@code {
    [Parameter]
    public int MemberId { get; set; }

    private MemberShipInfo? _member;
    private List<MembershipLevel> _levels = [];
    private bool _loading = true;
    private bool _submitting;
    private string? _resultMessage;
    private bool _isError;

    private sealed class EditMemberModel
    {
        [Required(ErrorMessage = "First name is required.")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required.")]
        public string LastName { get; set; } = string.Empty;

        [Required]
        public DateTime DateOfBirth { get; set; }

        [Required(ErrorMessage = "Phone is required.")]
        [RegularExpression(@"^\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$", ErrorMessage = "Enter a valid 10-digit Canadian phone number (e.g. (403) 555-1234).")]
        public string Phone { get; set; } = string.Empty;

        [RegularExpression(@"^\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$", ErrorMessage = "Enter a valid 10-digit Canadian phone number (e.g. (403) 555-1234).")]
        public string? AlternatePhone { get; set; }

        [Required(ErrorMessage = "Address is required.")]
        public string Address { get; set; } = string.Empty;

        [Required(ErrorMessage = "Postal code is required.")]
        [RegularExpression(@"^[A-Za-z]\d[A-Za-z]\s?\d[A-Za-z]\d$", ErrorMessage = "Enter a valid Canadian postal code (e.g. T2A 4K3).")]
        public string PostalCode { get; set; } = string.Empty;

        public int MembershipLevelId { get; set; }
    }

    private readonly EditMemberModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _levels = await DbContext.MembershipLevels.ToListAsync();

            _member = await DbContext.MemberShips
                .Include(m => m.User)
                .Include(m => m.MembershipLevel)
                .FirstOrDefaultAsync(m => m.Id == MemberId);

            if (_member is not null)
            {
                _model.FirstName = _member.User.FirstName ?? string.Empty;
                _model.LastName = _member.User.LastName ?? string.Empty;
                _model.DateOfBirth = _member.User.DateOfBirth;
                _model.Phone = _member.User.PhoneNumber ?? string.Empty;
                _model.AlternatePhone = _member.User.AlternatePhoneNumber;
                _model.Address = _member.User.AddressLine1 ?? string.Empty;
                _model.PostalCode = _member.User.PostalCode ?? string.Empty;
                _model.MembershipLevelId = _member.MembershipLevel.Id;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load member {MemberId}", MemberId);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleSubmitAsync()
    {
        if (_member is null) return;

        _submitting = true;
        _resultMessage = null;
        _isError = false;

        try
        {
            var normalizedPostalCode = NormalizePostalCode(_model.PostalCode);
            var normalizedPhone = NormalizePhone(_model.Phone);
            var normalizedAltPhone = _model.AlternatePhone is not null ? NormalizePhone(_model.AlternatePhone) : null;

            _member.User.FirstName = _model.FirstName;
            _member.User.LastName = _model.LastName;
            _member.User.DateOfBirth = _model.DateOfBirth;
            _member.User.PhoneNumber = normalizedPhone;
            _member.User.AlternatePhoneNumber = normalizedAltPhone;
            _member.User.AddressLine1 = _model.Address;
            _member.User.PostalCode = normalizedPostalCode;

            var newLevel = _levels.FirstOrDefault(l => l.Id == _model.MembershipLevelId);
            if (newLevel is null)
            {
                _resultMessage = "The selected membership level was not found. Please refresh and try again.";
                _isError = true;
                return;
            }
            _member.MembershipLevel = newLevel;

            await DbContext.SaveChangesAsync();

            // Sync membership-level claims (standing-tee-time.book, shareholder, copper-tier).
            var claimsSynced = await ClaimSynchroniser.SynchroniseAsync(_member.User, newLevel);

            _resultMessage = claimsSynced
                ? "Member profile updated successfully."
                : "Member profile saved, but the permission claims could not be fully synced. Please check the server logs and verify this user's claims.";
            _isError = !claimsSynced;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update member {MemberId}", MemberId);
            _resultMessage = "Failed to save changes. Please try again.";
            _isError = true;
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string NormalizePostalCode(string postalCode)
    {
        var cleaned = postalCode.ToUpperInvariant().Replace(" ", "");
        return cleaned.Length == 6 ? $"{cleaned[..3]} {cleaned[3..]}" : postalCode.ToUpperInvariant();
    }

    private static string NormalizePhone(string phone)
    {
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        return digits.Length == 10
            ? $"({digits[..3]}) {digits[3..6]}-{digits[6..]}"
            : phone;
    }
}
