@page "/teetimes/staff"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.Admin)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain
@using ClubBaist.Services

@inject TeeTimeBookingService<Guid> BookingService
@inject IApplicationDbContext<Guid> DbContext
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Staff Console - Club Baist</PageTitle>

<h3 class="mb-4">Staff Console</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header">
        <strong>Member Search</strong>
    </div>
    <div class="card-body">
        <div class="row align-items-end">
            <div class="col-md-6">
                <div class="form-floating mb-3">
                    <input type="text" class="form-control" id="searchInput"
                           @bind="searchTerm" @bind:event="oninput"
                           placeholder="Search by name or member number" />
                    <label for="searchInput">Name or Member Number</label>
                </div>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary mb-3" @onclick="SearchMembers" disabled="@isSearching">
                    @if (isSearching)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Search
                </button>
            </div>
        </div>

        @if (searchResults is not null && searchResults.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Member #</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in searchResults)
                        {
                            <tr class="@(selectedMember?.MemberAccountId == member.MemberAccountId ? "table-active" : "")">
                                <td>@member.MemberNumber</td>
                                <td>@member.FirstName @member.LastName</td>
                                <td>@member.Email</td>
                                <td>@member.MembershipCategory</td>
                                <td>
                                    @if (member.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => SelectMember(member)">
                                        Select
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (searchResults is not null)
        {
            <p class="text-muted">No members found matching your search.</p>
        }
    </div>
</div>

@if (selectedMember is not null)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Reservations for @selectedMember.FirstName @selectedMember.LastName (@selectedMember.MemberNumber)</strong>
            <a href="@($"/teetimes?date={DateOnly.FromDateTime(DateTime.Today):yyyy-MM-dd}")"
               class="btn btn-sm btn-primary">
                Book on Behalf
            </a>
        </div>
        <div class="card-body">
            @if (isLoadingReservations)
            {
                <div class="text-center my-3">
                    <div class="spinner-border spinner-border-sm" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (memberReservations is not null && memberReservations.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Players</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var res in memberReservations)
                            {
                                <tr class="@(res.IsCancelled ? "table-secondary" : "")">
                                    <td>@res.SlotDate.ToString("MMM d, yyyy")</td>
                                    <td>@res.SlotTime.ToString("h:mm tt")</td>
                                    <td>@(res.PlayerMemberAccountIds.Count + 1)</td>
                                    <td>
                                        @if (res.IsCancelled)
                                        {
                                            <span class="badge bg-secondary">Cancelled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@($"/teetimes/reservation/{res.ReservationId}")"
                                           class="btn btn-sm btn-outline-primary me-1">
                                            View/Edit
                                        </a>
                                        @if (!res.IsCancelled && res.SlotDate >= DateOnly.FromDateTime(DateTime.Today))
                                        {
                                            @if (cancelConfirmId == res.ReservationId)
                                            {
                                                <button class="btn btn-sm btn-danger me-1"
                                                        @onclick="() => ConfirmCancel(res.ReservationId)">
                                                    Confirm
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => cancelConfirmId = null">
                                                    No
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => cancelConfirmId = res.ReservationId">
                                                    Cancel
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No reservations found for this member.</p>
            }
        </div>
    </div>
}

@code {
    private string searchTerm = string.Empty;
    private bool isSearching;
    private bool isLoadingReservations;
    private string? errorMessage;
    private string? successMessage;
    private Guid? cancelConfirmId;

    private List<MemberAccount<Guid>>? searchResults;
    private MemberAccount<Guid>? selectedMember;
    private List<Reservation>? memberReservations;

    private async Task SearchMembers()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            errorMessage = "Please enter a search term.";
            return;
        }

        isSearching = true;
        errorMessage = null;
        selectedMember = null;
        memberReservations = null;

        try
        {
            var term = searchTerm.Trim().ToLower();
            searchResults = await DbContext.MemberAccounts
                .Where(m => m.FirstName.ToLower().Contains(term)
                         || m.LastName.ToLower().Contains(term)
                         || m.MemberNumber.ToLower().Contains(term))
                .OrderBy(m => m.LastName)
                .ThenBy(m => m.FirstName)
                .Take(50)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Search failed: {ex.Message}";
        }
        finally
        {
            isSearching = false;
        }
    }

    private async Task SelectMember(MemberAccount<Guid> member)
    {
        selectedMember = member;
        cancelConfirmId = null;
        isLoadingReservations = true;
        errorMessage = null;

        try
        {
            memberReservations = (await BookingService.GetMemberReservationsAsync(member.MemberAccountId))
                .OrderBy(r => r.SlotDate).ThenBy(r => r.SlotTime)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load reservations: {ex.Message}";
        }
        finally
        {
            isLoadingReservations = false;
        }
    }

    private async Task ConfirmCancel(Guid reservationId)
    {
        errorMessage = null;
        successMessage = null;
        cancelConfirmId = null;

        try
        {
            var result = await BookingService.CancelReservationAsync(reservationId);

            if (result)
            {
                successMessage = "Reservation cancelled successfully.";
                if (selectedMember is not null)
                {
                    await SelectMember(selectedMember);
                }
            }
            else
            {
                errorMessage = "Unable to cancel reservation. It may have already been cancelled.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to cancel reservation: {ex.Message}";
        }
    }
}
