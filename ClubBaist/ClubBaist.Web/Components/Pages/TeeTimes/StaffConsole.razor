@page "/teetimes/staff"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.Admin)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain
@using ClubBaist.Services

@inject TeeTimeBookingService<Guid> BookingService
@inject IApplicationDbContext<Guid> DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<StaffConsole> Logger

<PageTitle>Staff Console - Club Baist</PageTitle>

<h3 class="mb-4">Staff Console</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header">
        <strong>Member Search</strong>
    </div>
    <div class="card-body">
        <div class="row align-items-end">
            <div class="col-md-6">
                <div class="form-floating mb-3">
                    <input type="text" class="form-control" id="searchInput"
                           @bind="searchTerm" @bind:event="oninput"
                           placeholder="Search by name or member number" />
                    <label for="searchInput">Name or Member Number</label>
                </div>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary mb-3" @onclick="SearchMembers" disabled="@isSearching">
                    @if (isSearching)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Search
                </button>
            </div>
        </div>

        @if (searchResults is not null && searchResults.Count > 0)
        {
            <QuickGrid Items="@searchResults.AsQueryable()" Class="table table-striped table-hover"
                       RowClass="@(m => selectedMember?.MemberAccountId == m.MemberAccountId ? "table-active" : "")">
                <TemplateColumn Title="Member #" SortBy="@(GridSort<MemberAccount<Guid>>.ByAscending(m => m.MemberNumber))">
                    @context.MemberNumber
                </TemplateColumn>
                <TemplateColumn Title="Name" SortBy="@(GridSort<MemberAccount<Guid>>.ByAscending(m => m.LastName).ThenAscending(m => m.FirstName))">
                    @context.FirstName @context.LastName
                </TemplateColumn>
                <TemplateColumn Title="Email">
                    @context.Email
                </TemplateColumn>
                <TemplateColumn Title="Category">
                    @context.MembershipCategory
                </TemplateColumn>
                <TemplateColumn Title="Status">
                    @if (context.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </TemplateColumn>
                <TemplateColumn Title="Action">
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => SelectMember(context)">
                        Select
                    </button>
                </TemplateColumn>
            </QuickGrid>
        }
        else if (searchResults is not null)
        {
            <p class="text-muted">No members found matching your search.</p>
        }
    </div>
</div>

@if (selectedMember is not null)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Reservations for @selectedMember.FirstName @selectedMember.LastName (@selectedMember.MemberNumber)</strong>
            <a href="@($"/teetimes?date={DateOnly.FromDateTime(DateTime.Today):yyyy-MM-dd}")"
               class="btn btn-sm btn-primary">
                Book on Behalf
            </a>
        </div>
        <div class="card-body">
            @if (isLoadingReservations)
            {
                <div class="text-center my-3">
                    <div class="spinner-border spinner-border-sm" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (memberReservations is not null && memberReservations.Count > 0)
            {
                <QuickGrid Items="@memberReservations.AsQueryable()" Class="table table-striped"
                           RowClass="@(r => r.IsCancelled ? "table-secondary" : "")">
                    <TemplateColumn Title="Date" SortBy="@(GridSort<Reservation>.ByAscending(r => r.SlotDate))">
                        @context.SlotDate.ToString("MMM d, yyyy")
                    </TemplateColumn>
                    <TemplateColumn Title="Time" SortBy="@(GridSort<Reservation>.ByAscending(r => r.SlotTime))">
                        @context.SlotTime.ToString("h:mm tt")
                    </TemplateColumn>
                    <TemplateColumn Title="Players">
                        @(context.PlayerMemberAccountIds.Count + 1)
                    </TemplateColumn>
                    <TemplateColumn Title="Status">
                        @if (context.IsCancelled)
                        {
                            <span class="badge bg-secondary">Cancelled</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </TemplateColumn>
                    <TemplateColumn Title="Actions">
                        <a href="@($"/teetimes/reservation/{context.ReservationId}")"
                           class="btn btn-sm btn-outline-primary me-1">
                            View/Edit
                        </a>
                        @if (!context.IsCancelled && context.SlotDate >= DateOnly.FromDateTime(DateTime.Today))
                        {
                            @if (cancelConfirmId == context.ReservationId)
                            {
                                <button class="btn btn-sm btn-danger me-1"
                                        @onclick="() => ConfirmCancel(context.ReservationId)">
                                    Confirm
                                </button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => cancelConfirmId = null">
                                    No
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => cancelConfirmId = context.ReservationId">
                                    Cancel
                                </button>
                            }
                        }
                    </TemplateColumn>
                </QuickGrid>
            }
            else
            {
                <p class="text-muted">No reservations found for this member.</p>
            }
        </div>
    </div>
}

@code {
    private string searchTerm = string.Empty;
    private bool isSearching;
    private bool isLoadingReservations;
    private string? errorMessage;
    private string? successMessage;
    private Guid? cancelConfirmId;

    private List<MemberAccount<Guid>>? searchResults;
    private MemberAccount<Guid>? selectedMember;
    private List<Reservation>? memberReservations;

    private async Task SearchMembers()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            errorMessage = "Please enter a search term.";
            return;
        }

        isSearching = true;
        errorMessage = null;
        selectedMember = null;
        memberReservations = null;

        try
        {
            var pattern = $"%{searchTerm.Trim()}%";
            searchResults = await DbContext.MemberAccounts
                .Where(m => EF.Functions.Like(m.FirstName, pattern)
                         || EF.Functions.Like(m.LastName, pattern)
                         || EF.Functions.Like(m.MemberNumber, pattern))
                .OrderBy(m => m.LastName)
                .ThenBy(m => m.FirstName)
                .Take(50)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Member search failed for term '{SearchTerm}'", searchTerm);
            errorMessage = "An unexpected error occurred during the search. Please try again later.";
        }
        finally
        {
            isSearching = false;
        }
    }

    private async Task SelectMember(MemberAccount<Guid> member)
    {
        selectedMember = member;
        cancelConfirmId = null;
        isLoadingReservations = true;
        errorMessage = null;

        try
        {
            memberReservations = (await BookingService.GetMemberReservationsAsync(member.MemberAccountId))
                .OrderBy(r => r.SlotDate).ThenBy(r => r.SlotTime)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load reservations for member {MemberId}", member.MemberAccountId);
            errorMessage = "An unexpected error occurred while loading reservations. Please try again later.";
        }
        finally
        {
            isLoadingReservations = false;
        }
    }

    private async Task ConfirmCancel(Guid reservationId)
    {
        errorMessage = null;
        successMessage = null;
        cancelConfirmId = null;

        try
        {
            var result = await BookingService.CancelReservationAsync(reservationId);

            if (result)
            {
                successMessage = "Reservation cancelled successfully.";
                if (selectedMember is not null)
                {
                    await SelectMember(selectedMember);
                }
            }
            else
            {
                errorMessage = "Unable to cancel reservation. It may have already been cancelled.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to cancel reservation {ReservationId}", reservationId);
            errorMessage = "An unexpected error occurred while cancelling the reservation. Please try again later.";
        }
    }
}
