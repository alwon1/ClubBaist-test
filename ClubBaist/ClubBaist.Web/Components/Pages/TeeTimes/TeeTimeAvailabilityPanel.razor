@using ClubBaist.Domain
@using ClubBaist.Services
@using Microsoft.AspNetCore.Components.QuickGrid
@implements IDisposable

@inject TeeTimeBookingService<Guid> BookingService
@inject ISeasonService SeasonService
@inject AvailabilityUpdateService AvailabilityUpdates
@inject ILogger<TeeTimeAvailabilityPanel> Logger

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="card mb-4">
    <div class="card-body">
        <div class="row align-items-end">
            <div class="col-auto">
                <div class="form-floating mb-3">
                    <input type="date" class="form-control" id="@($"dateInput-{_id}")"
                           value="@selectedDate.ToString("yyyy-MM-dd")"
                           @onchange="OnDateChanged" />
                    <label for="@($"dateInput-{_id}")">Select Date</label>
                </div>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary mb-3" @onclick="RefreshCurrentView" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Refresh
                </button>
            </div>
            <div class="col-auto d-none d-lg-block mb-3">
                <div class="btn-group" role="group" aria-label="View mode">
                    <button type="button"
                            class="btn btn-outline-secondary @(viewMode == ViewMode.Day ? "active" : "")"
                            @onclick='() => SetViewMode(ViewMode.Day)'>
                        Day
                    </button>
                    <button type="button"
                            class="btn btn-outline-secondary @(viewMode == ViewMode.Week ? "active" : "")"
                            @onclick='() => SetViewMode(ViewMode.Week)'>
                        Week
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!isLoading && (slots is not null || weeklySlots is not null))
{
    <div class="mb-2 d-flex gap-3 align-items-center small text-muted flex-wrap">
        <span><span class="badge bg-primary">&nbsp;</span> Booking member</span>
        <span><span class="badge bg-secondary">&nbsp;</span> Additional player</span>
        <span class="border rounded px-1 empty-slot-bookable" style="font-size:0.8rem;">+</span> Click to book
        <span class="rounded px-1" style="background:rgba(25,135,84,0.10);font-size:0.8rem;">&#9632;</span> Available
        <span class="rounded px-1" style="background:rgba(255,193,7,0.14);font-size:0.8rem;">&#9632;</span> Not available at this time
        <span class="rounded px-1" style="background:rgba(220,53,69,0.10);font-size:0.8rem;">&#9632;</span> Full
        @if (!IsAdmin)
        {
            <span class="ms-2"><span class="reservation-editable-sample border rounded px-1" style="border: 2px solid #0d6efd; cursor:pointer">✎</span> Click to edit your reservation</span>
        }
    </div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (viewMode == ViewMode.Week && weeklySlots is not null)
{
    <div class="mb-3 d-flex align-items-center gap-2">
        <button class="btn btn-outline-secondary btn-sm" @onclick="GoToPreviousWeek">&lsaquo; Prev</button>
        <span class="fw-semibold small">
            @weekDates[0].ToString("MMM d") &ndash; @weekDates[6].ToString("MMM d, yyyy")
        </span>
        <button class="btn btn-outline-secondary btn-sm" @onclick="GoToNextWeek">Next &rsaquo;</button>
    </div>

    <div class="weekly-container">
        <QuickGrid Items="@weeklyGridRows.AsQueryable()" Class="table weekly-table">

            <TemplateColumn Title="" Class="weekly-time-col">
                <span class="weekly-time-label">@context.Time.ToString("h:mm tt")</span>
            </TemplateColumn>

            @foreach (var date in weekDates)
            {
                var d = date;
                var isToday = d == selectedDate;
                <TemplateColumn @key="d" Class="@($"weekly-slot-cell{(isToday ? " weekly-today-col" : "")}")">
                    <HeaderTemplate>
                        <div class="@(isToday ? "weekly-today-header" : "")">
                            <div class="fw-bold">@d.ToString("ddd")</div>
                            <div class="fw-normal small">@d.ToString("MMM d")</div>
                        </div>
                    </HeaderTemplate>
                    <ChildContent>
                        @{
                            var slot = context.Slots.GetValueOrDefault(d);
                            var cellBg = slot is null ? "weekly-no-data" : UiHelpers.GetSlotStatusClass(slot.RemainingCapacity, slot.UserCanBook);
                            var emptyCount = slot is null ? 0 :
                                BookingConstants.MaxPlayersPerSlot - slot.Reservations.Sum(r => 1 + r.Players.Count);
                        }
                        <div class="weekly-cell-inner @cellBg">
                            @if (slot is not null)
                            {
                                @foreach (var res in slot.Reservations)
                                {
                                    var canEdit = IsAdmin || res.BookingMember.MemberAccountId == CurrentMemberAccountId;
                                    if (canEdit)
                                    {
                                        <a href="/teetimes/reservation/@res.ReservationId" class="text-decoration-none d-block">
                                            <span class="badge bg-primary weekly-badge" title="@res.BookingMember.FirstName @res.BookingMember.LastName">
                                                @res.BookingMember.FirstName
                                            </span>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary weekly-badge" title="@res.BookingMember.FirstName @res.BookingMember.LastName">
                                            @res.BookingMember.FirstName
                                        </span>
                                    }
                                    @foreach (var player in res.Players)
                                    {
                                        <span class="badge bg-secondary weekly-badge" title="@player.FirstName @player.LastName">
                                            @player.FirstName
                                        </span>
                                    }
                                }
                                @for (var i = 0; i < emptyCount; i++)
                                {
                                    @if (slot.RemainingCapacity > 0 && slot.UserCanBook)
                                    {
                                        var weekBookUrl = BookForMemberId.HasValue
                                            ? $"/teetimes/book?date={d:yyyy-MM-dd}&time={slot.Time:HH:mm}&bookFor={BookForMemberId}"
                                            : $"/teetimes/book?date={d:yyyy-MM-dd}&time={slot.Time:HH:mm}";
                                        <a href="@weekBookUrl" class="weekly-empty-spot weekly-empty-spot-bookable">+</a>
                                    }
                                    else if (slot.RemainingCapacity > 0)
                                    {
                                        <div class="weekly-empty-spot weekly-empty-spot-restricted" title="Not available at this time for your membership">—</div>
                                    }
                                    else
                                    {
                                        <div class="weekly-empty-spot">—</div>
                                    }
                                }
                            }
                        </div>
                    </ChildContent>
                </TemplateColumn>
            }

        </QuickGrid>
    </div>
}
else if (viewMode == ViewMode.Day && slots is not null)
{
    <div class="tee-time-grid">
        @foreach (var slot in slots)
        {
            var totalBooked = slot.Reservations.Sum(r => 1 + r.Players.Count);
            var emptyCount = BookingConstants.MaxPlayersPerSlot - totalBooked;
            var rowBg = UiHelpers.GetSlotStatusClass(slot.RemainingCapacity, slot.UserCanBook);

            <div class="slot-row @rowBg d-flex align-items-center border-bottom py-2 gap-3">
                <div class="slot-time fw-bold text-nowrap">
                    @slot.Time.ToString("h:mm tt")
                </div>

                <div class="slot-members flex-grow-1">
                    <div class="row g-1 flex-nowrap m-0">
                        @foreach (var res in slot.Reservations)
                        {
                            var memberCount = 1 + res.Players.Count;
                            var outerCol = $"col-{memberCount * 3}";
                            var innerCol = $"col-{12 / memberCount}";
                            var canEdit = IsAdmin || res.BookingMember.MemberAccountId == CurrentMemberAccountId;

                            <div class="@outerCol px-1">
                                @if (canEdit)
                                {
                                    <a href="/teetimes/reservation/@res.ReservationId"
                                       class="d-block text-decoration-none reservation-box reservation-editable"
                                       title="Edit reservation">
                                        <div class="row g-1 m-0">
                                            <div class="@innerCol px-1">
                                                <span class="badge bg-primary w-100 member-badge" title="@res.BookingMember.FirstName @res.BookingMember.LastName">
                                                    @res.BookingMember.FirstName @res.BookingMember.LastName
                                                </span>
                                            </div>
                                            @foreach (var player in res.Players)
                                            {
                                                <div class="@innerCol px-1">
                                                    <span class="badge bg-secondary w-100 member-badge" title="@player.FirstName @player.LastName">
                                                        @player.FirstName @player.LastName
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                    </a>
                                }
                                else
                                {
                                    <div class="reservation-box">
                                        <div class="row g-1 m-0">
                                            <div class="@innerCol px-1">
                                                <span class="badge bg-primary w-100 member-badge" title="@res.BookingMember.FirstName @res.BookingMember.LastName">
                                                    @res.BookingMember.FirstName @res.BookingMember.LastName
                                                </span>
                                            </div>
                                            @foreach (var player in res.Players)
                                            {
                                                <div class="@innerCol px-1">
                                                    <span class="badge bg-secondary w-100 member-badge" title="@player.FirstName @player.LastName">
                                                        @player.FirstName @player.LastName
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @for (var i = 0; i < emptyCount; i++)
                        {
                            <div class="col-3 px-1">
                                @if (slot.RemainingCapacity > 0 && slot.UserCanBook)
                                {
                                    var bookUrl = BookForMemberId.HasValue
                                        ? $"/teetimes/book?date={selectedDate:yyyy-MM-dd}&time={slot.Time:HH:mm}&bookFor={BookForMemberId}"
                                        : $"/teetimes/book?date={selectedDate:yyyy-MM-dd}&time={slot.Time:HH:mm}";
                                    <a href="@bookUrl" class="empty-slot empty-slot-bookable text-center">+</a>
                                }
                                else if (slot.RemainingCapacity > 0)
                                {
                                    <div class="empty-slot empty-slot-restricted text-center" title="Not available at this time for your membership">—</div>
                                }
                                else
                                {
                                    <div class="empty-slot text-muted text-center">—</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    /* === Day View Styles === */
    .tee-time-grid {
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        overflow: hidden;
    }

    .slot-row {
        padding-left: 0.75rem;
        padding-right: 0.75rem;
    }

    .slot-row-open { background-color: rgba(25, 135, 84, 0.10); }
    .slot-row-restricted { background-color: rgba(255, 193, 7, 0.14); }
    .slot-row-full { background-color: rgba(220, 53, 69, 0.10); }

    .slot-time {
        width: 5.5rem;
        flex-shrink: 0;
    }

    .reservation-box {
        border: 2px solid #adb5bd;
        border-radius: 0.375rem;
        padding: 0.2rem;
        background: #fff;
    }

    .reservation-editable {
        border-color: #0d6efd;
        color: inherit;
    }

    .reservation-editable:hover {
        background: #e7f1ff;
        border-color: #0a58ca;
    }

    .empty-slot {
        border: 2px dashed #dee2e6;
        border-radius: 0.375rem;
        padding: 0.2rem;
        min-height: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fafafa;
    }

    .empty-slot-bookable {
        border-color: #0d6efd;
        color: #0d6efd;
        text-decoration: none;
        cursor: pointer;
    }

    .empty-slot-bookable:hover {
        background: #e7f1ff;
        border-color: #0a58ca;
        color: #0a58ca;
    }

    .empty-slot-restricted {
        border-color: #ffc107;
        color: #997404;
        cursor: not-allowed;
    }

    .member-badge {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: block !important;
        font-size: 0.75rem;
    }

    /* === Weekly View Styles === */
    .weekly-container {
        overflow: auto;
        max-height: 75vh;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
    }

    .weekly-table {
        min-width: 700px;
    }

    .weekly-table thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #f8f9fa;
        border-bottom: 2px solid #dee2e6 !important;
        text-align: center;
        font-size: 0.8rem;
        white-space: nowrap;
    }

    .weekly-table thead th:first-child {
        left: 0;
        z-index: 3;
        border-right: 2px solid #dee2e6;
        min-width: 5.5rem;
    }

    td.weekly-time-col {
        position: sticky;
        left: 0;
        z-index: 1;
        background: #f8f9fa;
        border-right: 2px solid #dee2e6;
        min-width: 5.5rem;
        vertical-align: middle;
        padding: 0 !important;
    }

    .weekly-time-label {
        display: block;
        padding: 0.3rem 0.4rem;
        font-size: 0.7rem;
        font-weight: 600;
        white-space: nowrap;
        text-align: right;
    }

    td.weekly-slot-cell {
        min-width: 130px;
        vertical-align: top;
        padding: 0 !important;
    }

    .weekly-cell-inner {
        padding: 0.2rem;
        min-height: 2.5rem;
    }

    .weekly-badge {
        display: block;
        font-size: 0.6rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 100%;
        margin-bottom: 1px;
        line-height: 1.3;
    }

    .weekly-empty-spot {
        font-size: 0.6rem;
        color: #adb5bd;
        text-align: center;
        border: 1px dashed #dee2e6;
        border-radius: 0.2rem;
        margin-bottom: 1px;
        line-height: 1.4;
        background: #fafafa;
        display: block;
    }

    .weekly-empty-spot-bookable {
        border-color: #0d6efd;
        color: #0d6efd;
        text-decoration: none;
        cursor: pointer;
    }

    .weekly-empty-spot-bookable:hover {
        background: #e7f1ff;
        color: #0a58ca;
    }

    .weekly-empty-spot-restricted {
        border-color: #ffc107;
        color: #997404;
        cursor: not-allowed;
    }

    .weekly-today-header {
        color: #0d6efd;
        border-bottom: 3px solid #0d6efd;
        padding-bottom: 2px;
    }

    .weekly-today-col {
        border-left: 2px solid #0d6efd !important;
    }

    .weekly-no-data {
        background: #f8f9fa;
    }
</style>

@code {
    private enum ViewMode { Day, Week }

    private record WeeklySlotRow(
        TimeOnly Time,
        IReadOnlyDictionary<DateOnly, BookedSlotWithMembers?> Slots);

    /// <summary>Whose time restrictions to apply for colour coding.</summary>
    [Parameter] public MembershipCategory? MemberCategory { get; set; }

    /// <summary>Whether the viewer is an admin (all reservations editable).</summary>
    [Parameter] public bool IsAdmin { get; set; }

    /// <summary>The logged-in member's account ID (used to identify editable reservations for non-admins).</summary>
    [Parameter] public Guid CurrentMemberAccountId { get; set; }

    /// <summary>When set, booking links include bookFor=&lt;id&gt; so CreateReservation pre-selects this member.</summary>
    [Parameter] public Guid? BookForMemberId { get; set; }

    // Unique suffix to avoid duplicate HTML id clashes when multiple panels are on the same page.
    private readonly string _id = Guid.NewGuid().ToString("N")[..8];

    private ViewMode viewMode = ViewMode.Day;
    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Today);
    private IReadOnlyList<BookedSlotWithMembers>? slots;
    private Dictionary<DateOnly, IReadOnlyList<BookedSlotWithMembers>>? weeklySlots;
    private List<DateOnly> weekDates = new();
    private List<WeeklySlotRow> weeklyGridRows = [];
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        selectedDate = SeasonService.GetNextAvailableDate(DateOnly.FromDateTime(DateTime.Today))
            ?? DateOnly.FromDateTime(DateTime.Today);

        await LoadAvailability();

        AvailabilityUpdates.AvailabilityChanged += OnAvailabilityChanged;
    }

    private void OnAvailabilityChanged(DateOnly date)
    {
        var relevant = viewMode == ViewMode.Week
            ? weekDates.Count > 0 && date >= weekDates[0] && date <= weekDates[6]
            : date == selectedDate;

        if (!relevant) return;

        _ = InvokeAsync(async () =>
        {
            try
            {
                if (viewMode == ViewMode.Week && weeklySlots is not null)
                    await RefreshWeekDay(date);
                else
                    await LoadAvailability();
            }
            catch (Exception ex) { Logger.LogError(ex, "Live refresh failed for {Date}", date); }
        });
    }

    public void Dispose()
    {
        AvailabilityUpdates.AvailabilityChanged -= OnAvailabilityChanged;
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
        {
            selectedDate = date;
            if (viewMode == ViewMode.Week)
            {
                SetWeekDates();
                await LoadWeeklyAvailability();
            }
            else
            {
                await LoadAvailability();
            }
        }
    }

    private async Task RefreshCurrentView()
    {
        if (viewMode == ViewMode.Week)
            await LoadWeeklyAvailability();
        else
            await LoadAvailability();
    }

    private async Task SetViewMode(ViewMode mode)
    {
        if (viewMode == mode) return;
        viewMode = mode;
        if (mode == ViewMode.Week)
        {
            SetWeekDates();
            await LoadWeeklyAvailability();
        }
        else
        {
            await LoadAvailability();
        }
    }

    private void SetWeekDates()
    {
        var dayOfWeek = (int)selectedDate.DayOfWeek;
        var daysFromMonday = dayOfWeek == 0 ? 6 : dayOfWeek - 1;
        var monday = selectedDate.AddDays(-daysFromMonday);
        weekDates = Enumerable.Range(0, 7).Select(i => monday.AddDays(i)).ToList();
    }

    private async Task GoToPreviousWeek()
    {
        selectedDate = weekDates[0].AddDays(-7);
        SetWeekDates();
        await LoadWeeklyAvailability();
    }

    private async Task GoToNextWeek()
    {
        selectedDate = weekDates[0].AddDays(7);
        SetWeekDates();
        await LoadWeeklyAvailability();
    }

    private async Task LoadWeeklyAvailability()
    {
        isLoading = true;
        errorMessage = null;
        weeklySlots = null;
        weeklyGridRows = [];

        try
        {
            var result = new Dictionary<DateOnly, IReadOnlyList<BookedSlotWithMembers>>();
            foreach (var date in weekDates)
            {
                result[date] = await BookingService.GetBookedSlotsWithMembersAsync(date, MemberCategory);
            }
            weeklySlots = result;
            RebuildWeeklyGridRows();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load weekly availability");
            errorMessage = "An unexpected error occurred while loading availability. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void RebuildWeeklyGridRows()
    {
        if (weeklySlots is null) { weeklyGridRows = []; return; }
        var times = weeklySlots.Values.FirstOrDefault(s => s.Count > 0)?.Select(s => s.Time) ?? [];
        weeklyGridRows = times.Select(time => new WeeklySlotRow(
            time,
            weekDates.ToDictionary(
                d => d,
                d => weeklySlots.GetValueOrDefault(d)?.FirstOrDefault(s => s.Time == time))
        )).ToList();
    }

    private async Task RefreshWeekDay(DateOnly date)
    {
        var daySlots = await BookingService.GetBookedSlotsWithMembersAsync(date, MemberCategory);
        weeklySlots![date] = daySlots;
        RebuildWeeklyGridRows();
        StateHasChanged();
    }

    private async Task LoadAvailability()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            slots = await BookingService.GetBookedSlotsWithMembersAsync(selectedDate, MemberCategory);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load availability");
            errorMessage = "An unexpected error occurred while loading availability. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
