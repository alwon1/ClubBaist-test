@page "/teetimes"
@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.AdminOrMember)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.QuickGrid
@using ClubBaist.Domain
@using ClubBaist.Services

@inject TeeTimeBookingService<Guid> BookingService
@inject ILogger<Availability> Logger

<PageTitle>Tee Time Availability - Club Baist</PageTitle>

<h3 class="mb-4">Tee Time Availability</h3>

<div class="card mb-4">
    <div class="card-body">
        <div class="row align-items-end">
            <div class="col-auto">
                <div class="form-floating mb-3">
                    <input type="date" class="form-control" id="dateInput"
                           value="@selectedDate.ToString("yyyy-MM-dd")"
                           @onchange="OnDateChanged" />
                    <label for="dateInput">Select Date</label>
                </div>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary mb-3" @onclick="LoadAvailability" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Refresh
                </button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (slots is not null)
{
    <QuickGrid Items="@slots.AsQueryable()" Class="table table-striped" RowClass="@GetRowClass">
        <TemplateColumn Title="Time" SortBy="@(GridSort<SlotAvailability>.ByAscending(s => s.Time))">
            @context.Time.ToString("h:mm tt")
        </TemplateColumn>
        <TemplateColumn Title="Available Spots">
            @context.RemainingCapacity / @BookingConstants.MaxPlayersPerSlot
        </TemplateColumn>
        <TemplateColumn Title="Action">
            @if (context.RemainingCapacity > 0)
            {
                <a class="btn btn-sm btn-primary"
                   href="@($"/teetimes/book?date={selectedDate:yyyy-MM-dd}&time={context.Time:HH:mm}")">
                    Book
                </a>
            }
            else
            {
                <button class="btn btn-sm btn-secondary" disabled>Full</button>
            }
        </TemplateColumn>
    </QuickGrid>
}

@code {
    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Today);
    private IReadOnlyList<SlotAvailability>? slots;
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailability();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
        {
            selectedDate = date;
            await LoadAvailability();
        }
    }

    private async Task LoadAvailability()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await BookingService.GetAvailabilityAsync(selectedDate, selectedDate);
            slots = result.FirstOrDefault()?.Slots;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load availability");
            errorMessage = "An unexpected error occurred while loading availability. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetRowClass(SlotAvailability slot) => slot.RemainingCapacity switch
    {
        BookingConstants.MaxPlayersPerSlot => "table-success",
        > 0 => "table-warning",
        _ => "table-danger"
    };
}
