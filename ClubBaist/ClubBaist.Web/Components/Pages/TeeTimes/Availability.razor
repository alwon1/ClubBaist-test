@page "/teetimes"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = AppRoles.AdminOrMember)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain
@using ClubBaist.Services

@inject TeeTimeBookingService<Guid> BookingService
@inject ISeasonService SeasonService
@inject IApplicationDbContext<Guid> DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<Availability> Logger

<PageTitle>Tee Time Availability - Club Baist</PageTitle>

<h3 class="mb-4">Tee Time Availability</h3>

<div class="card mb-4">
    <div class="card-body">
        <div class="row align-items-end">
            <div class="col-auto">
                <div class="form-floating mb-3">
                    <input type="date" class="form-control" id="dateInput"
                           value="@selectedDate.ToString("yyyy-MM-dd")"
                           @onchange="OnDateChanged" />
                    <label for="dateInput">Select Date</label>
                </div>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary mb-3" @onclick="RefreshCurrentView" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Refresh
                </button>
            </div>
            <div class="col-auto d-none d-lg-block mb-3">
                <div class="btn-group" role="group" aria-label="View mode">
                    <button type="button"
                            class="btn btn-outline-secondary @(viewMode == ViewMode.Day ? "active" : "")"
                            @onclick='() => SetViewMode(ViewMode.Day)'>
                        Day
                    </button>
                    <button type="button"
                            class="btn btn-outline-secondary @(viewMode == ViewMode.Week ? "active" : "")"
                            @onclick='() => SetViewMode(ViewMode.Week)'>
                        Week
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (viewMode == ViewMode.Week && weeklySlots is not null)
{
    <div class="mb-3 d-flex align-items-center gap-2">
        <button class="btn btn-outline-secondary btn-sm" @onclick="GoToPreviousWeek">&lsaquo; Prev</button>
        <span class="fw-semibold small">
            @weekDates[0].ToString("MMM d") &ndash; @weekDates[6].ToString("MMM d, yyyy")
        </span>
        <button class="btn btn-outline-secondary btn-sm" @onclick="GoToNextWeek">Next &rsaquo;</button>
    </div>

    <div class="mb-2 d-flex gap-3 align-items-center small text-muted flex-wrap">
        <span><span class="badge bg-primary">&nbsp;</span> Booking member</span>
        <span><span class="badge bg-secondary">&nbsp;</span> Additional player</span>
        <span class="border rounded px-1" style="border-style: dashed !important;">—</span> Available spot
        @if (!isAdmin)
        {
            <span class="ms-2"><span class="border rounded px-1" style="border: 2px solid #0d6efd; cursor:pointer">✎</span> Click to edit your reservation</span>
        }
    </div>

    <div class="weekly-container">
        <table class="weekly-table">
            <thead>
                <tr>
                    <th class="weekly-time-th"></th>
                    @foreach (var date in weekDates)
                    {
                        <th class="weekly-day-th @(date == selectedDate ? "weekly-today-header" : "")">
                            <div class="fw-bold">@date.ToString("ddd")</div>
                            <div class="fw-normal">@date.ToString("MMM d")</div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var time in allWeekTimes)
                {
                    <tr>
                        <td class="weekly-time-td">@time.ToString("h:mm tt")</td>
                        @foreach (var date in weekDates)
                        {
                            var daySlots = weeklySlots.GetValueOrDefault(date);
                            var slot = daySlots?.FirstOrDefault(s => s.Time == time);
                            if (slot is null)
                            {
                                <td class="weekly-slot-cell weekly-no-data @(date == selectedDate ? "weekly-today-col" : "")"></td>
                            }
                            else
                            {
                                var totalBooked = slot.Reservations.Sum(r => 1 + r.Players.Count);
                                var emptyCount = BookingConstants.MaxPlayersPerSlot - totalBooked;
                                var cellBg = slot.RemainingCapacity switch
                                {
                                    BookingConstants.MaxPlayersPerSlot => "slot-row-open",
                                    > 0 => "slot-row-partial",
                                    _ => "slot-row-full"
                                };
                                var bookDate = date;
                                var bookTime = slot.Time;
                                <td class="weekly-slot-cell @cellBg @(date == selectedDate ? "weekly-today-col" : "")">
                                    @foreach (var res in slot.Reservations)
                                    {
                                        var canEdit = isAdmin || res.BookingMember.MemberAccountId == currentMemberAccountId;
                                        if (canEdit)
                                        {
                                            <a href="/teetimes/reservation/@res.ReservationId" class="text-decoration-none d-block">
                                                <span class="badge bg-primary weekly-badge" title="@res.BookingMember.FirstName @res.BookingMember.LastName">
                                                    @res.BookingMember.FirstName
                                                </span>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary weekly-badge" title="@res.BookingMember.FirstName @res.BookingMember.LastName">
                                                @res.BookingMember.FirstName
                                            </span>
                                        }
                                        @foreach (var player in res.Players)
                                        {
                                            <span class="badge bg-secondary weekly-badge" title="@player.FirstName @player.LastName">
                                                @player.FirstName
                                            </span>
                                        }
                                    }
                                    @for (var i = 0; i < emptyCount; i++)
                                    {
                                        <div class="weekly-empty-spot">—</div>
                                    }
                                    @if (slot.RemainingCapacity > 0)
                                    {
                                        <div class="weekly-book-link">
                                            <a href="@($"/teetimes/book?date={bookDate:yyyy-MM-dd}&time={bookTime:HH:mm}")"
                                               class="btn btn-primary btn-sm weekly-book-btn">Book</a>
                                        </div>
                                    }
                                </td>
                            }
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (viewMode == ViewMode.Day && slots is not null)
{
    <div class="mb-2 d-flex gap-3 align-items-center small text-muted">
        <span><span class="badge bg-primary">&nbsp;</span> Booking member</span>
        <span><span class="badge bg-secondary">&nbsp;</span> Additional player</span>
        <span class="border rounded px-1" style="border-style: dashed !important;">—</span> Available spot
        @if (!isAdmin)
        {
            <span class="ms-2"><span class="reservation-editable-sample border rounded px-1" style="border: 2px solid #0d6efd; cursor:pointer">✎</span> Click to edit your reservation</span>
        }
    </div>

    <div class="tee-time-grid">
        @foreach (var slot in slots)
        {
            var totalBooked = slot.Reservations.Sum(r => 1 + r.Players.Count);
            var emptyCount = BookingConstants.MaxPlayersPerSlot - totalBooked;
            var rowBg = slot.RemainingCapacity switch
            {
                BookingConstants.MaxPlayersPerSlot => "slot-row-open",
                > 0 => "slot-row-partial",
                _ => "slot-row-full"
            };

            <div class="slot-row @rowBg d-flex align-items-center border-bottom py-2 gap-3">
                <div class="slot-time fw-bold text-nowrap">
                    @slot.Time.ToString("h:mm tt")
                </div>

                <div class="slot-members flex-grow-1">
                    <div class="row g-1 flex-nowrap m-0">
                        @foreach (var res in slot.Reservations)
                        {
                            var memberCount = 1 + res.Players.Count;
                            var outerCol = $"col-{memberCount * 3}";
                            var innerCol = $"col-{12 / memberCount}";
                            var canEdit = isAdmin || res.BookingMember.MemberAccountId == currentMemberAccountId;

                            <div class="@outerCol px-1">
                                @if (canEdit)
                                {
                                    <a href="/teetimes/reservation/@res.ReservationId"
                                       class="d-block text-decoration-none reservation-box reservation-editable"
                                       title="Edit reservation">
                                        <div class="row g-1 m-0">
                                            <div class="@innerCol px-1">
                                                <span class="badge bg-primary w-100 member-badge" title="@res.BookingMember.FirstName @res.BookingMember.LastName">
                                                    @res.BookingMember.FirstName @res.BookingMember.LastName
                                                </span>
                                            </div>
                                            @foreach (var player in res.Players)
                                            {
                                                <div class="@innerCol px-1">
                                                    <span class="badge bg-secondary w-100 member-badge" title="@player.FirstName @player.LastName">
                                                        @player.FirstName @player.LastName
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                    </a>
                                }
                                else
                                {
                                    <div class="reservation-box">
                                        <div class="row g-1 m-0">
                                            <div class="@innerCol px-1">
                                                <span class="badge bg-primary w-100 member-badge" title="@res.BookingMember.FirstName @res.BookingMember.LastName">
                                                    @res.BookingMember.FirstName @res.BookingMember.LastName
                                                </span>
                                            </div>
                                            @foreach (var player in res.Players)
                                            {
                                                <div class="@innerCol px-1">
                                                    <span class="badge bg-secondary w-100 member-badge" title="@player.FirstName @player.LastName">
                                                        @player.FirstName @player.LastName
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @for (var i = 0; i < emptyCount; i++)
                        {
                            <div class="col-3 px-1">
                                <div class="empty-slot text-muted text-center">—</div>
                            </div>
                        }
                    </div>
                </div>

                <div class="slot-action">
                    @if (slot.RemainingCapacity > 0)
                    {
                        <a class="btn btn-sm btn-primary"
                           href="@($"/teetimes/book?date={selectedDate:yyyy-MM-dd}&time={slot.Time:HH:mm}")">
                            Book
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-secondary" disabled>Full</button>
                    }
                </div>
            </div>
        }
    </div>
}

<style>
    /* === Day View Styles === */
    .tee-time-grid {
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        overflow: hidden;
    }

    .slot-row {
        padding-left: 0.75rem;
        padding-right: 0.75rem;
    }

    .slot-row-open { background-color: rgba(25, 135, 84, 0.06); }
    .slot-row-partial { background-color: rgba(255, 193, 7, 0.08); }
    .slot-row-full { background-color: rgba(220, 53, 69, 0.06); }

    .slot-time {
        width: 5.5rem;
        flex-shrink: 0;
    }

    .slot-action {
        width: 4.5rem;
        flex-shrink: 0;
        text-align: right;
    }

    .reservation-box {
        border: 2px solid #adb5bd;
        border-radius: 0.375rem;
        padding: 0.2rem;
        background: #fff;
    }

    .reservation-editable {
        border-color: #0d6efd;
        color: inherit;
    }

    .reservation-editable:hover {
        background: #e7f1ff;
        border-color: #0a58ca;
    }

    .empty-slot {
        border: 2px dashed #dee2e6;
        border-radius: 0.375rem;
        padding: 0.2rem;
        min-height: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fafafa;
    }

    .member-badge {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: block !important;
        font-size: 0.75rem;
    }

    /* === Weekly View Styles === */
    .weekly-container {
        overflow: auto;
        max-height: 75vh;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
    }

    .weekly-table {
        border-collapse: collapse;
        width: 100%;
        min-width: 700px;
    }

    /* Sticky header row */
    .weekly-table thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
        border-left: 1px solid #dee2e6;
        padding: 0.4rem 0.3rem;
        text-align: center;
        font-size: 0.8rem;
        white-space: nowrap;
    }

    /* Sticky + leftmost corner cell */
    .weekly-time-th {
        position: sticky;
        left: 0;
        z-index: 3;
        background: #f8f9fa;
        min-width: 5.5rem;
        border-left: none;
        border-right: 2px solid #dee2e6;
    }

    /* Sticky time column cells */
    .weekly-time-td {
        position: sticky;
        left: 0;
        z-index: 1;
        background: #f8f9fa;
        font-size: 0.7rem;
        font-weight: 600;
        white-space: nowrap;
        padding: 0.3rem 0.4rem;
        text-align: right;
        vertical-align: middle;
        border-bottom: 1px solid #dee2e6;
        border-right: 2px solid #dee2e6;
        min-width: 5.5rem;
    }

    /* Day column headers */
    .weekly-day-th {
        min-width: 130px;
    }

    /* Slot cells */
    .weekly-slot-cell {
        border-left: 1px solid #dee2e6;
        border-bottom: 1px solid #dee2e6;
        padding: 0.2rem;
        vertical-align: top;
        font-size: 0.7rem;
        min-width: 130px;
    }

    .weekly-badge {
        display: block;
        font-size: 0.6rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 100%;
        margin-bottom: 1px;
        line-height: 1.3;
    }

    .weekly-empty-spot {
        font-size: 0.6rem;
        color: #adb5bd;
        text-align: center;
        border: 1px dashed #dee2e6;
        border-radius: 0.2rem;
        margin-bottom: 1px;
        line-height: 1.4;
        background: #fafafa;
    }

    .weekly-book-link {
        text-align: right;
        margin-top: 2px;
    }

    .weekly-book-btn {
        font-size: 0.55rem;
        padding: 0.05rem 0.25rem;
        line-height: 1.4;
    }

    /* Today column highlight */
    .weekly-today-header {
        color: #0d6efd;
        border-bottom: 3px solid #0d6efd !important;
    }

    .weekly-today-col {
        border-left: 2px solid #0d6efd !important;
    }

    .weekly-no-data {
        background: #f8f9fa;
    }
</style>

@code {
    private enum ViewMode { Day, Week }

    private ViewMode viewMode = ViewMode.Day;
    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Today);
    private IReadOnlyList<BookedSlotWithMembers>? slots;
    private Dictionary<DateOnly, IReadOnlyList<BookedSlotWithMembers>>? weeklySlots;
    private List<DateOnly> weekDates = new();
    private List<TimeOnly> allWeekTimes = new();
    private bool isLoading;
    private string? errorMessage;
    private bool isAdmin;
    private Guid currentMemberAccountId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);
        isAdmin = user.IsInRole(AppRoles.Admin);

        if (!isAdmin)
        {
            var member = await DbContext.MemberAccounts
                .FirstOrDefaultAsync(m => m.ApplicationUserId == userId);
            currentMemberAccountId = member?.MemberAccountId ?? Guid.Empty;
        }

        selectedDate = SeasonService.GetNextAvailableDate(DateOnly.FromDateTime(DateTime.Today))
            ?? DateOnly.FromDateTime(DateTime.Today);

        await LoadAvailability();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
        {
            selectedDate = date;
            if (viewMode == ViewMode.Week)
            {
                SetWeekDates();
                await LoadWeeklyAvailability();
            }
            else
            {
                await LoadAvailability();
            }
        }
    }

    private async Task RefreshCurrentView()
    {
        if (viewMode == ViewMode.Week)
            await LoadWeeklyAvailability();
        else
            await LoadAvailability();
    }

    private async Task SetViewMode(ViewMode mode)
    {
        if (viewMode == mode) return;
        viewMode = mode;
        if (mode == ViewMode.Week)
        {
            SetWeekDates();
            await LoadWeeklyAvailability();
        }
        else
        {
            await LoadAvailability();
        }
    }

    private void SetWeekDates()
    {
        var dayOfWeek = (int)selectedDate.DayOfWeek;
        var daysFromMonday = dayOfWeek == 0 ? 6 : dayOfWeek - 1;
        var monday = selectedDate.AddDays(-daysFromMonday);
        weekDates = Enumerable.Range(0, 7).Select(i => monday.AddDays(i)).ToList();
    }

    private async Task GoToPreviousWeek()
    {
        selectedDate = weekDates[0].AddDays(-7);
        SetWeekDates();
        await LoadWeeklyAvailability();
    }

    private async Task GoToNextWeek()
    {
        selectedDate = weekDates[0].AddDays(7);
        SetWeekDates();
        await LoadWeeklyAvailability();
    }

    private async Task LoadWeeklyAvailability()
    {
        isLoading = true;
        errorMessage = null;
        weeklySlots = null;
        allWeekTimes = new();

        try
        {
            var result = new Dictionary<DateOnly, IReadOnlyList<BookedSlotWithMembers>>();
            foreach (var date in weekDates)
            {
                result[date] = await BookingService.GetBookedSlotsWithMembersAsync(date);
            }
            weeklySlots = result;
            allWeekTimes = weeklySlots.Values
                .FirstOrDefault(s => s.Count > 0)
                ?.Select(s => s.Time)
                .ToList() ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load weekly availability");
            errorMessage = "An unexpected error occurred while loading availability. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadAvailability()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            slots = await BookingService.GetBookedSlotsWithMembersAsync(selectedDate);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load availability");
            errorMessage = "An unexpected error occurred while loading availability. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
