@page "/teetimes"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = AppRoles.AdminOrMember)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore

@inject IAppDbContext2 DbContext
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Tee Time Availability - Club Baist</PageTitle>

<h3 class="mb-4">Tee Time Availability</h3>

@if (!isLoading)
{
    <TeeTimeAvailabilityPanel
        IsAdmin="isAdmin"
        CurrentMemberId="currentMemberId"
        BookForMemberId="null" />
}
else
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isAdmin;
    private int currentMemberId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);
        isAdmin = user.IsInRole(AppRoles.Admin);

        if (!isAdmin)
        {
            var member = await DbContext.MemberShips
                .FirstOrDefaultAsync(m => m.User.Id == userId);
            currentMemberId = member?.Id ?? 0;
        }

        isLoading = false;
    }
}

