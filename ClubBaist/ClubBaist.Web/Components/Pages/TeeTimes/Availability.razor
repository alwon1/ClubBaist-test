@page "/teetimes"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Member")]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using ClubBaist.Domain
@using ClubBaist.Services

@inject TeeTimeBookingService<Guid> BookingService

<PageTitle>Tee Time Availability - Club Baist</PageTitle>

<h3 class="mb-4">Tee Time Availability</h3>

<div class="card mb-4">
    <div class="card-body">
        <div class="row align-items-end">
            <div class="col-auto">
                <div class="form-floating mb-3">
                    <input type="date" class="form-control" id="dateInput"
                           value="@selectedDate.ToString("yyyy-MM-dd")"
                           @onchange="OnDateChanged" />
                    <label for="dateInput">Select Date</label>
                </div>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary mb-3" @onclick="LoadAvailability" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Refresh
                </button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (slots is not null)
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Available Spots</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in slots)
                {
                    var rowClass = slot.RemainingCapacity switch
                    {
                        4 => "table-success",
                        > 0 => "table-warning",
                        _ => "table-danger"
                    };
                    <tr class="@rowClass">
                        <td>@slot.Time.ToString("h:mm tt")</td>
                        <td>@slot.RemainingCapacity / 4</td>
                        <td>
                            @if (slot.RemainingCapacity > 0)
                            {
                                <a class="btn btn-sm btn-primary"
                                   href="@($"/teetimes/book?date={selectedDate:yyyy-MM-dd}&time={slot.Time:HH:mm}")">
                                    Book
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-secondary" disabled>Full</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Today);
    private IReadOnlyList<SlotAvailability>? slots;
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailability();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
        {
            selectedDate = date;
            await LoadAvailability();
        }
    }

    private async Task LoadAvailability()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await BookingService.GetAvailabilityAsync(selectedDate, selectedDate);
            slots = result.FirstOrDefault()?.Slots;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load availability: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
