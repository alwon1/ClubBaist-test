@page "/membership/apply"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using ClubBaist.Domain
@using ClubBaist.Services

@inject ApplicationManagementService<Guid> ApplicationService
@inject IApplicationDbContext<Guid> DbContext
@inject ILogger<Apply> Logger

<PageTitle>Apply for Membership</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">Apply for Membership</h2>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success" role="alert">
            @_successMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @_errorMessage
        </div>
    }

    @if (!_submitted)
    {
        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="applyForm">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" />

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Create Your Account</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="email" class="form-control" @bind-Value="_model.Email" placeholder="Email" autocomplete="username" />
                                <label for="email">Email Address</label>
                                <ValidationMessage For="() => _model.Email" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="password" type="password" class="form-control" @bind-Value="_model.Password" placeholder="Password" autocomplete="new-password" />
                                <label for="password">Password</label>
                                <ValidationMessage For="() => _model.Password" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="_model.ConfirmPassword" placeholder="Confirm Password" autocomplete="new-password" />
                                <label for="confirmPassword">Confirm Password</label>
                                <ValidationMessage For="() => _model.ConfirmPassword" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="firstName" class="form-control" @bind-Value="_model.FirstName" placeholder="First Name" />
                                <label for="firstName">First Name</label>
                                <ValidationMessage For="() => _model.FirstName" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="lastName" class="form-control" @bind-Value="_model.LastName" placeholder="Last Name" />
                                <label for="lastName">Last Name</label>
                                <ValidationMessage For="() => _model.LastName" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputDate id="dateOfBirth" class="form-control" @bind-Value="_model.DateOfBirth" placeholder="Date of Birth" />
                                <label for="dateOfBirth">Date of Birth</label>
                                <ValidationMessage For="() => _model.DateOfBirth" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="phone" class="form-control" @bind-Value="_model.Phone" placeholder="Phone" />
                                <label for="phone">Phone (e.g. (403) 555-1234)</label>
                                <ValidationMessage For="() => _model.Phone" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="alternatePhone" class="form-control" @bind-Value="_model.AlternatePhone" placeholder="Alternate Phone" />
                                <label for="alternatePhone">Alternate Phone (Optional)</label>
                                <ValidationMessage For="() => _model.AlternatePhone" />
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <InputText id="address" class="form-control" @bind-Value="_model.Address" placeholder="Address" />
                        <label for="address">Address</label>
                        <ValidationMessage For="() => _model.Address" />
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-floating mb-3">
                                <InputText id="postalCode" class="form-control" @bind-Value="_model.PostalCode" placeholder="Postal Code" />
                                <label for="postalCode">Postal Code (e.g. T2A 4K3)</label>
                                <ValidationMessage For="() => _model.PostalCode" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Employment Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="occupation" class="form-control" @bind-Value="_model.Occupation" placeholder="Occupation" />
                                <label for="occupation">Occupation</label>
                                <ValidationMessage For="() => _model.Occupation" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputText id="companyName" class="form-control" @bind-Value="_model.CompanyName" placeholder="Company Name" />
                                <label for="companyName">Company Name</label>
                                <ValidationMessage For="() => _model.CompanyName" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Membership Details</h5>
                </div>
                <div class="card-body">
                    <div class="form-floating mb-3">
                        <InputSelect id="membershipCategory" class="form-select" @bind-Value="_model.RequestedMembershipCategory">
                            <option value="">-- Select Category --</option>
                            @foreach (var category in Enum.GetValues<MembershipCategory>())
                            {
                                <option value="@category">@category</option>
                            }
                        </InputSelect>
                        <label for="membershipCategory">Membership Category</label>
                        <ValidationMessage For="() => _model.RequestedMembershipCategory" />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputNumber id="sponsor1" class="form-control" @bind-Value="_model.Sponsor1MemberNumber" placeholder="Sponsor 1 Member Number" />
                                <label for="sponsor1">Sponsor 1 Member Number</label>
                                <ValidationMessage For="() => _model.Sponsor1MemberNumber" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <InputNumber id="sponsor2" class="form-control" @bind-Value="_model.Sponsor2MemberNumber" placeholder="Sponsor 2 Member Number" />
                                <label for="sponsor2">Sponsor 2 Member Number</label>
                                <ValidationMessage For="() => _model.Sponsor2MemberNumber" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <button type="submit" class="btn btn-primary" disabled="@_submitting">
                    @if (_submitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Submit Application
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    private ApplicationFormModel _model = new();
    private bool _submitting;
    private bool _submitted;
    private string? _successMessage;
    private string? _errorMessage;

    private async Task HandleSubmitAsync()
    {
        _submitting = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            if (_model.Sponsor1MemberNumber == _model.Sponsor2MemberNumber)
            {
                _errorMessage = "Sponsor 1 and Sponsor 2 must be different members.";
                _submitting = false;
                return;
            }

            var sponsor1AccountId = await DbContext.MemberAccounts
                .Where(m => m.MemberNumber == _model.Sponsor1MemberNumber!.Value
                         && m.IsActive
                         && m.MembershipCategory == MembershipCategory.Shareholder)
                .Select(m => (int?)m.MemberAccountId)
                .FirstOrDefaultAsync();

            if (sponsor1AccountId is null)
            {
                _errorMessage = "Sponsor 1 member number was not found or is not an active Shareholder member.";
                _submitting = false;
                return;
            }

            var sponsor2AccountId = await DbContext.MemberAccounts
                .Where(m => m.MemberNumber == _model.Sponsor2MemberNumber!.Value
                         && m.IsActive
                         && m.MembershipCategory == MembershipCategory.Shareholder)
                .Select(m => (int?)m.MemberAccountId)
                .FirstOrDefaultAsync();

            if (sponsor2AccountId is null)
            {
                _errorMessage = "Sponsor 2 member number was not found or is not an active Shareholder member.";
                _submitting = false;
                return;
            }

            var normalizedPostalCode = NormalizePostalCode(_model.PostalCode!);

            var request = new SubmitApplicationRequest<Guid>(
                NewUserEmail: _model.Email!,
                NewUserPassword: _model.Password!,
                FirstName: _model.FirstName!,
                LastName: _model.LastName!,
                Occupation: _model.Occupation!,
                CompanyName: _model.CompanyName!,
                Address: _model.Address!,
                PostalCode: normalizedPostalCode,
                Phone: _model.Phone!,
                DateOfBirth: _model.DateOfBirth,
                RequestedMembershipCategory: _model.RequestedMembershipCategory!.Value,
                Sponsor1MemberId: sponsor1AccountId.Value,
                Sponsor2MemberId: sponsor2AccountId.Value,
                AlternatePhone: _model.AlternatePhone
            );

            await ApplicationService.SubmitApplicationAsync(request, CancellationToken.None);

            _successMessage = "Your membership application has been submitted successfully. You can now log in with your new account and will be notified once your application has been reviewed.";
            _submitted = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to submit membership application");
            _errorMessage = ex.Message.StartsWith("Failed to create user account:")
                ? ex.Message
                : "An unexpected error occurred while submitting your application. Please try again later.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string NormalizePostalCode(string postalCode)
    {
        var cleaned = postalCode.ToUpperInvariant().Replace(" ", "");
        return cleaned.Length == 6 ? $"{cleaned[..3]} {cleaned[3..]}" : postalCode.ToUpperInvariant();
    }

    private sealed class ApplicationFormModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string? Email { get; set; }

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters.")]
        public string? Password { get; set; }

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string? ConfirmPassword { get; set; }

        [Required(ErrorMessage = "First name is required.")]
        public string? FirstName { get; set; }

        [Required(ErrorMessage = "Last name is required.")]
        public string? LastName { get; set; }

        [Required(ErrorMessage = "Occupation is required.")]
        public string? Occupation { get; set; }

        [Required(ErrorMessage = "Company name is required.")]
        public string? CompanyName { get; set; }

        [Required(ErrorMessage = "Address is required.")]
        public string? Address { get; set; }

        [Required(ErrorMessage = "Postal code is required.")]
        [RegularExpression(@"^[A-Za-z]\d[A-Za-z]\s?\d[A-Za-z]\d$", ErrorMessage = "Enter a valid Canadian postal code (e.g. T2A 4K3).")]
        public string? PostalCode { get; set; }

        [Required(ErrorMessage = "Phone number is required.")]
        [RegularExpression(@"^\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$", ErrorMessage = "Enter a valid 10-digit Canadian phone number (e.g. (403) 555-1234).")]
        public string? Phone { get; set; }

        [Required(ErrorMessage = "Date of birth is required.")]
        public DateTime DateOfBirth { get; set; } = DateTime.Today.AddYears(-30);

        [RegularExpression(@"^\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$", ErrorMessage = "Enter a valid 10-digit Canadian phone number (e.g. (403) 555-1234).")]
        public string? AlternatePhone { get; set; }

        [Required(ErrorMessage = "Membership category is required.")]
        public MembershipCategory? RequestedMembershipCategory { get; set; }

        [Required(ErrorMessage = "Sponsor 1 member number is required.")]
        public int? Sponsor1MemberNumber { get; set; }

        [Required(ErrorMessage = "Sponsor 2 member number is required.")]
        public int? Sponsor2MemberNumber { get; set; }
    }
}
